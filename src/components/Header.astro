---
import { getEntries } from '../lib/contentful';

// Fetch latest changelogs from Contentful
let changelogs = [];
try {
  const response = await getEntries({ content_type: 'changelog', limit: 2, order: '-sys.createdAt' });
  if (response && response.items) {
    changelogs = response.items;
  }
} catch (e) {
  // Fallback if content type doesn't exist yet or fails
  changelogs = [];
}

const navItems = [
  {
    href: '/coverage',
    label: 'Coverage',
    align: 'left',
    overlay: [
      { href: '/coverage/global', label: 'Global Coverage', desc: 'Where we operate' },
      { href: '/coverage/vehicle-types', label: 'Vehicle Types', desc: 'Supported categories' },
      { href: '/coverage/quality', label: 'Studio Quality', desc: 'Our standard of excellence' },
      { href: '/coverage/regions', label: 'Regions', desc: 'Regional coverage' },
      { href: '/coverage/coming-soon', label: 'Coming Soon', desc: 'Future expansions' },
    ],
  },
  {
    href: '/pricing',
    label: 'Pricing',
    align: 'center',
    overlay: [
      { href: '/pricing/plans', label: 'Plans', desc: 'Simple, transparent pricing' },
      { href: '/pricing/comparison', label: 'Comparison', desc: 'See how we stack up' },
      { href: '/pricing/enterprise', label: 'Enterprise', desc: 'For large volume' },
      { href: '/pricing/startups', label: 'For Startups', desc: 'Special startup rates' },
    ],
  },
  {
    href: '/documentation',
    label: 'Documentation',
    align: 'center',
    overlay: [
      { href: '/documentation/api', label: 'API Reference', desc: 'Full endpoint details' },
      { href: '/documentation/guides', label: 'Guides', desc: 'Step-by-step tutorials' },
      { href: '/documentation/examples', label: 'Examples', desc: 'Code snippets' },
      { href: '/documentation/sdks', label: 'SDKs', desc: 'Client libraries' },
    ],
  },
  {
    href: '/faq',
    label: 'FAQ',
    align: 'center',
    overlay: [
      { href: '/faq/general', label: 'General', desc: 'Common questions' },
      { href: '/faq/api', label: 'API', desc: 'Technical answers' },
      { href: '/faq/billing', label: 'Billing', desc: 'Payment questions' },
      { href: '/faq/support', label: 'Support', desc: 'Get assistance' },
    ],
  },
  {
    href: '/contact',
    label: 'Contact',
    align: 'right',
    overlay: [
      { href: '/contact/sales', label: 'Sales', desc: 'Enterprise inquiries' },
      { href: '/contact/support', label: 'Support', desc: 'Technical assistance' },
      { href: '/contact/partners', label: 'Partners', desc: 'Partnership program' },
      { href: '/contact/press', label: 'Press', desc: 'Media kit & news' },
    ],
  },
];
---

<header id="site-header" class="sticky top-0 z-50 border-b border-white/10 bg-[#1C2B32] transition-transform duration-300 ease-out" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">
  <div style="position:relative; width:100%; padding-left:48px; padding-right:48px;">
    <nav style="display:flex; height:5rem; width:100%; align-items:center;">
      
      <!-- Linker Bereich: Logo & Menü direkt daneben -->
      <div style="display:flex; align-items:center; gap:3rem;">
        <!-- Logo -->
        <a href="/" class="group flex shrink-0 items-center transition-opacity hover:opacity-80">
          <img 
            src="/vehicle_imagery_logo.png" 
            alt="Vehicle Imagery" 
            class="h-[38px] w-auto brightness-0 invert" 
          />
        </a>

        <!-- Navigation (Links neben dem Logo) -->
        <div class="hidden items-center gap-9 md:flex relative" id="nav-menu">
          {navItems.map((item) => (
            <div class="group/nav relative flex h-20 items-center" data-nav-item>
              <a
                href={item.href}
                class="peer relative text-[14px] font-medium text-white/80 transition-colors duration-200 hover:text-white"
              >
                {item.label}
                <span class="pointer-events-none absolute -bottom-[31px] left-0 h-[3px] w-0 bg-white opacity-0 transition-all duration-300 group-hover/nav:w-full group-hover/nav:opacity-100 z-[60]"></span>
              </a>
              
              <!-- Bridge (unsichtbar) für den Hover -->
              <div class="absolute top-[80px] left-0 h-[30px] w-full bg-transparent z-[40]"></div>
              
              <!-- Overlay: Positioniert unter dem ausgewählten Nav-Punkt -->
              <div class="nav-overlay pointer-events-none fixed top-[80px] z-50 w-[860px] opacity-0 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-4 group-hover/nav:pointer-events-auto group-hover/nav:translate-y-0 group-hover/nav:opacity-100" style="left: 0;">
                
                <!-- Visuelle Verbindungslinie zum Menü -->
                <div class="absolute -top-[1px] left-0 h-[1px] w-full bg-white/20"></div>

                <!-- Eckige Box mit scharfen Kanten -->
                <div class="border border-white/15 bg-[#1C2B32] shadow-[0_30px_80px_-15px_rgba(0,0,0,0.6)] relative overflow-hidden">
                  
                  <!-- Abstract Background Element per Menu Item -->
                  <div class="absolute -right-20 -top-20 opacity-[0.03] pointer-events-none select-none">
                    {item.label === 'Coverage' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                    {item.label === 'Pricing' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
                    {item.label === 'Documentation' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>}
                    {item.label === 'FAQ' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01"/></svg>}
                    {item.label === 'Contact' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>}
                  </div>

                  <div class="grid grid-cols-12 relative z-10">
                  <!-- Linke Spalte: Links -->
                  <div class="col-span-5 border-r border-white/10 p-8">
                    <h3 class="mb-5 text-[11px] font-bold uppercase tracking-[0.15em] text-white/40">Explore {item.label}</h3>
                    <ul class="flex flex-col gap-1">
                      {item.overlay.map((sub) => (
                        <li>
                          <a href={sub.href} class="group/item flex flex-col justify-center px-4 py-3 -mx-4 border border-transparent transition-colors hover:bg-white/5">
                            <span class="text-[14px] font-bold text-white/90 transition-colors group-hover/item:text-white">{sub.label}</span>
                            <span class="text-[12px] font-medium text-white/40 transition-colors group-hover/item:text-white/60">{sub.desc}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <!-- Mittlere Spalte: Changelogs -->
                  <div class="col-span-4 border-r border-white/10 p-8">
                    <h3 class="mb-5 text-[11px] font-bold uppercase tracking-[0.15em] text-white/40">Latest Changelogs</h3>
                    <div class="flex flex-col gap-6">
                      {changelogs.length > 0 ? (
                        changelogs.map((log) => (
                          <a href={`/changelog/${log.fields.slug || ''}`} class="group/feat flex flex-col gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-[#FF8844]">
                              {new Date(log.sys.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                            </span>
                            <h4 class="text-[14px] font-bold leading-snug text-white/90 transition-colors duration-200 group-hover/feat:text-white">
                              {log.fields.title}
                            </h4>
                          </a>
                        ))
                      ) : (
                        <div class="flex flex-col gap-2 opacity-60">
                          <span class="text-[10px] font-bold uppercase tracking-widest text-white/40">Updates</span>
                          <h4 class="text-[14px] font-medium leading-snug text-white/60">
                            No changelogs available yet.
                          </h4>
                        </div>
                      )}
                    </div>
                  </div>

                  <!-- Rechte Spalte: Contact -->
                  <div class="col-span-3 bg-[#25363F] p-8 flex flex-col justify-between">
                    <div>
                      <h3 class="mb-5 text-[11px] font-bold uppercase tracking-[0.15em] text-white/40">Need Help?</h3>
                      <p class="text-[13px] leading-relaxed text-white/60 mb-6">
                        Get in touch with our team for custom requests and technical support.
                      </p>
                    </div>
                    <a href="/contact" class="group/contact flex items-center justify-between border border-white/20 bg-transparent px-4 py-3 text-[13px] font-bold text-white transition-all duration-300 hover:border-white/50 hover:bg-white/5">
                      <span>Contact Us</span>
                      <svg class="h-4 w-4 transition-transform duration-300 group-hover/contact:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="square" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA Buttons -->
      <div style="position:absolute; right:48px; top:50%; transform:translateY(-50%); display:flex; align-items:center; gap:0.75rem;">
        <a
          href="/book-a-call"
          class="hidden h-[38px] items-center justify-center border border-white/40 bg-transparent px-5 text-[13px] font-medium text-white transition-all duration-300 hover:border-white hover:bg-white/5 sm:inline-flex"
        >
          Book a Call
        </a>
        <a
          href="/try-it-out"
          class="inline-flex h-[38px] items-center justify-center border border-white bg-white px-5 text-[13px] font-medium text-[rgb(10,43,49)] transition-all duration-300 hover:bg-[rgb(255,254,252)] hover:shadow-[0_0_15px_rgba(255,255,255,0.15)]"
        >
          Try Now
        </a>
        
        <!-- Mobile Menu Button -->
        <button
          type="button"
          class="flex h-10 w-10 items-center justify-center text-white/80 transition-colors hover:text-white md:hidden"
          aria-label="Menü öffnen"
          id="mobile-menu-btn"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" viewBox="0 0 24 24">
            <path d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div class="hidden border-t border-white/10 pb-6 pt-2 md:hidden" id="mobile-menu">
      <div class="space-y-0">
        {navItems.map((item) => (
          <div class="border-b border-white/5">
            <a
              href={item.href}
              class="block bg-white/5 px-4 py-3.5 text-[15px] font-semibold text-white/90 uppercase tracking-wide"
            >
              {item.label}
            </a>
            <div class="flex flex-col bg-[#1C2B32] px-2 py-2">
              {item.overlay.map((sub) => (
                <a
                  href={sub.href}
                  class="px-4 py-3 text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5 hover:text-white"
                >
                  {sub.label}
                </a>
              ))}
            </div>
          </div>
        ))}
        <div class="mt-6 flex flex-col gap-3 px-4">
          <a
            href="/book-a-call"
            class="flex items-center justify-center border border-white/40 py-3.5 text-[14px] font-medium text-white transition-colors hover:bg-white/10"
          >
            Book a Call
          </a>
          <a
            href="/try-it-out"
            class="flex items-center justify-center border border-white/40 py-3.5 text-[14px] font-medium text-white transition-colors hover:bg-white/10"
          >
            Try Now
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }

  // Header hide on scroll down, show on scroll up
  (function() {
    const header = document.getElementById('site-header');
    if (!header) return;
    let lastScrollY = window.scrollY;
    let ticking = false;
    function updateHeader() {
      const scrollY = window.scrollY;
      if (scrollY > lastScrollY && scrollY > 80) {
        header.classList.add('-translate-y-full');
      } else {
        header.classList.remove('-translate-y-full');
      }
      lastScrollY = scrollY;
      ticking = false;
    }
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateHeader);
        ticking = true;
      }
    }, { passive: true });
  })();

  function positionOverlays() {
    const navItems = document.querySelectorAll('[data-nav-item]');
    navItems.forEach((item) => {
      const overlay = item.querySelector('.nav-overlay');
      if (!overlay) return;
      const rect = item.getBoundingClientRect();
      let left = rect.left;
      const overlayWidth = 860;
      const maxLeft = window.innerWidth - overlayWidth;
      if (left > maxLeft) left = maxLeft;
      if (left < 0) left = 0;
      overlay.style.left = left + 'px';
    });
  }

  positionOverlays();
  window.addEventListener('resize', positionOverlays);
</script>