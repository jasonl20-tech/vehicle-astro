---
import { getEntries } from '../lib/contentful';
import { getLocaleFromUrl, useTranslations, localizeUrl, stripLocalePrefix, localeNames, type Locale, locales, defaultLocale } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const l = (url: string) => localizeUrl(url, locale);

const currentPath = stripLocalePrefix(Astro.url.pathname);
const localeOptions = locales.map((loc) => ({
  locale: loc,
  label: localeNames[loc],
  href: localizeUrl(currentPath, loc),
  isActive: loc === locale,
}));

let changelogs: any[] = [];
try {
  const response = await getEntries({ content_type: 'api', limit: 2, order: '-sys.createdAt' });
  if (response && response.items) {
    changelogs = response.items as any[];
  }
} catch {
  changelogs = [];
}

const navItems = [
  {
    href: l('/coverage'),
    label: t('nav.coverage'),
    align: 'left',
    svgKey: 'Coverage',
    overlay: [
      { href: l('/coverage/global'), label: t('nav.coverage.global'), desc: t('nav.coverage.globalDesc') },
      { href: l('/coverage/vehicle-types'), label: t('nav.coverage.vehicleTypes'), desc: t('nav.coverage.vehicleTypesDesc') },
      { href: l('/coverage/quality'), label: t('nav.coverage.quality'), desc: t('nav.coverage.qualityDesc') },
    ],
  },
  {
    href: l('/pricing'),
    label: t('nav.pricing'),
    align: 'center',
    svgKey: 'Pricing',
    overlay: [
      { href: l('/pricing'), label: t('nav.pricing.trial'), desc: t('nav.pricing.trialDesc') },
      { href: l('/pricing'), label: t('nav.pricing.onRequest'), desc: t('nav.pricing.onRequestDesc') },
      { href: l('/pricing/startups'), label: t('nav.pricing.startups'), desc: t('nav.pricing.startupsDesc') },
    ],
  },
  {
    href: l('/documentation'),
    label: t('nav.documentation'),
    align: 'center',
    svgKey: 'Documentation',
    overlay: [
      { href: l('/documentation#authentication'), label: t('nav.docs.apiRef'), desc: t('nav.docs.apiRefDesc') },
      { href: l('/documentation#query-params'), label: t('nav.docs.params'), desc: t('nav.docs.paramsDesc') },
      { href: l('/documentation#brands'), label: t('nav.docs.endpoints'), desc: t('nav.docs.endpointsDesc') },
      { href: l('/documentation#errors'), label: t('nav.docs.errors'), desc: t('nav.docs.errorsDesc') },
    ],
  },
  {
    href: l('/faq'),
    label: t('nav.faq'),
    align: 'center',
    svgKey: 'FAQ',
    overlay: [
      { href: l('/faq/general'), label: t('nav.faq.general'), desc: t('nav.faq.generalDesc') },
      { href: l('/faq/api'), label: t('nav.faq.api'), desc: t('nav.faq.apiDesc') },
      { href: l('/faq/billing'), label: t('nav.faq.billing'), desc: t('nav.faq.billingDesc') },
      { href: l('/faq/support'), label: t('nav.faq.support'), desc: t('nav.faq.supportDesc') },
    ],
  },
  {
    href: l('/contact'),
    label: t('nav.contact'),
    align: 'right',
    svgKey: 'Contact',
    overlay: [
      { href: l('/team'), label: t('nav.contact.team'), desc: t('nav.contact.teamDesc') },
      { href: l('/support'), label: t('nav.contact.support'), desc: t('nav.contact.supportDesc') },
      { href: l('/partners'), label: t('nav.contact.partners'), desc: t('nav.contact.partnersDesc') },
      { href: l('/press'), label: t('nav.contact.press'), desc: t('nav.contact.pressDesc') },
    ],
  },
];
---

<header id="site-header" class="sticky top-0 z-50 border-b border-white/10 bg-[#1C2B32] transition-transform duration-300 ease-out" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">
  <div class="relative w-full px-4 sm:px-6 lg:px-12">
    <nav class="relative flex h-14 sm:h-16 md:h-20 w-full items-center">
      
      <div class="flex flex-1 items-center gap-6 lg:gap-9">
        <a href={l('/')} class="group flex shrink-0 items-center transition-opacity hover:opacity-80" aria-label="Vehicle Imagery Home">
          <img
            src="/logo.svg"
            alt="Vehicle Imagery"
            class="h-8 w-auto brightness-0 invert sm:h-[38px]"
          />
        </a>

        <div class="hidden items-center gap-6 lg:gap-9 md:flex relative" id="nav-menu">
          {navItems.map((item) => (
            <div class="group/nav relative flex h-20 items-center" data-nav-item>
              <a
                href={item.href}
                class="peer relative text-[13px] lg:text-[14px] font-medium text-white/80 transition-colors duration-200 hover:text-white"
              >
                {item.label}
                <span class="pointer-events-none absolute -bottom-[31px] left-0 h-[3px] w-0 bg-white opacity-0 transition-all duration-300 group-hover/nav:w-full group-hover/nav:opacity-100 z-[60]"></span>
              </a>
              
              <div class="absolute top-[80px] left-0 h-[30px] w-full bg-transparent z-[40]"></div>
              
              <div class="nav-overlay pointer-events-none fixed top-[80px] z-50 w-[calc(100vw-2rem)] max-w-[860px] opacity-0 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-4 group-hover/nav:pointer-events-auto group-hover/nav:translate-y-0 group-hover/nav:opacity-100 left-0" style="left: 0;">
                
                <div class="absolute -top-[1px] left-0 h-[1px] w-full bg-white/20"></div>

                <div class="border border-white/15 bg-[#1C2B32] shadow-[0_30px_80px_-15px_rgba(0,0,0,0.6)] relative overflow-hidden">
                  
                  <div class="absolute -right-20 -top-20 opacity-[0.03] pointer-events-none select-none">
                    {item.svgKey === 'Coverage' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                    {item.svgKey === 'Pricing' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
                    {item.svgKey === 'Documentation' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>}
                    {item.svgKey === 'FAQ' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01"/></svg>}
                    {item.svgKey === 'Contact' && <svg class="w-96 h-96" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="0.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>}
                  </div>

                  <div class="grid grid-cols-1 lg:grid-cols-12 relative z-10">
                  <div class="lg:col-span-5 border-b border-white/10 lg:border-b-0 lg:border-r border-white/10 p-4 sm:p-6 lg:p-8">
                    <h3 class="mb-5 text-[11px] font-bold uppercase tracking-[0.15em] text-white/40">{t('nav.explore')} {item.label}</h3>
                    <ul class="flex flex-col gap-1">
                      {item.overlay.map((sub) => (
                        <li>
                          <a href={sub.href} class="group/item flex flex-col justify-center px-4 py-3 -mx-4 border border-transparent transition-colors hover:bg-white/5">
                            <span class="text-[14px] font-bold text-white/90 transition-colors group-hover/item:text-white">{sub.label}</span>
                            <span class="text-[12px] font-medium text-white/40 transition-colors group-hover/item:text-white/60">{sub.desc}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="lg:col-span-4 border-b border-white/10 lg:border-b-0 lg:border-r border-white/10 p-4 sm:p-6 lg:p-8">
                    <h3 class="mb-5 text-[11px] font-bold uppercase tracking-[0.15em] text-white/40">{t('nav.latestChangelogs')}</h3>
                    <div class="flex flex-col gap-6">
                      {changelogs.length > 0 ? (
                        changelogs.map((log: any) => (
                          <a href={l(`/changelog/${log.fields.slug || ''}`)} class="group/feat flex flex-col gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-[#FF8844]">
                              {new Date(log.sys.createdAt).toLocaleDateString(locale === 'es' ? 'es-ES' : 'en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                            </span>
                            <h4 class="text-[14px] font-bold leading-snug text-white/90 transition-colors duration-200 group-hover/feat:text-white">
                              {log.fields.title}
                            </h4>
                          </a>
                        ))
                      ) : (
                        <div class="flex flex-col gap-2 opacity-60">
                          <span class="text-[10px] font-bold uppercase tracking-widest text-white/40">{t('nav.updates')}</span>
                          <h4 class="text-[14px] font-medium leading-snug text-white/60">
                            {t('nav.noChangelogs')}
                          </h4>
                        </div>
                      )}
                    </div>
                  </div>

                  <div class="lg:col-span-3 bg-[#25363F] p-4 sm:p-6 lg:p-8 flex flex-col justify-between">
                    <div>
                      <h3 class="mb-5 text-[11px] font-bold uppercase tracking-[0.15em] text-white/40">{t('nav.needHelp')}</h3>
                      <p class="text-[13px] leading-relaxed text-white/60 mb-6">
                        {t('nav.needHelpDesc')}
                      </p>
                    </div>
                    <a href={l('/contact')} class="group/contact flex items-center justify-between border border-white/20 bg-transparent px-4 py-3 text-[13px] font-bold text-white transition-all duration-300 hover:border-white/50 hover:bg-white/5">
                      <span>{t('nav.contactUs')}</span>
                      <svg class="h-4 w-4 transition-transform duration-300 group-hover/contact:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="square" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="absolute right-4 top-1/2 flex -translate-y-1/2 items-center gap-2 sm:right-6 sm:gap-3 lg:right-12">
        <!-- Language Dropdown -->
        <div class="lang-dropdown group/lang relative hidden sm:block">
          <button
            type="button"
            class="lang-dropdown-trigger flex h-9 min-w-[72px] items-center justify-between gap-1.5 border border-white/25 bg-transparent px-3 text-[12px] font-bold uppercase tracking-wider text-white/70 transition-colors hover:border-white/50 hover:text-white"
            aria-haspopup="listbox"
            aria-expanded="false"
            aria-controls="lang-dropdown-menu"
            id="lang-dropdown-btn"
          >
            <span>{localeNames[locale]}</span>
            <svg class="h-3.5 w-3.5 transition-transform duration-200 group-[.open]/lang:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div id="lang-dropdown-menu" role="listbox" class="lang-dropdown-menu pointer-events-none absolute right-0 top-full z-[60] mt-1 min-w-[140px] translate-y-1 opacity-0 transition-all duration-200 group-[.open]/lang:pointer-events-auto group-[.open]/lang:translate-y-0 group-[.open]/lang:opacity-100">
            <div class="border border-white/15 bg-[#1C2B32] shadow-lg">
              {localeOptions.map((opt) => (
                <a
                  href={opt.href}
                  role="option"
                  aria-selected={opt.isActive}
                  class={`block px-4 py-2.5 text-[13px] font-medium transition-colors ${opt.isActive ? 'bg-white/10 text-white' : 'text-white/80 hover:bg-white/5 hover:text-white'}`}
                >
                  <span class="flex items-center gap-2">
                    {opt.isActive && <svg class="h-4 w-4 text-[#FF8844]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>}
                    {opt.label}
                  </span>
                </a>
              ))}
            </div>
          </div>
        </div>
        <a
          href={l('/book-a-call')}
          class="hidden h-9 items-center justify-center border border-white/40 bg-transparent px-4 text-[13px] font-medium text-white transition-colors hover:border-white hover:bg-white/5 sm:inline-flex"
        >
          {t('nav.bookACall')}
        </a>
        <a
          href={l('/trial')}
          class="inline-flex h-9 items-center justify-center border border-white bg-white px-4 text-[13px] font-medium text-[rgb(10,43,49)] transition-colors hover:bg-[rgb(255,254,252)] hover:shadow-[0_0_15px_rgba(255,255,255,0.15)]"
        >
          {t('nav.tryNow')}
        </a>
        <button
          type="button"
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md text-white/80 transition-colors hover:bg-white/10 hover:text-white md:hidden"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          id="mobile-menu-btn"
        >
          <svg class="h-6 w-6" id="mobile-menu-icon-open" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="hidden h-6 w-6" id="mobile-menu-icon-close" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>

    <div class="hidden border-t border-white/10 bg-[#1C2B32] md:hidden" id="mobile-menu" role="dialog" aria-label="Navigation menu">
      <div class="flex items-center justify-between border-b border-white/10 px-4 py-3">
        <span class="text-xs font-semibold uppercase tracking-wider text-white/50">{t('nav.menu')}</span>
        <button type="button" class="flex h-9 w-9 items-center justify-center rounded-md text-white/70 hover:bg-white/10 hover:text-white" aria-label="Close menu" id="mobile-menu-close">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div class="max-h-[calc(100vh-8rem)] overflow-y-auto pb-6">
        {navItems.map((item, idx) => (
          <div class="border-b border-white/5" data-mobile-nav-item>
            <div class="flex items-center justify-between gap-2">
              <a href={item.href} class="flex-1 py-3.5 pl-4 pr-2 text-[15px] font-semibold text-white/95">{item.label}</a>
              <button type="button" class="mobile-nav-toggle flex h-11 w-11 shrink-0 items-center justify-center text-white/60 hover:bg-white/5 hover:text-white" aria-expanded="false" aria-controls={`mobile-sub-${idx}`} id={`mobile-toggle-${idx}`} data-mobile-toggle data-target={`mobile-sub-${idx}`}>
                <svg class="h-5 w-5 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
            </div>
            <div id={`mobile-sub-${idx}`} class="hidden flex-col border-t border-white/5 bg-[#0f1a1d] pb-2" data-mobile-sub>
              {item.overlay.map((sub) => (
                <a href={sub.href} class="mobile-menu-link block border-l-2 border-transparent py-2.5 pl-6 pr-4 text-[14px] font-medium text-white/75 transition-colors hover:border-white/30 hover:bg-white/5 hover:text-white">
                  {sub.label}
                </a>
              ))}
            </div>
          </div>
        ))}
        <!-- Mobile language switcher -->
        <div class="border-b border-white/5 px-4 py-3">
          <p class="text-[11px] font-bold uppercase tracking-widest text-white/40 mb-2">Idioma / Language</p>
          <div class="flex flex-col gap-1">
            {localeOptions.map((opt) => (
              <a href={opt.href} class={`mobile-menu-link flex items-center gap-2 py-2.5 px-3 text-[14px] font-medium rounded transition-colors ${opt.isActive ? 'bg-white/10 text-white' : 'text-white/75 hover:bg-white/5 hover:text-white'}`}>
                {opt.isActive && <svg class="h-4 w-4 text-[#FF8844] shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>}
                {opt.label}
              </a>
            ))}
          </div>
        </div>
        <div class="mt-4 flex flex-col gap-3 px-4">
          <a href={l('/book-a-call')} class="mobile-menu-link flex items-center justify-center border border-white/40 py-3.5 text-[14px] font-medium text-white transition-colors hover:bg-white/10">
            {t('nav.bookACall')}
          </a>
          <a href={l('/trial')} class="mobile-menu-link flex items-center justify-center border border-white py-3.5 text-[14px] font-medium text-[rgb(10,43,49)] transition-colors hover:bg-white/90">
            {t('nav.tryNow')}
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  (function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const closeBtn = document.getElementById('mobile-menu-close');
    const iconOpen = document.getElementById('mobile-menu-icon-open');
    const iconClose = document.getElementById('mobile-menu-icon-close');

    function openMenu() {
      menu?.classList.remove('hidden');
      btn?.setAttribute('aria-expanded', 'true');
      btn?.setAttribute('aria-label', 'Close menu');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      btn?.setAttribute('aria-label', 'Open menu');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      document.body.style.overflow = '';
      document.querySelectorAll('[data-mobile-sub]').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('[data-mobile-toggle]').forEach(el => { el.setAttribute('aria-expanded', 'false'); el.querySelector('svg')?.classList.remove('rotate-180'); });
    }

    btn?.addEventListener('click', () => { if (menu?.classList.contains('hidden')) openMenu(); else closeMenu(); });
    closeBtn?.addEventListener('click', closeMenu);

    document.querySelectorAll('.mobile-menu-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    document.querySelectorAll('[data-mobile-toggle]').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        const target = targetId ? document.getElementById(targetId) : null;
        if (!target) return;
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        if (isExpanded) {
          target.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
          btn.querySelector('svg')?.classList.remove('rotate-180');
        } else {
          target.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
          btn.querySelector('svg')?.classList.add('rotate-180');
        }
      });
    });

    window.addEventListener('resize', () => { if (window.innerWidth >= 768) closeMenu(); });
  })();

  (function initLangDropdown() {
    const btn = document.getElementById('lang-dropdown-btn');
    const dropdown = btn?.closest('.lang-dropdown');
    const menu = document.getElementById('lang-dropdown-menu');
    if (!btn || !dropdown || !menu) return;

    function openDropdown() {
      dropdown?.classList.add('open');
      btn?.setAttribute('aria-expanded', 'true');
    }
    function closeDropdown() {
      dropdown?.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
    }
    function toggleDropdown() {
      dropdown?.classList.contains('open') ? closeDropdown() : openDropdown();
    }

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      toggleDropdown();
    });

    document.addEventListener('click', (e) => {
      if (dropdown && !dropdown.contains(e.target)) closeDropdown();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDropdown();
    });
  })();

  (function() {
    const header = document.getElementById('site-header');
    if (!header) return;
    let lastScrollY = window.scrollY;
    let ticking = false;
    function updateHeader() {
      const scrollY = window.scrollY;
      if (scrollY > lastScrollY && scrollY > 80) {
        header.classList.add('-translate-y-full');
      } else {
        header.classList.remove('-translate-y-full');
      }
      lastScrollY = scrollY;
      ticking = false;
    }
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateHeader);
        ticking = true;
      }
    }, { passive: true });
  })();

  function positionOverlays() {
    const navItems = document.querySelectorAll('[data-nav-item]');
    navItems.forEach((item) => {
      const overlay = item.querySelector('.nav-overlay');
      if (!overlay) return;
      const rect = item.getBoundingClientRect();
      let left = rect.left;
      const overlayWidth = (overlay as HTMLElement).offsetWidth;
      const maxLeft = window.innerWidth - overlayWidth - 16;
      if (left > maxLeft) left = Math.max(8, maxLeft);
      if (left < 8) left = 8;
      (overlay as HTMLElement).style.left = left + 'px';
    });
  }

  if (document.querySelector('[data-nav-item]')) {
    positionOverlays();
    window.addEventListener('resize', positionOverlays);
  }
</script>
