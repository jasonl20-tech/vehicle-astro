---
interface Props {
  title?: string;
  description?: string;
  buttonLabel?: string;
  buttonUrl?: string;
  secondaryLabel?: string;
  secondaryUrl?: string;
}

const {
  title = 'Start building today',
  description = 'Free Trial or custom quote — we\'ll get back to you within 24 hours.',
  buttonLabel = 'Contact Sales',
  buttonUrl = '/contact',
  secondaryLabel = 'Documentation',
  secondaryUrl = '/documentation',
} = Astro.props;
---

<section class="pb-24 sm:pb-32">
  <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
    <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] px-8 py-20 sm:px-16 sm:py-24" style="background-color: rgb(10, 43, 49);">
      <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
      <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full opacity-[0.04] pointer-events-none" style="background: radial-gradient(circle, white 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="relative z-10 text-center max-w-2xl mx-auto">
        <h2 class="text-4xl sm:text-5xl font-light tracking-tight text-white leading-[1.05] mb-6">{title}</h2>
        {description && (
          <p class="text-[14px] text-white/45 leading-relaxed mb-12 max-w-md mx-auto">{description}</p>
        )}
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          {buttonLabel && buttonUrl && (
            <a href={buttonUrl} class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[13px] font-medium text-black transition-all duration-300 hover:bg-[rgb(200,90,70)] hover:text-white">
              {buttonLabel}
            </a>
          )}
          {secondaryLabel && secondaryUrl && (
            <a href={secondaryUrl} class="inline-flex items-center justify-center rounded-full border border-white/15 px-8 py-4 text-[13px] font-medium text-white/70 transition-all duration-300 hover:bg-white/10 hover:text-white">
              {secondaryLabel}
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
