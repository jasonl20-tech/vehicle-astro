---
---

<footer class="text-white pt-24 pb-12 w-full border-t border-white/10" style="background-color:rgb(10, 43, 49); font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">
  <div class="w-full px-6 sm:px-12 md:px-16 lg:px-20 xl:px-24">
    <div class="w-full mx-auto">
      <!-- Top area: Logo + CTAs + Fleet image -->
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-20 gap-12 border-b border-white/10 pb-12">
        <div class="max-w-xl">
          <div class="flex items-center space-x-3 mb-6">
            <img src="/logo.svg" alt="Vehicle Imagery Logo" class="h-12 w-auto brightness-0 invert" loading="lazy" draggable="false"/>
          </div>
          <p class="text-gray-400 text-lg leading-relaxed mb-8">The developer-first vehicle imagery API.<br/>Studio quality. Global CDN. Transparent pricing.</p>
          <div class="flex gap-4">
            <a class="bg-white text-black px-6 py-3 rounded-none font-bold uppercase tracking-widest hover:bg-[rgb(200,90,70)] hover:text-white transition-colors" href="/contact">Get API Key</a>
            <a class="border border-white/30 text-white px-6 py-3 rounded-none font-bold uppercase tracking-widest hover:bg-white/10 transition-colors" href="/contact">Contact Sales</a>
          </div>
        </div>
        <div class="w-full lg:w-auto flex flex-col items-end">
          <picture><source srcset="/images/footer_vehicles.webp" type="image/webp" /><img alt="Vehicle fleet showcase" loading="lazy" decoding="async" width="1200" height="300" class="h-24 md:h-32 w-auto object-contain opacity-80 mb-6" src="/images/footer_vehicles.png" draggable="false"/></picture>
          <p class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Stay updated</p>
          <form class="flex flex-col sm:flex-row gap-2" action="https://submit-form.com/v6dFS1FAS" method="POST">
            <input type="hidden" name="subject" value="Newsletter Subscribe"/>
            <input type="email" name="email" required placeholder="Enter email address" class="px-4 py-3 bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:outline-none focus:border-white w-full sm:w-80 rounded-none"/>
            <button type="submit" class="px-6 py-3 font-bold uppercase tracking-widest transition-colors rounded-none bg-white text-black hover:bg-gray-200">Subscribe</button>
          </form>
        </div>
      </div>

      <!-- Link columns: nur vorhandene Seiten + administrative Links -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 mb-12 items-start">
        <div>
          <h4 class="font-bold text-white mb-6 uppercase tracking-widest text-xs opacity-70">Resources</h4>
          <ul class="space-y-4 text-sm text-gray-400">
            <li><a class="hover:text-white transition-colors" href="/blog">Blog & Updates</a></li>
            <li><a class="hover:text-white transition-colors" href="/changelog">Changelog</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-white mb-6 uppercase tracking-widest text-xs opacity-70">Company</h4>
          <ul class="space-y-4 text-sm text-gray-400">
            <li><a class="hover:text-white transition-colors" href="/contact">Contact</a></li>
            <li><a class="hover:text-white transition-colors" href="/impressum">Imprint</a></li>
          </ul>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-6">
        <p class="text-sm text-gray-500">© {new Date().getFullYear()} Vehicle Imagery. Made with German engineering.</p>
        <div class="flex items-center gap-6 text-sm text-gray-500">
          <a class="hover:text-white transition-colors" href="/legal">Legal Notice</a>
          <a class="hover:text-white transition-colors" href="/privacy">Privacy Policy</a>
          <a class="hover:text-white transition-colors" href="/terms">Terms of Service</a>
          <a class="hover:text-white transition-colors" href="/cookies">Cookie Settings</a>
        </div>
        <div class="flex items-center gap-4">
          <a class="text-gray-500 hover:text-white transition-colors" href="https://twitter.com" aria-label="X (Twitter)">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
          </a>
          <a class="text-gray-500 hover:text-white transition-colors" href="https://linkedin.com" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
