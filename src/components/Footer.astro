---
import { getEntries } from '../lib/contentful';
import { getLocaleFromUrl, useTranslations, localizeUrl, getContentfulLocale, type Locale } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const l = (url: string) => localizeUrl(url, locale);
const cfLocale = getContentfulLocale(locale);

interface DynamicLink {
  label: string;
  href: string;
  order: number;
}

interface DynamicCategory {
  name: string;
  links: DynamicLink[];
}

let dynamicCategories: DynamicCategory[] = [];

try {
  const res = await getEntries({ content_type: 'dynamicPage-2', limit: 500, locale: cfLocale });
  const footerItems = (res.items as any[]).filter((item) => item.fields?.footer === true);

  const catMap = new Map<string, DynamicLink[]>();
  for (const item of footerItems) {
    const f = item.fields;
    const category = (f.category as string) || 'Other';
    const slug = f.slug as string;
    const prefix = f.urlPrefix as string | undefined;
    const href = l(prefix ? `/${prefix}/${slug}` : `/${slug}`);
    const label = (f.footerLabel as string) || (f.title as string) || slug;
    const order = (f.order as number) || 999;

    if (!catMap.has(category)) catMap.set(category, []);
    catMap.get(category)!.push({ label, href, order });
  }

  for (const [name, links] of catMap) {
    links.sort((a, b) => a.order - b.order);
    dynamicCategories.push({ name, links });
  }
  dynamicCategories.sort((a, b) => a.name.localeCompare(b.name));
} catch {
  dynamicCategories = [];
}

const MAX_LINKS = 6;
---

<footer class="text-white pt-24 pb-12 w-full border-t border-white/10" style="background-color:rgb(10, 43, 49); font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">
  <div class="w-full px-4 sm:px-6 md:px-12 lg:px-20 xl:px-24">
    <div class="w-full mx-auto">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-20 gap-12 border-b border-white/10 pb-12">
        <div class="max-w-xl">
          <div class="flex items-center space-x-3 mb-6">
            <img src="/logo.svg" alt="Vehicle Imagery Logo" class="h-12 w-auto brightness-0 invert" loading="lazy" draggable="false"/>
          </div>
          <p class="text-gray-300 text-lg leading-relaxed mb-8">{t('footer.tagline')}<br/>{t('footer.taglineDetails')}</p>
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
            <a class="bg-white text-black px-6 py-3 rounded-none font-bold uppercase tracking-widest hover:bg-[rgb(200,90,70)] hover:text-white transition-colors text-center sm:text-left" href={l('/trial')}>{t('footer.getApiKey')}</a>
            <a class="border border-white/30 text-white px-6 py-3 rounded-none font-bold uppercase tracking-widest hover:bg-white/10 transition-colors text-center sm:text-left" href={l('/book-a-call')}>{t('footer.bookACall')}</a>
          </div>
        </div>
        <div class="w-full lg:w-auto flex flex-col items-center text-center lg:items-end lg:text-left">
          <picture><source srcset="/images/footer_vehicles.webp" type="image/webp" /><img alt="Vehicle fleet showcase" loading="lazy" decoding="async" width="1200" height="300" class="h-24 md:h-32 w-auto object-contain opacity-80 mb-6" src="/images/footer_vehicles.png" draggable="false"/></picture>
          <p class="text-sm font-bold uppercase tracking-widest text-gray-300 mb-4">{t('footer.stayUpdated')}</p>
          <div id="footer-nl-wrapper">
            <div id="footer-nl-content">
              <form id="footer-nl-form" class="flex w-full max-w-sm flex-col sm:flex-row gap-2 sm:max-w-none">
                <input type="hidden" name="subject" value="Newsletter Subscribe"/>
                <input type="email" name="email" required placeholder={t('footer.enterEmail')} class="px-4 py-3 bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:outline-none focus:border-white w-full sm:w-80 rounded-none"/>
                <button type="submit" id="footer-nl-btn" class="px-6 py-3 font-bold uppercase tracking-widest transition-colors rounded-none bg-white text-black hover:bg-gray-200">{t('footer.subscribe')}</button>
              </form>
            </div>
            <div id="footer-nl-success" class="hidden items-center gap-3">
              <svg class="h-5 w-5 text-emerald-400" viewBox="0 0 52 52" fill="none">
                <circle cx="26" cy="26" r="24" stroke="currentColor" stroke-width="2.5" fill="none" stroke-dasharray="150.8" stroke-dashoffset="150.8" class="fnl-circle" />
                <path d="M15 27L23 35L37 19" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" stroke-dasharray="40" stroke-dashoffset="40" class="fnl-check" />
              </svg>
              <p class="text-white text-sm font-bold uppercase tracking-widest">{t('footer.subscribed')}</p>
            </div>
          </div>

          <style>
            @keyframes fnl-dc { to { stroke-dashoffset: 0; } }
            @keyframes fnl-dk { to { stroke-dashoffset: 0; } }
            #footer-nl-wrapper.success .fnl-circle { animation: fnl-dc 0.6s ease-out 0.2s forwards; }
            #footer-nl-wrapper.success .fnl-check { animation: fnl-dk 0.4s ease-out 0.7s forwards; }
          </style>

          <script>
            (function() {
              const form = document.getElementById('footer-nl-form') as HTMLFormElement | null;
              const wrapper = document.getElementById('footer-nl-wrapper');
              const content = document.getElementById('footer-nl-content');
              const success = document.getElementById('footer-nl-success');
              form?.addEventListener('submit', (e) => {
                e.preventDefault();
                const data = Object.fromEntries(new FormData(form).entries());
                fetch('https://submit-form.com/v6dFS1FAS', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify(data) }).catch(() => {});
                if (content) { content.style.opacity = '0'; content.style.transition = 'opacity 0.3s ease'; }
                setTimeout(() => { content?.classList.add('hidden'); wrapper?.classList.add('success'); success?.classList.remove('hidden'); success?.classList.add('flex'); if (success) { success.style.opacity = '0'; requestAnimationFrame(() => { success.style.transition = 'opacity 0.5s ease'; success.style.opacity = '1'; }); } }, 300);
              });
            })();
          </script>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-8 lg:gap-10 mb-12 items-start">
        <div>
          <h4 class="font-bold text-white mb-6 uppercase tracking-widest text-xs opacity-70">{t('footer.product')}</h4>
          <ul class="space-y-4 text-sm text-gray-300">
            <li><a class="hover:text-white transition-colors" href={l('/documentation')}>{t('footer.documentation')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/pricing')}>{t('footer.pricing')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/trial')}>{t('footer.freeTrial')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/book-a-call')}>{t('footer.bookACall')}</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-white mb-6 uppercase tracking-widest text-xs opacity-70">{t('footer.coverage')}</h4>
          <ul class="space-y-4 text-sm text-gray-400">
            <li><a class="hover:text-white transition-colors" href={l('/coverage')}>{t('footer.allBrands')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/coverage/global')}>{t('footer.globalCoverage')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/coverage/vehicle-types')}>{t('footer.vehicleTypes')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/coverage/quality')}>{t('footer.studioQuality')}</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-white mb-6 uppercase tracking-widest text-xs opacity-70">{t('footer.resources')}</h4>
          <ul class="space-y-4 text-sm text-gray-300">
            <li><a class="hover:text-white transition-colors" href={l('/blog')}>{t('footer.blog')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/whitepapers')}>{t('footer.whitepapers')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/case-studies')}>{t('footer.caseStudies')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/changelog')}>{t('footer.changelog')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/faq')}>{t('footer.faq')}</a></li>
          </ul>
        </div>

        {dynamicCategories.map((cat) => (
          <div>
            <h4 class="font-bold text-white mb-6 uppercase tracking-widest text-xs opacity-70">{cat.name}</h4>
            <ul class="space-y-4 text-sm text-gray-400">
              {cat.links.slice(0, MAX_LINKS).map((link) => (
                <li><a class="hover:text-white transition-colors" href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}

        <div>
          <h4 class="font-bold text-white mb-6 uppercase tracking-widest text-xs opacity-70">{t('footer.company')}</h4>
          <ul class="space-y-4 text-sm text-gray-300">
            <li><a class="hover:text-white transition-colors" href={l('/team')}>{t('footer.team')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/contact')}>{t('footer.contact')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/support')}>{t('footer.support')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/partners')}>{t('footer.partners')}</a></li>
            <li><a class="hover:text-white transition-colors" href={l('/press')}>{t('footer.press')}</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-6">
        <p class="text-sm text-gray-300">{t('footer.copyright').replace('{year}', String(new Date().getFullYear()))}</p>
        <div class="flex flex-wrap items-center justify-center gap-4 text-sm text-gray-300">
          <a class="hover:text-white transition-colors" href={l('/impressum')}>{t('footer.imprint')}</a>
          <span class="text-white/30" aria-hidden="true">&middot;</span>
          <a class="hover:text-white transition-colors" href={l('/privacy')}>{t('footer.privacyPolicy')}</a>
          <span class="text-white/30" aria-hidden="true">&middot;</span>
          <a class="hover:text-white transition-colors" href={l('/terms')}>{t('footer.termsOfService')}</a>
          <span class="text-white/30" aria-hidden="true">&middot;</span>
          <a class="hover:text-white transition-colors" href={l('/cookies')}>{t('footer.cookieSettings')}</a>
        </div>
        <div class="flex items-center gap-4">
          <a class="text-gray-300 hover:text-white transition-colors" href="https://twitter.com" aria-label="X (Twitter)">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
          </a>
          <a class="text-gray-300 hover:text-white transition-colors" href="https://linkedin.com" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
