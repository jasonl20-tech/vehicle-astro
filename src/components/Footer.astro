---
import { getEntries } from '../lib/contentful';

interface DynamicLink {
  label: string;
  href: string;
  order: number;
}

interface DynamicCategory {
  name: string;
  links: DynamicLink[];
}

let dynamicCategories: DynamicCategory[] = [];

try {
  const res = await getEntries({ content_type: 'dynamicPage-2', limit: 500 });
  const footerItems = (res.items as any[]).filter((item) => item.fields?.footer === true);

  const catMap = new Map<string, DynamicLink[]>();
  for (const item of footerItems) {
    const f = item.fields;
    const category = (f.category as string) || 'Other';
    const slug = f.slug as string;
    const prefix = f.urlPrefix as string | undefined;
    const href = prefix ? `/${prefix}/${slug}` : `/${slug}`;
    const label = (f.footerLabel as string) || (f.title as string) || slug;
    const order = (f.order as number) || 999;

    if (!catMap.has(category)) catMap.set(category, []);
    catMap.get(category)!.push({ label, href, order });
  }

  for (const [name, links] of catMap) {
    links.sort((a, b) => a.order - b.order);
    dynamicCategories.push({ name, links });
  }
  dynamicCategories.sort((a, b) => a.name.localeCompare(b.name));
} catch {
  dynamicCategories = [];
}

const totalCols = 4 + dynamicCategories.length;
---

<footer class="text-white pt-24 pb-12 w-full border-t border-white/10" style="background-color:rgb(10, 43, 49); font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">
