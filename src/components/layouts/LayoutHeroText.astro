---
import HeroSection from '../sections/HeroSection.astro';
import StatsSection from '../sections/StatsSection.astro';
import CtaSection from '../sections/CtaSection.astro';

interface Props {
  label?: string;
  headline: string;
  description?: string;
  stats?: Array<{ value: string; label: string }>;
  bodyHtml?: string;
  ctaTitle?: string;
  ctaDescription?: string;
  ctaButtonLabel?: string;
  ctaButtonUrl?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryUrl?: string;
}

const { label, headline, description, stats, bodyHtml, ctaTitle, ctaDescription, ctaButtonLabel, ctaButtonUrl, ctaSecondaryLabel, ctaSecondaryUrl } = Astro.props;
---

<HeroSection label={label} headline={headline} description={description} />

{stats && stats.length > 0 && <StatsSection stats={stats} />}

{bodyHtml && (
  <section class="mx-auto max-w-[1400px] px-6 pb-24 sm:px-12 lg:px-16">
    <div class="grid lg:grid-cols-[1fr_2fr] gap-16 items-start">
      <div></div>
      <div class="prose prose-lg max-w-none prose-headings:font-light prose-headings:tracking-tight prose-p:text-black/50 prose-p:text-[15px] prose-p:leading-relaxed prose-a:text-[rgb(200,90,70)] prose-a:no-underline hover:prose-a:underline prose-strong:text-black prose-ul:text-black/50 prose-ol:text-black/50" set:html={bodyHtml} />
    </div>
  </section>
)}

<CtaSection title={ctaTitle} description={ctaDescription} buttonLabel={ctaButtonLabel} buttonUrl={ctaButtonUrl} secondaryLabel={ctaSecondaryLabel} secondaryUrl={ctaSecondaryUrl} />
