---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const categories = [
  {
    title: 'Sport & Performance',
    desc: 'High-performance sports cars and supercars from the world\'s most prestigious manufacturers.',
    brands: [
      { slug: 'ferrari', name: 'Ferrari' }, { slug: 'porsche', name: 'Porsche' }, { slug: 'lamborghini', name: 'Lamborghini' },
      { slug: 'mclaren', name: 'McLaren' }, { slug: 'aston_martin', name: 'Aston Martin' }, { slug: 'bugatti', name: 'Bugatti' },
      { slug: 'koenigsegg', name: 'Koenigsegg' }, { slug: 'lotus', name: 'Lotus' }, { slug: 'maserati', name: 'Maserati' },
      { slug: 'abarth', name: 'Abarth' },
    ],
  },
  {
    title: 'Luxury',
    desc: 'Premium luxury vehicles from the world\'s most exclusive automotive brands.',
    brands: [
      { slug: 'rolls_royce', name: 'Rolls-Royce' }, { slug: 'bentley', name: 'Bentley' }, { slug: 'mercedes_benz', name: 'Mercedes-Benz' },
      { slug: 'bmw', name: 'BMW' }, { slug: 'audi', name: 'Audi' }, { slug: 'lexus', name: 'Lexus' },
      { slug: 'jaguar', name: 'Jaguar' }, { slug: 'land_rover', name: 'Land Rover' }, { slug: 'genesis', name: 'Genesis' },
      { slug: 'lincoln', name: 'Lincoln' }, { slug: 'cadillac', name: 'Cadillac' }, { slug: 'infiniti', name: 'Infiniti' },
    ],
  },
  {
    title: 'Mainstream',
    desc: 'Popular mass-market vehicles from leading global manufacturers.',
    brands: [
      { slug: 'volkswagen', name: 'Volkswagen' }, { slug: 'toyota', name: 'Toyota' }, { slug: 'ford', name: 'Ford' },
      { slug: 'honda', name: 'Honda' }, { slug: 'nissan', name: 'Nissan' }, { slug: 'hyundai', name: 'Hyundai' },
      { slug: 'kia', name: 'Kia' }, { slug: 'mazda', name: 'Mazda' }, { slug: 'subaru', name: 'Subaru' },
      { slug: 'mitsubishi', name: 'Mitsubishi' }, { slug: 'suzuki', name: 'Suzuki' }, { slug: 'isuzu', name: 'Isuzu' },
    ],
  },
  {
    title: 'European',
    desc: 'European automotive manufacturers including French, Italian, and other continental brands.',
    brands: [
      { slug: 'peugeot', name: 'Peugeot' }, { slug: 'renault', name: 'Renault' }, { slug: 'citroen', name: 'Citroën' },
      { slug: 'seat', name: 'SEAT' }, { slug: 'skoda', name: 'Škoda' }, { slug: 'cupra', name: 'CUPRA' },
      { slug: 'alfa_romeo', name: 'Alfa Romeo' }, { slug: 'fiat', name: 'Fiat' }, { slug: 'vauxhall', name: 'Vauxhall' },
      { slug: 'mini', name: 'MINI' }, { slug: 'smart', name: 'smart' }, { slug: 'volvo', name: 'Volvo' },
      { slug: 'saab', name: 'Saab' }, { slug: 'ineos', name: 'INEOS' },
    ],
  },
  {
    title: 'American',
    desc: 'American automotive manufacturers including trucks, SUVs, and classic American vehicles.',
    brands: [
      { slug: 'chevrolet', name: 'Chevrolet' }, { slug: 'gmc', name: 'GMC' }, { slug: 'dodge', name: 'Dodge' },
      { slug: 'ram', name: 'RAM' }, { slug: 'jeep', name: 'Jeep' }, { slug: 'chrysler', name: 'Chrysler' },
      { slug: 'buick', name: 'Buick' }, { slug: 'hummer', name: 'Hummer' }, { slug: 'acura', name: 'Acura' },
      { slug: 'pontiac', name: 'Pontiac' }, { slug: 'oldsmobile', name: 'Oldsmobile' }, { slug: 'mercury', name: 'Mercury' },
      { slug: 'saturn', name: 'Saturn' }, { slug: 'plymouth', name: 'Plymouth' }, { slug: 'scion', name: 'Scion' },
    ],
  },
  {
    title: 'Electric & Hybrid',
    desc: 'Electric and hybrid vehicle manufacturers leading the transition to sustainable mobility.',
    brands: [
      { slug: 'tesla', name: 'Tesla' }, { slug: 'polestar', name: 'Polestar' }, { slug: 'lucid', name: 'Lucid' },
    ],
  },
];
---

<BaseLayout
  title="Vehicle Coverage | 140+ Brands & 65,000+ Models | Vehicle Imagery API"
  description="Comprehensive vehicle imagery database covering 140+ automotive brands and 65,000+ models worldwide."
  canonicalUrl="/coverage"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 pt-24 pb-8 sm:px-12 lg:px-16">
      <div class="max-w-3xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Coverage</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-[0.95] text-black tracking-tight mb-8">
          140+ brands.<br />65K models.
        </h1>
        <p class="text-[16px] text-black/50 leading-relaxed max-w-lg">
          Studio-quality vehicle imagery for every major manufacturer. From supercars to family vehicles, always up to date.
        </p>
      </div>
    </section>

    <!-- Stats -->
    <section class="mx-auto max-w-[1400px] px-6 pb-16 sm:px-12 lg:px-16">
      <div class="flex gap-12 sm:gap-16 border-t border-black/5 pt-8">
        {[
          { value: '140+', label: 'Brands' },
          { value: '65,000+', label: 'Models' },
          { value: '1,000+', label: 'Colors' },
          { value: '50ms', label: 'Avg. Response' },
        ].map((stat) => (
          <div>
            <p class="text-2xl sm:text-3xl font-light text-black tracking-tight">{stat.value}</p>
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/25 mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Categories -->
    <section class="mx-auto max-w-[1400px] px-6 pb-32 sm:px-12 lg:px-16">
      <div class="space-y-6">
        {categories.map((cat, catIdx) => (
          <div class="relative rounded-[2rem] overflow-hidden border border-black/[0.06] bg-white">
            <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-black/10 via-black/5 to-transparent"></div>
            <div class="p-8 sm:p-12">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-10">
                <div class="flex items-center gap-4">
                  <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/20">{String(catIdx + 1).padStart(2, '0')}</span>
                  <h2 class="text-3xl sm:text-4xl font-light text-black tracking-tight">{cat.title}</h2>
                </div>
                <p class="text-[13px] text-black/35 mt-2 sm:mt-0">{cat.brands.length} brands</p>
              </div>
              <p class="text-[14px] text-black/45 leading-relaxed mb-10 max-w-xl">{cat.desc}</p>
              <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-8 gap-3">
                {cat.brands.map((brand) => (
                  <div class="flex flex-col items-center justify-center rounded-xl p-4 sm:p-5 transition-all duration-200 cursor-default group/brand">
                    <div class="w-full h-10 sm:h-12 flex items-center justify-center mb-2">
                      <img
                        src={`/manufactures/${brand.slug}_logo.svg`}
                        alt={brand.name}
                        width="80"
                        height="40"
                        class="object-contain max-w-full max-h-full opacity-50 group-hover/brand:opacity-100 transition-opacity"
                        loading="lazy"
                        decoding="async"
                        draggable="false"
                      />
                    </div>
                    <span class="text-[10px] font-medium text-black/30 group-hover/brand:text-black/60 transition-colors text-center leading-tight">{brand.name}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Data Coverage -->
    <section class="mx-auto max-w-[1400px] px-6 pb-32 sm:px-12 lg:px-16">
      <div class="grid lg:grid-cols-[1fr_2fr] gap-16 items-start">
        <div class="lg:sticky lg:top-32">
          <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Data</p>
          <h2 class="text-4xl sm:text-5xl font-light text-black tracking-tight leading-[1.05]">Beyond<br />imagery.</h2>
        </div>
        <div class="space-y-0">
          {[
            { title: 'Trim Levels & Equipment', text: 'Coverage of all trim levels and equipment packages. AMG-Line, S-Line, M-Package — our API delivers the correct images for the exact specification.' },
            { title: 'Paint Colors', text: 'Comprehensive paint color coverage matched to manufacturer specifications. Standard, metallic, matte, and special edition colors.' },
            { title: 'Interior Configurations', text: '360° interior panoramas with multiple seat configurations, dashboard variants, and material options. Cockpit, front row, and rear row perspectives.' },
            { title: 'Regional Specifications', text: 'US-Specs, EU-Specs, and market variations. Lighting differences, safety equipment, and RHD variants for UK, Australia, and Asian markets.' },
            { title: 'Model Year Updates', text: 'New model years, facelifts, and mid-cycle updates available within weeks of official launch. Accurate visual representation for every model year.' },
          ].map((item) => (
            <div class="py-8 border-b border-black/5 first:border-t">
              <h3 class="text-[15px] font-bold text-black mb-2">{item.title}</h3>
              <p class="text-[14px] text-black/45 leading-relaxed max-w-xl">{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-[1400px] px-6 pb-32 sm:px-12 lg:px-16">
      <div class="relative rounded-[2rem] overflow-hidden transition-all duration-500 hover:shadow-[0_40px_80px_-20px_rgba(10,43,49,0.35)]" style="background-color: rgb(10, 43, 49);">
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
        <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[rgb(200,90,70)] via-[rgb(200,90,70)]/40 to-transparent"></div>
        <div class="relative p-10 sm:p-16 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
          <div>
            <h2 class="text-3xl sm:text-4xl font-light text-white tracking-tight mb-3">Need a specific brand?</h2>
            <p class="text-[14px] text-white/40 max-w-md">Can't find a brand or model? We're constantly expanding and welcome requests.</p>
          </div>
          <div class="flex gap-3 shrink-0">
            <a href="/contact" class="group/btn inline-flex items-center gap-3 bg-white text-[rgb(10,43,49)] px-7 py-4 text-[13px] font-bold uppercase tracking-widest hover:bg-[rgb(200,90,70)] hover:text-white transition-colors">
              Request Coverage
            </a>
            <a href="/documentation" class="inline-flex items-center gap-3 border border-white/20 text-white px-7 py-4 text-[13px] font-bold uppercase tracking-widest hover:bg-white/10 transition-colors">
              Docs
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
