---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const regions = [
  {
    title: 'Europe',
    desc: 'Complete coverage of all European markets including UK, DACH, Nordics, and Southern Europe.',
    countries: 'Germany, UK, France, Italy, Spain, Sweden, Netherlands, Switzerland, Austria, Norway, Belgium, Denmark, Poland, Czech Republic, Finland',
    brands: '85+',
  },
  {
    title: 'North America',
    desc: 'Full US and Canadian market coverage including US-spec lighting, safety equipment, and trim configurations.',
    countries: 'United States, Canada, Mexico',
    brands: '60+',
  },
  {
    title: 'Asia Pacific',
    desc: 'Japanese, Korean, and Australian market vehicles with region-specific trim levels and configurations.',
    countries: 'Japan, South Korea, Australia, China, India, Thailand, Indonesia, Malaysia',
    brands: '45+',
  },
  {
    title: 'Middle East & Africa',
    desc: 'GCC-spec vehicles and select African markets. Region-specific trim levels and equipment packages.',
    countries: 'UAE, Saudi Arabia, Qatar, Kuwait, Bahrain, Oman, South Africa',
    brands: '30+',
  },
];
---

<BaseLayout
  title="Global Coverage | Vehicle Imagery API"
  description="Vehicle imagery coverage spanning Europe, North America, Asia Pacific, and the Middle East. 140+ brands across all major automotive markets."
  canonicalUrl="/coverage/global"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 pt-24 pb-8 sm:px-12 lg:px-16">
      <div class="max-w-3xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Global Coverage</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-[0.95] text-black tracking-tight mb-8">
          Worldwide.<br />Every market.
        </h1>
        <p class="text-[16px] text-black/50 leading-relaxed max-w-lg">
          Our vehicle imagery database covers all major automotive markets — with region-specific configurations, specifications, and trim levels.
        </p>
      </div>
    </section>

    <!-- Stats -->
    <section class="mx-auto max-w-[1400px] px-6 pb-16 sm:px-12 lg:px-16">
      <div class="flex gap-12 sm:gap-16 border-t border-black/5 pt-8">
        {[
          { value: '140+', label: 'Brands' },
          { value: '4', label: 'Regions' },
          { value: '40+', label: 'Countries' },
          { value: '65,000+', label: 'Models' },
        ].map((stat) => (
          <div>
            <p class="text-2xl sm:text-3xl font-light text-black tracking-tight">{stat.value}</p>
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/25 mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- World Map -->
    <section class="mx-auto max-w-[1400px] px-6 pb-24 sm:px-12 lg:px-16">
      <div class="bg-[#fafafa] rounded-2xl p-6 sm:p-10">
        <img src="/images/world-map.svg" alt="Global vehicle imagery coverage map" class="w-full h-auto" loading="eager" />
        <div class="flex items-center gap-8 mt-6 pl-2">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-sm" style="background: rgba(200,90,70,0.18); border: 1px solid rgba(200,90,70,0.5);"></span>
            <span class="text-[11px] text-black/40">Active coverage</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-sm bg-[#e8e8e8] border border-[#d0d0d0]"></span>
            <span class="text-[11px] text-black/40">Expanding</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Regional Coverage -->
    <section class="mx-auto max-w-[1400px] px-6 pb-32 sm:px-12 lg:px-16">
      <div class="grid sm:grid-cols-2 gap-px bg-black/[0.04]">
        {regions.map((region, idx) => (
          <div class="bg-white p-10 sm:p-12">
            <div class="flex items-center justify-between mb-8">
              <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/20">{String(idx + 1).padStart(2, '0')}</span>
              <div class="flex items-baseline gap-1.5">
                <span class="text-3xl sm:text-4xl font-extralight text-black tracking-tight">{region.brands}</span>
                <span class="text-[10px] text-black/25 uppercase tracking-wider">brands</span>
              </div>
            </div>
            <h2 class="text-2xl sm:text-3xl font-light text-black tracking-tight mb-3">{region.title}</h2>
            <p class="text-[14px] text-black/40 leading-relaxed mb-8">{region.desc}</p>
            <p class="text-[11px] text-black/25 leading-relaxed">{region.countries}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="pb-24 sm:pb-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] px-8 py-20 sm:px-16 sm:py-24" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full opacity-[0.04] pointer-events-none" style="background: radial-gradient(circle, white 0%, transparent 60%);" aria-hidden="true"></div>
          <div class="relative z-10 text-center max-w-2xl mx-auto">
            <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Get started</p>
            <h2 class="text-4xl sm:text-5xl font-light tracking-tight text-white leading-[1.05] mb-6">
              Global imagery, one API
            </h2>
            <p class="text-[14px] text-white/45 leading-relaxed mb-12 max-w-md mx-auto">
              Access vehicle imagery for any market through a single, consistent API. Start with a free trial.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/trial" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[13px] font-medium text-black transition-all duration-300 hover:bg-[rgb(200,90,70)] hover:text-white">
                Request Trial
              </a>
              <a href="/coverage" class="inline-flex items-center justify-center rounded-full border border-white/15 px-8 py-4 text-[13px] font-medium text-white/70 transition-all duration-300 hover:bg-white/10 hover:text-white">
                Browse Brands
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
