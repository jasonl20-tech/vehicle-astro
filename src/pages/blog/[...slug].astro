---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getEntries, getCompanyInfo } from '../../lib/contentful';
import { renderRichText, richTextToPlainText, buildAssetMap } from '../../lib/contentful-rich-text';

export async function getStaticPaths() {
  try {
    const res = await getEntries({ content_type: 'blogPost', include: 2, limit: 200 });
    const includes = res.includes ?? {};
    const slugToTitle = Object.fromEntries(
      (res.items as Array<{ fields?: { slug?: string; title?: string } }>)
        .filter((i) => i.fields?.slug && i.fields?.title)
        .map((i) => [i.fields!.slug!, i.fields!.title!])
    );
    return res.items
      .filter((item: { fields?: { slug?: string } }) => item.fields?.slug)
      .map((item: { fields?: { slug?: string; relatedPostSlugs?: string[] } }) => {
        const slugs = item.fields?.relatedPostSlugs ?? [];
        const relatedPosts = slugs.map((s: string) => ({ slug: s, title: slugToTitle[s] ?? s }));
        return {
          params: { slug: item.fields!.slug! },
          props: { entry: item, includes, relatedPosts },
        };
      });
  } catch {
    return [];
  }
}

const { entry, includes, relatedPosts: relatedPostsFromProps } = Astro.props;
const fields = entry?.fields ?? {};

const title = (fields.title as string) ?? 'Post';
const subtitle = (fields.subtitle as string) ?? '';
const excerpt = fields.excerpt as import('@contentful/rich-text-types').Document | undefined;
const body = fields.body as import('@contentful/rich-text-types').Document | undefined;
const featuredImage = fields.featuredImage as { sys?: { id?: string }; fields?: { file?: { url?: string }; title?: string } } | undefined;
const featuredImageAlt = (fields.featuredImageAlt as string) ?? '';
const publishedAt = fields.publishedAt as string | undefined;
const category = (fields.category as string) ?? '';
const categorySlug = (fields.categorySlug as string) ?? '';
const tags = (fields.tags as string[] | undefined) ?? [];
const authorName = (fields.authorName as string) ?? '';
const authorSlug = (fields.authorSlug as string) ?? '';
const authorAvatar = fields.authorAvatar as { sys?: { id?: string }; fields?: { file?: { url?: string }; title?: string } } | undefined;
const authorBio = fields.authorBio as import('@contentful/rich-text-types').Document | undefined;
const authorWebsite = (fields.authorWebsite as string) ?? '';
const authorTwitter = (fields.authorTwitter as string) ?? '';
const authorLinkedIn = (fields.authorLinkedIn as string) ?? '';
const readingTimeMinutes = fields.readingTimeMinutes as number | undefined;
const relatedPostSlugs = (fields.relatedPostSlugs as string[] | undefined) ?? [];
const seoTitle = (fields.seoTitle as string) ?? '';
const seoDescription = fields.seoDescription as import('@contentful/rich-text-types').Document | undefined;
const ogImageField = fields.ogImage as { sys?: { id?: string }; fields?: { file?: { url?: string }; title?: string } } | undefined;
const ogImageAlt = (fields.ogImageAlt as string) ?? '';
const canonicalUrl = (fields.canonicalUrl as string) ?? '';
const noIndex = (fields.noIndex as boolean) ?? false;

const assetMapResolved = buildAssetMap(includes as { Asset?: Array<{ sys: { id: string }; fields?: { file?: { url?: string }; title?: string } }> });

function assetUrl(linkOrAsset: { sys?: { id?: string }; fields?: { file?: { url?: string } } } | null | undefined): string {
  if (!linkOrAsset) return '';
  if (linkOrAsset.fields?.file?.url) {
    const u = linkOrAsset.fields.file.url;
    return u.startsWith('//') ? `https:${u}` : u;
  }
  const id = linkOrAsset.sys?.id;
  if (!id) return '';
  const asset = assetMapResolved[id];
  if (!asset?.fields?.file?.url) return '';
  const u = asset.fields.file.url;
  return u.startsWith('//') ? `https:${u}` : u;
}

const pageTitle = seoTitle || title;
const metaDescription = seoDescription ? richTextToPlainText(seoDescription, 160) : richTextToPlainText(excerpt, 160) || undefined;
const ogImageAsset = ogImageField ?? featuredImage;
const ogImageUrl = assetUrl(ogImageAsset);
const siteUrl = Astro.url.origin;
const ogImageFull = ogImageUrl ? (ogImageUrl.startsWith('http') ? ogImageUrl : `${siteUrl}${ogImageUrl.startsWith('/') ? '' : '/'}${ogImageUrl}`) : undefined;

const bodyHtml = body ? renderRichText(body, assetMapResolved) : '';
const excerptHtml = excerpt ? renderRichText(excerpt, assetMapResolved) : '';
const authorBioHtml = authorBio ? renderRichText(authorBio, assetMapResolved) : '';
const featuredImageUrl = assetUrl(featuredImage);
const authorAvatarUrl = assetUrl(authorAvatar);

const relatedPosts = relatedPostsFromProps ?? [];
const company = await getCompanyInfo();

const articleUrl = canonicalUrl ? `${siteUrl}${canonicalUrl.startsWith('/') ? '' : '/'}${canonicalUrl}` : `${siteUrl}/blog/${fields.slug}`;
const articleImage = ogImageFull || (featuredImageUrl ? (featuredImageUrl.startsWith('http') ? featuredImageUrl : `https:${featuredImageUrl}`) : undefined);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: metaDescription || title,
  url: articleUrl,
  ...(articleImage && { image: articleImage }),
  ...(publishedAt && { datePublished: publishedAt }),
  author: { '@type': 'Person', name: authorName || company.companyName },
  publisher: { '@type': 'Organization', name: company.companyName, logo: { '@type': 'ImageObject', url: `${siteUrl}/logo.svg` } },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: pageTitle, item: articleUrl },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  ogImage={ogImageFull}
  ogImageAlt={ogImageAlt || featuredImageAlt}
  canonicalUrl={canonicalUrl || `/blog/${fields.slug}`}
  noIndex={noIndex}
>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <main class="min-h-screen bg-cream">
    <!-- Article header: full-bleed optional image + title block -->
    <header class="relative">
      {featuredImageUrl && (
        <div class="relative h-[50vh] min-h-[320px] max-h-[560px] w-full overflow-hidden bg-[#1C2B32]">
          <img
            src={featuredImageUrl.startsWith('http') ? featuredImageUrl : `https:${featuredImageUrl}`}
            alt={featuredImageAlt}
            class="h-full w-full object-cover"
            width="1600"
            height="900"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1C2B32]/95 via-[#1C2B32]/40 to-transparent" aria-hidden="true" />
        </div>
      )}
      <div class={`mx-auto max-w-6xl px-6 sm:px-12 lg:px-16 ${featuredImageUrl ? '-mt-32 relative z-10 pb-16' : 'pt-16 pb-12'}`}>
        <div class="rounded-none border border-white/10 bg-white p-8 shadow-xl sm:p-10 md:p-12">
          {category && (
            <a
              href={`/blog?category=${encodeURIComponent(categorySlug || category)}`}
              class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-accent hover:underline"
            >
              {category}
            </a>
          )}
          <h1 class="mt-3 text-3xl font-black leading-tight tracking-tight text-[#1C2B32] sm:text-4xl md:text-5xl">
            {title}
          </h1>
          {subtitle && (
            <p class="mt-4 text-xl leading-relaxed text-[#1C2B32]/75">
              {subtitle}
            </p>
          )}
          <div class="mt-8 flex flex-wrap items-center gap-6 border-t border-[#1C2B32]/10 pt-8">
            {authorAvatarUrl && (
              <img
                src={authorAvatarUrl.startsWith('http') ? authorAvatarUrl : `https:${authorAvatarUrl}`}
                alt={authorName ? `${authorName} avatar` : ''}
                class="h-12 w-12 rounded-full object-cover ring-2 ring-white shadow-md"
                width="48"
                height="48"
              />
            )}
            <div class="flex flex-wrap items-center gap-x-6 gap-y-1 text-sm">
              {authorName && <span class="font-semibold text-[#1C2B32]">{authorName}</span>}
              {publishedAt && (
                <time datetime={publishedAt} class="text-[#1C2B32]/60">
                  {new Date(publishedAt).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
              )}
              {readingTimeMinutes != null && (
                <span class="text-[#1C2B32]/60">{readingTimeMinutes} min read</span>
              )}
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Excerpt (lead) -->
    {excerptHtml && (
      <div class="mx-auto max-w-6xl px-6 sm:px-12 lg:px-16">
        <div class="border-l-4 border-accent bg-[#1C2B32]/[0.03] py-4 pl-6 pr-6">
          <div class="blog-prose blog-prose--lead text-lg leading-relaxed text-[#1C2B32]/85" set:html={excerptHtml} />
        </div>
      </div>
    )}

    <!-- Two columns: main content + author card sidebar -->
    <div class="mx-auto max-w-6xl px-6 pb-16 pt-12 sm:px-12 lg:px-16">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_320px] lg:gap-16">
        <!-- Main: article body, tags, related -->
        <article class="min-w-0">
          <a href="/blog" class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-[#1C2B32]/60 transition-colors hover:text-accent">
            <span aria-hidden="true">←</span> Back to blog
          </a>
          {bodyHtml ? (
            <div class="blog-prose blog-article-body mt-8" set:html={bodyHtml} />
          ) : (
            <p class="mt-8 text-[#1C2B32]/60">No content.</p>
          )}

          <!-- Tags -->
          {tags.length > 0 && (
            <div class="mt-12 flex flex-wrap items-center gap-2 border-t border-[#1C2B32]/10 pt-10">
              <span class="text-xs font-bold uppercase tracking-wider text-[#1C2B32]/50">Tags</span>
              {tags.map((tag: string) => (
                <a
                  href={`/blog?tag=${encodeURIComponent(tag)}`}
                  class="rounded-none border border-[#1C2B32]/15 bg-white px-3 py-1.5 text-sm font-medium text-[#1C2B32]/80 transition-colors hover:border-accent hover:bg-accent/5 hover:text-accent"
                >
                  {tag}
                </a>
              ))}
            </div>
          )}

          <!-- Related posts -->
          {relatedPosts.length > 0 && (
            <section class="mt-16 border-t border-[#1C2B32]/10 pt-12">
              <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-[#1C2B32]/50">Related posts</h2>
              <ul class="mt-6 grid gap-4 sm:grid-cols-2">
                {relatedPosts.map((r) => (
                  <li>
                    <a
                      href={`/blog/${r.slug}`}
                      class="flex items-center gap-4 rounded-none border border-[#1C2B32]/10 bg-white p-4 transition-colors hover:border-accent/30 hover:bg-accent/5"
                    >
                      <span class="flex h-12 w-12 shrink-0 items-center justify-center bg-[#1C2B32]/10 text-lg font-bold text-[#1C2B32]/60">
                        →
                      </span>
                      <span class="font-semibold text-[#1C2B32] line-clamp-2">{r.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </article>

        <!-- Sidebar: author card (sticky, rechts auf Desktop) -->
        <aside>
          {(authorName || authorBioHtml) && (
            <div class="sticky top-24 rounded-none border border-[#1C2B32]/12 bg-white p-6 shadow-[0_4px_24px_-4px_rgba(28,43,50,0.1)]">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#1C2B32]/50">Author</p>
              <div class="mt-5 flex flex-col items-center text-center">
                {authorAvatarUrl && (
                  <img
                    src={authorAvatarUrl.startsWith('http') ? authorAvatarUrl : `https:${authorAvatarUrl}`}
                    alt={authorName ? `${authorName} avatar` : ''}
                    class="h-24 w-24 rounded-full object-cover ring-2 ring-[#1C2B32]/10"
                    width="96"
                    height="96"
                  />
                )}
                <p class="mt-4 text-lg font-bold text-[#1C2B32]">{authorName || 'Author'}</p>
                {authorBioHtml && (
                  <div class="blog-prose blog-prose--sm mt-3 text-left text-[#1C2B32]/75" set:html={authorBioHtml} />
                )}
                <div class="mt-5 flex flex-wrap justify-center gap-3">
                  {authorWebsite && (
                    <a
                      href={authorWebsite.startsWith('http') ? authorWebsite : `https://${authorWebsite}`}
                      class="text-xs font-semibold uppercase tracking-wider text-accent hover:underline"
                    >
                      Website
                    </a>
                  )}
                  {authorTwitter && (
                    <a
                      href={`https://twitter.com/${authorTwitter.replace(/^@/, '')}`}
                      class="text-xs font-semibold uppercase tracking-wider text-accent hover:underline"
                    >
                      Twitter
                    </a>
                  )}
                  {authorLinkedIn && (
                    <a
                      href={authorLinkedIn.startsWith('http') ? authorLinkedIn : `https://${authorLinkedIn}`}
                      class="text-xs font-semibold uppercase tracking-wider text-accent hover:underline"
                    >
                      LinkedIn
                    </a>
                  )}
                </div>
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  /* Blog prose: article body + excerpt + author bio */
  .blog-prose p {
    margin-top: 0;
    margin-bottom: 1em;
  }
  .blog-prose p:last-child {
    margin-bottom: 0;
  }
  .blog-prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-prose a:hover {
    color: var(--color-accent-hover);
  }
  .blog-prose strong {
    font-weight: 700;
    color: #1C2B32;
  }
  .blog-prose em {
    font-style: italic;
  }
  .blog-prose ul {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    padding-left: 1.5em;
    list-style-type: disc;
  }
  .blog-prose ol {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    padding-left: 1.5em;
    list-style-type: decimal;
  }
  .blog-prose li {
    margin-bottom: 0.5em;
    padding-left: 0.25em;
  }
  .blog-prose li::marker {
    color: var(--color-accent);
  }
  .blog-prose blockquote {
    margin: 2em 0;
    padding: 1em 0 1em 1.25em;
    border-left: 4px solid var(--color-accent);
    background: rgba(28, 43, 50, 0.04);
    font-style: italic;
    color: #1C2B32;
  }
  .blog-prose blockquote p:last-child {
    margin-bottom: 0;
  }
  .blog-prose h1 {
    margin-top: 2.25em;
    margin-bottom: 0.8em;
    font-size: 1.9rem;
    font-weight: 900;
    line-height: 1.2;
    color: #1C2B32;
  }
  .blog-prose h1:first-child {
    margin-top: 0;
  }
  .blog-prose h2 {
    margin-top: 2em;
    margin-bottom: 0.75em;
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1.25;
    color: #1C2B32;
  }
  .blog-prose h2:first-child {
    margin-top: 0;
  }
  .blog-prose h3 {
    margin-top: 1.75em;
    margin-bottom: 0.5em;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1C2B32;
  }
  .blog-prose h4 {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1C2B32;
  }
  .blog-prose hr {
    margin: 2.5em 0;
    border: none;
    border-top: 1px solid rgba(28, 43, 50, 0.12);
  }
  .blog-prose figure {
    margin: 2em 0;
  }
  .blog-prose figure img {
    width: 100%;
    height: auto;
    border-radius: 0;
    border: 1px solid rgba(28, 43, 50, 0.08);
  }
  .blog-prose figcaption {
    margin-top: 0.75em;
    font-size: 0.875rem;
    color: #1C2B32;
    opacity: 0.7;
  }
  .blog-prose code {
    font-size: 0.9em;
    padding: 0.15em 0.4em;
    background: rgba(28, 43, 50, 0.08);
    border: 1px solid rgba(28, 43, 50, 0.1);
    font-family: ui-monospace, monospace;
  }
  .blog-prose pre {
    margin: 1.5em 0;
    padding: 1.25em;
    overflow-x: auto;
    background: #1C2B32;
    color: #FBFBF7;
    border: none;
  }
  .blog-prose pre code {
    padding: 0;
    background: none;
    border: none;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .blog-article-body {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #1C2B32;
  }
  .blog-prose--lead {
    font-size: 1.125rem;
  }
  .blog-prose--sm {
    font-size: 0.9375rem;
    line-height: 1.65;
  }
</style>
