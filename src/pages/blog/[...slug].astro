---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getEntries } from '../../lib/contentful';
import { documentToHtmlString } from '@contentful/rich-text-html-renderer';

export async function getStaticPaths() {
  try {
    const res = await getEntries({ content_type: 'blogPost' });
    return res.items.map((item: { fields?: { slug?: string } }) => ({
      params: { slug: item.fields?.slug ?? '' },
      props: { entry: item },
    }));
  } catch {
    return [];
  }
}

const { entry } = Astro.props;
const title = entry?.fields?.title ?? 'Post';
const body = entry?.fields?.body;
const bodyHtml = body ? documentToHtmlString(body) : '';
---

<BaseLayout title={title} description={title}>
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <article>
      <h1 class="text-4xl font-bold">{title}</h1>
      {bodyHtml ? (
        <div class="prose prose-lg mt-8" set:html={bodyHtml} />
      ) : (
        <p class="mt-8 text-gray-600">Kein Inhalt.</p>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>
