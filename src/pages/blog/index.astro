---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getEntries } from '../../lib/contentful';
import { richTextToPlainText } from '../../lib/contentful-rich-text';

type PostItem = { slug: string; title: string; date?: string; excerpt?: string; category?: string };

let posts: PostItem[] = [];

try {
  const res = await getEntries({
    content_type: 'blogPost',
    order: '-fields.publishedAt',
    limit: 100,
  });
  posts = res.items
    .filter((item: { fields?: { slug?: string } }) => item.fields?.slug)
    .map((item: {
      fields?: {
        slug?: string;
        title?: string;
        publishedAt?: string;
        excerpt?: import('@contentful/rich-text-types').Document;
        category?: string;
      };
    }) => ({
      slug: item.fields!.slug!,
      title: item.fields?.title ?? 'Untitled',
      date: item.fields?.publishedAt,
      excerpt: item.fields?.excerpt ? richTextToPlainText(item.fields.excerpt, 160) : undefined,
      category: item.fields?.category,
    }));
} catch {
  // Contentful nicht konfiguriert oder keine Einträge
}
---

<BaseLayout title="Blog" description="Blog-Übersicht Vehicle Imagery">
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold text-gray-900">Blog</h1>
    <p class="mt-2 text-gray-600">Updates, API-Tipps und Einblicke.</p>
    <ul class="mt-10 space-y-8">
      {posts.length > 0 ? (
        posts.map((post) => (
          <li class="border-b border-gray-100 pb-8 last:border-0">
            <a href={`/blog/${post.slug}`} class="group block">
              {post.category && (
                <span class="text-sm font-semibold uppercase tracking-wider text-[#FF8844]">{post.category}</span>
              )}
              <h2 class="mt-1 text-2xl font-bold text-gray-900 group-hover:text-[#FF8844] transition-colors">{post.title}</h2>
              {post.excerpt && <p class="mt-2 text-gray-600 line-clamp-2">{post.excerpt}</p>}
              {post.date && (
                <time class="mt-2 block text-sm text-gray-500" datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
              )}
            </a>
          </li>
        ))
      ) : (
        <li class="text-gray-500">Keine Blog-Posts. Contentful mit Content-Type „blogPost“ konfigurieren.</li>
      )}
    </ul>
  </main>
  <Footer />
</BaseLayout>
