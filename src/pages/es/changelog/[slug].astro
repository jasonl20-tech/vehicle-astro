---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getEntries } from '../../../lib/contentful';
import { renderRichText, buildAssetMap } from '../../../lib/contentful-rich-text';

function getAssetUrl(asset: { fields?: { file?: { url?: string } } } | null | undefined): string | undefined {
  if (!asset?.fields?.file?.url) return undefined;
  const url = asset.fields.file.url;
  return url.startsWith('//') ? `https:${url}` : url;
}

function parseChangesText(text: string | unknown): Array<{ type: string; title: string; description?: string }> {
  if (typeof text !== 'string' || !text.trim()) return [];
  const lines = text.split('\n').map((l) => l.trim()).filter(Boolean);
  const types = ['added', 'fixed', 'changed', 'deprecated', 'removed'];
  return lines.map((line) => {
    const colonIdx = line.indexOf(':');
    if (colonIdx === -1) return { type: 'added', title: line, description: undefined };
    const type = line.slice(0, colonIdx).toLowerCase().trim();
    const rest = line.slice(colonIdx + 1).trim();
    const validType = types.includes(type) ? type : 'added';
    const dashIdx = rest.indexOf(' - ');
    const title = dashIdx >= 0 ? rest.slice(0, dashIdx).trim() : rest;
    const description = dashIdx >= 0 ? rest.slice(dashIdx + 3).trim() : undefined;
    return { type: validType, title, description };
  });
}

export async function getStaticPaths() {
  try {
    const res = await getEntries({ content_type: 'api', order: '-sys.createdAt', include: 2, locale: 'es' });
    const assetMap = buildAssetMap(res.includes);
    return res.items
      .filter((item: { fields?: { slug?: string } }) => item.fields?.slug)
      .map((item: { fields?: { slug?: string } }) => ({
        params: { slug: item.fields!.slug! },
        props: { entry: item, assetMap },
      }));
  } catch {
    return [];
  }
}

const { entry, assetMap } = Astro.props;
const fields = entry?.fields ?? {};
const title = fields.title ?? 'Changelog';
const slug = fields.slug ?? '';
const body = fields.body;
const metaTitle = fields.metaTitle ?? `${title} | Vehicle Imagery Changelog`;
const metaDescription = fields.metaDescription ?? (typeof fields.excerpt === 'string' ? fields.excerpt : title);
const ogImageAsset = fields.ogImage ?? fields.featuredImage;
const ogImageUrl = getAssetUrl(ogImageAsset);
const ogImageAlt = fields.ogImageAlt ?? fields.featuredImageAlt ?? title;
const bodyHtml = body ? renderRichText(body, assetMap) : '';
const createdAt = fields.publishedDate ?? entry?.sys?.createdAt ?? '';
const version = fields.version;
const category = fields.category;
const author = fields.author;
const tags = Array.isArray(fields.tags) ? fields.tags : (fields.tags ? [fields.tags] : []);
const changesRaw = fields.changesText ?? fields.changes ?? '';
const changes = parseChangesText(changesRaw);
const featuredImage = fields.featuredImage;
const featuredImageUrl = getAssetUrl(featuredImage);
const featuredImageAlt = fields.featuredImageAlt ?? title;
const gallery = Array.isArray(fields.gallery) ? fields.gallery : (fields.gallery ? [fields.gallery] : []);

const changeTypeStyles: Record<string, string> = {
  added: 'bg-emerald-500/10 text-emerald-800 border-emerald-200',
  fixed: 'bg-amber-500/10 text-amber-800 border-amber-200',
  changed: 'bg-blue-500/10 text-blue-800 border-blue-200',
  deprecated: 'bg-gray-500/10 text-gray-700 border-gray-200',
  removed: 'bg-red-500/10 text-red-800 border-red-200',
};
const changeTypeLabels: Record<string, string> = {
  added: 'Añadido',
  fixed: 'Corregido',
  changed: 'Cambiado',
  deprecated: 'Obsoleto',
  removed: 'Eliminado',
};
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  ogImage={ogImageUrl}
  ogImageAlt={ogImageAlt}
  canonicalUrl={`/es/changelog/${slug}`}
>
  <Header />
  <main class="vi-font min-h-screen" style="background-color:rgb(255, 254, 252);">
    <div class="max-w-4xl mx-auto px-6 sm:px-8 pt-8">
      <a href="/es/changelog" class="inline-flex items-center text-sm font-bold uppercase tracking-widest text-gray-500 hover:text-[rgb(200,90,70)] transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Todas las entradas
      </a>
    </div>

    <article class="max-w-4xl mx-auto px-6 sm:px-8 py-12 md:py-16">
      <header class="mb-12">
        <div class="flex flex-wrap items-center gap-3 text-sm mb-4">
          <time class="font-mono text-[rgb(200,90,70)] uppercase tracking-widest font-semibold" datetime={createdAt}>
            {createdAt ? new Date(createdAt).toLocaleDateString('es-ES', { month: 'long', day: 'numeric', year: 'numeric' }) : ''}
          </time>
          {version && <span class="px-3 py-1 rounded text-xs font-bold uppercase tracking-wider text-white" style="background-color:rgb(10, 43, 49);">{version}</span>}
          {category && <span class="px-3 py-1 rounded text-xs font-bold uppercase tracking-wider border border-black/20 text-black/70">{category}</span>}
          {author && <span class="text-gray-500">por {author}</span>}
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-black tracking-tighter leading-[1.05]">{title}</h1>
        {tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {tags.map((tag: string) => <span class="text-xs font-mono text-gray-500 bg-black/5 px-2.5 py-1 rounded">#{tag}</span>)}
          </div>
        )}
      </header>

      {featuredImageUrl && (
        <figure class="mb-14 -mx-6 sm:mx-0 sm:rounded-xl overflow-hidden shadow-xl">
          <img src={featuredImageUrl} alt={featuredImageAlt} class="w-full h-auto object-cover" width="1200" height="600" loading="eager" decoding="async" />
        </figure>
      )}

      {changes.length > 0 && (
        <div class="mb-14 p-8 rounded-xl border border-black/10 bg-white shadow-sm">
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-black/50 mb-6">Cambios en esta versión</h2>
          <ul class="space-y-4">
            {changes.map((change) => {
              const label = changeTypeLabels[change.type] ?? change.type;
              const style = changeTypeStyles[change.type] ?? changeTypeStyles.added;
              return (
                <li class="flex gap-4 items-start">
                  <span class={`shrink-0 text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded border ${style}`}>{label}</span>
                  <div class="min-w-0">
                    <span class="font-semibold text-black">{change.title}</span>
                    {change.description && <p class="text-gray-600 text-sm mt-1 leading-relaxed">{change.description}</p>}
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      )}

      {bodyHtml ? (
        <div class="prose prose-lg max-w-none prose-headings:font-black prose-headings:tracking-tighter prose-headings:text-black prose-p:text-gray-700 prose-p:leading-relaxed prose-a:text-[rgb(200,90,70)] prose-a:no-underline hover:prose-a:underline prose-a:font-medium prose-strong:text-black prose-strong:font-bold prose-ul:my-6 prose-ol:my-6 prose-li:my-1 prose-img:rounded-lg prose-img:shadow-md prose-blockquote:border-l-4 prose-blockquote:border-[rgb(200,90,70)] prose-blockquote:pl-6 prose-blockquote:italic prose-blockquote:text-gray-600" set:html={bodyHtml} />
      ) : (
        <p class="text-gray-500 py-8">Sin contenido.</p>
      )}

      {gallery.length > 0 && (
        <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 gap-6">
          {gallery.map((asset: { fields?: { file?: { url?: string }; title?: string } }) => {
            const url = getAssetUrl(asset);
            if (!url) return null;
            return (
              <figure class="overflow-hidden rounded-xl shadow-lg">
                <img src={url} alt={asset.fields?.title ?? ''} class="w-full h-auto object-cover" loading="lazy" decoding="async" />
              </figure>
            );
          })}
        </div>
      )}
    </article>

    <div class="max-w-4xl mx-auto px-6 sm:px-8 pb-20 pt-8 border-t border-black/10">
      <a href="/es/changelog" class="inline-flex items-center text-sm font-bold uppercase tracking-widest text-black hover:text-[rgb(200,90,70)] transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Volver al changelog
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
