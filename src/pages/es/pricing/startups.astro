---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const benefits = [
  { title: 'Tarifas para startups', desc: 'Precios que escalan contigo. Ofrecemos mejores condiciones iniciales para que puedas crecer sin costes iniciales.' },
  { title: 'Condiciones flexibles', desc: 'Sin permanencia prolongada. Opciones mes a mes y niveles de volumen que se adaptan a medida que crece tu uso.' },
  { title: 'Onboarding dedicado', desc: 'Soporte de integración rápido y orientación técnica para que puedas empezar a funcionar más rápido.' },
];
---

<BaseLayout
  title="Precios para Startups | Vehicle Imagery API"
  description="Plan personalizado para startups con mejores condiciones iniciales. Tarifas para startups, condiciones flexibles y onboarding dedicado. Solicita tu presupuesto."
  canonicalUrl="/es/pricing/startups"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 pt-24 pb-8 sm:px-12 lg:px-16">
      <div class="max-w-3xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Precios</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-[0.95] text-black tracking-tight mb-8">
          Diseñado para<br/>Startups
        </h1>
        <p class="text-[16px] text-black/50 leading-relaxed max-w-lg">
          Un plan personalizado diseñado para equipos en etapa inicial: mejores condiciones iniciales, términos flexibles y precios que crecen contigo — sin grandes compromisos iniciales.
        </p>
        <p class="mt-6 text-[13px] text-black/40">
          <a href="/es/pricing" class="hover:text-[rgb(200,90,70)] transition-colors">← Volver a Precios</a>
        </p>
      </div>
    </section>

    <!-- Main: Plan card + form -->
    <section class="mx-auto max-w-[1400px] px-6 pt-16 pb-24 sm:px-12 lg:px-16">
      <div class="grid gap-16 lg:grid-cols-[1fr_1fr] items-start">

        <!-- Left: Plan info & benefits -->
        <div>
          <div class="rounded-[2rem] overflow-hidden border border-black/[0.06] bg-[#fafafa] p-10 sm:p-12 mb-12">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[rgb(200,90,70)] mb-4 block">Plan Startup</span>
            <h2 class="text-4xl sm:text-5xl font-light text-black tracking-tight leading-[1.05] mb-6">
              Plan personalizado bajo solicitud
            </h2>
            <p class="text-[14px] text-black/50 leading-relaxed mb-8 max-w-md">
              Cuéntanos sobre tu etapa y uso. Crearemos un plan con tarifas para startups, volumen flexible y soporte que se ajuste a tus plazos.
            </p>
            <ul class="space-y-4">
              {benefits.map((b) => (
                <li class="flex gap-4">
                  <span class="shrink-0 w-6 h-6 rounded-full bg-[rgb(200,90,70)]/10 flex items-center justify-center">
                    <svg class="w-3 h-3 text-[rgb(200,90,70)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </span>
                  <div>
                    <p class="text-[14px] font-medium text-black">{b.title}</p>
                    <p class="text-[13px] text-black/50 leading-relaxed">{b.desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <div class="grid grid-cols-3 gap-6">
            <div>
              <p class="text-2xl font-light text-black tracking-tight">24h</p>
              <p class="text-[10px] text-black/40 uppercase tracking-wider mt-1">Tiempo de respuesta</p>
            </div>
            <div>
              <p class="text-2xl font-light text-black tracking-tight">Flex</p>
              <p class="text-[10px] text-black/40 uppercase tracking-wider mt-1">Condiciones de pago</p>
            </div>
            <div>
              <p class="text-2xl font-light text-black tracking-tight">Misma API</p>
              <p class="text-[10px] text-black/40 uppercase tracking-wider mt-1">Acceso completo</p>
            </div>
          </div>
        </div>

        <!-- Right: Request form -->
        <div class="group relative rounded-[2rem] overflow-hidden transition-all duration-500 hover:shadow-[0_40px_80px_-20px_rgba(10,43,49,0.35)]" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[rgb(200,90,70)] via-[rgb(200,90,70)]/40 to-transparent"></div>
          <div class="relative p-10 sm:p-14">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/20 mb-4 block">Solicita tu presupuesto</span>
            <h3 class="text-3xl sm:text-4xl font-light text-white tracking-tight leading-[1.05] mb-4">
              Obtén condiciones startup
            </h3>
            <p class="text-[14px] text-white/40 leading-relaxed mb-10 max-w-sm">
              Te responderemos en 24 horas con una oferta personalizada y los próximos pasos.
            </p>

            <div id="startups-form-wrapper" class="transition-all duration-700 ease-out">
              <div id="startups-form-content">
                <form id="startups-form" class="space-y-5">
                  <input type="hidden" name="subject" value="Pricing – Startup Plan Request" />

                  <div>
                    <input type="text" name="name" required placeholder="Tu nombre" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <input type="email" name="email" required placeholder="Correo de trabajo" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <input type="text" name="company" placeholder="Empresa / Producto" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <textarea name="message" rows="3" placeholder="Cuéntanos sobre tu etapa, uso esperado y lo que estás construyendo..." class="w-full resize-none border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors"></textarea>
                  </div>

                  <div class="pt-4">
                    <button type="submit" id="startups-submit-btn" class="group/btn inline-flex items-center justify-center rounded-full px-8 py-4 text-[13px] font-medium transition-all duration-300 bg-white text-black hover:bg-[rgb(200,90,70)] hover:text-white w-full sm:w-auto">
                      <span>Solicitar presupuesto startup</span>
                      <svg class="w-4 h-4 ml-2 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                      </svg>
                    </button>
                  </div>
                </form>
              </div>

              <div id="startups-success" class="hidden flex-col items-center justify-center text-center py-12">
                <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-white/20">
                  <svg class="h-10 w-10" viewBox="0 0 52 52" fill="none">
                    <circle cx="26" cy="26" r="24" stroke="white" stroke-width="2.5" fill="none" stroke-dasharray="150.8" stroke-dashoffset="150.8" class="startups-circle" />
                    <path d="M15 27L23 35L37 19" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" stroke-dasharray="40" stroke-dashoffset="40" class="startups-check" />
                  </svg>
                </div>
                <h3 class="text-2xl font-normal text-white mb-3">¡Presupuesto solicitado!</h3>
                <p class="text-[14px] text-white/70 max-w-xs leading-relaxed">Te responderemos en 24 horas con una oferta personalizada.</p>
              </div>
            </div>

            <style>
              @keyframes startups-draw-circle { to { stroke-dashoffset: 0; } }
              @keyframes startups-draw-check { to { stroke-dashoffset: 0; } }
              #startups-form-wrapper.success .startups-circle { animation: startups-draw-circle 0.6s ease-out 0.2s forwards; }
              #startups-form-wrapper.success .startups-check { animation: startups-draw-check 0.4s ease-out 0.7s forwards; }
            </style>

            <script>
              (function() {
                const form = document.getElementById('startups-form');
                const wrapper = document.getElementById('startups-form-wrapper');
                const formContent = document.getElementById('startups-form-content');
                const successEl = document.getElementById('startups-success');
                form.addEventListener('submit', (e) => {
                  e.preventDefault();
                  const data = Object.fromEntries(new FormData(form).entries());
                  fetch('/api/submit', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify(data) }).catch(() => {});
                  formContent.style.opacity = '0'; formContent.style.transform = 'scale(0.95)'; formContent.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                  setTimeout(() => { formContent.classList.add('hidden'); wrapper.classList.add('success'); successEl.classList.remove('hidden'); successEl.classList.add('flex'); successEl.style.opacity = '0'; successEl.style.transform = 'scale(0.95)'; requestAnimationFrame(() => { successEl.style.transition = 'opacity 0.5s ease 0.1s, transform 0.5s ease 0.1s'; successEl.style.opacity = '1'; successEl.style.transform = 'scale(1)'; }); }, 300);
                });
              })();
            </script>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="pb-24 sm:pb-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] px-8 py-16 sm:px-16 sm:py-20" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-10">
            <div class="max-w-xl">
              <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Otras opciones</p>
              <h2 class="text-3xl sm:text-4xl font-light tracking-tight text-white leading-[1.05] mb-4">
                Prueba gratuita o plan personalizado estándar
              </h2>
              <p class="text-[14px] text-white/40 leading-relaxed">
                ¿No eres una startup? Consulta nuestros precios principales: prueba gratuita o un plan personalizado bajo solicitud.
              </p>
            </div>
            <div class="flex flex-col sm:flex-row gap-4 shrink-0">
              <a href="/es/pricing" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[13px] font-medium text-black transition-all duration-300 hover:bg-[rgb(200,90,70)] hover:text-white">
                Ver precios
              </a>
              <a href="/es/contact" class="inline-flex items-center justify-center rounded-full border border-white/15 px-8 py-4 text-[13px] font-medium text-white/70 transition-all duration-300 hover:bg-white/10 hover:text-white">
                Contacto
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
