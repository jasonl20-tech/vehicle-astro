---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getEntries } from '../../../lib/contentful';
import { richTextToPlainText, buildAssetMap } from '../../../lib/contentful-rich-text';

type TutorialItem = {
  slug: string;
  title: string;
  date?: string;
  excerpt?: string;
  category?: string;
  categorySlug?: string;
  featuredImageUrl?: string;
  featuredImageAlt?: string;
  authorName?: string;
  authorAvatarUrl?: string;
  difficulty?: string;
  durationMinutes?: number;
  tags?: string[];
};

let tutorials: TutorialItem[] = [];

try {
  const res = await getEntries({
    content_type: 'tutorials',
    order: '-fields.publishedAt',
    limit: 100,
    include: 2,
    locale: 'es',
  });
  const assetMap = buildAssetMap(res.includes as { Asset?: Array<{ sys: { id: string }; fields?: { file?: { url?: string }; title?: string } }> });

  function assetUrl(linkOrAsset: { sys?: { id?: string }; fields?: { file?: { url?: string } } } | null | undefined): string {
    if (!linkOrAsset) return '';
    if (linkOrAsset.fields?.file?.url) {
      const u = linkOrAsset.fields.file.url;
      return u.startsWith('//') ? `https:${u}` : u;
    }
    const id = linkOrAsset.sys?.id;
    if (!id) return '';
    const asset = assetMap[id];
    if (!asset?.fields?.file?.url) return '';
    const u = asset.fields.file.url;
    return u.startsWith('//') ? `https:${u}` : u;
  }

  tutorials = res.items
    .filter((item: { fields?: { slug?: string } }) => item.fields?.slug)
    .map((item: {
      fields?: {
        slug?: string;
        title?: string;
        publishedAt?: string;
        excerpt?: import('@contentful/rich-text-types').Document;
        category?: string;
        categorySlug?: string;
        featuredImage?: { sys?: { id?: string }; fields?: { file?: { url?: string } } };
        featuredImageAlt?: string;
        authorName?: string;
        authorAvatar?: { sys?: { id?: string }; fields?: { file?: { url?: string } } };
        difficulty?: string;
        durationMinutes?: number;
        tags?: string[];
      };
    }) => ({
      slug: item.fields!.slug!,
      title: item.fields?.title ?? 'Sin título',
      date: item.fields?.publishedAt,
      excerpt: item.fields?.excerpt ? richTextToPlainText(item.fields.excerpt, 160) : undefined,
      category: item.fields?.category,
      categorySlug: item.fields?.categorySlug,
      featuredImageUrl: assetUrl(item.fields?.featuredImage) || undefined,
      featuredImageAlt: item.fields?.featuredImageAlt,
      authorName: item.fields?.authorName,
      authorAvatarUrl: assetUrl(item.fields?.authorAvatar) || undefined,
      difficulty: item.fields?.difficulty,
      durationMinutes: item.fields?.durationMinutes,
      tags: item.fields?.tags,
    }));
} catch {}
---

<BaseLayout
  title="Tutoriales | Vehicle Imagery API"
  description="Tutoriales paso a paso para la API de Vehicle Imagery. Aprende a integrar imágenes de vehículos con calidad de estudio en tu aplicación."
  canonicalUrl="/es/tutorials"
>
  <Header />
  <main class="min-h-screen bg-cream">
    <section class="border-b border-[#1C2B32]/10 bg-[#1C2B32] px-6 py-20 sm:px-12 lg:px-16">
      <div class="mx-auto max-w-7xl">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/50">Vehicle Imagery</p>
        <h1 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl md:text-6xl">Tutoriales</h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/80">
          Guías paso a paso para ayudarte a integrar y aprovechar al máximo la API de Vehicle Imagery.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-16 sm:px-12 lg:px-16">
      {tutorials.length > 0 ? (
        <ul class="grid gap-12 sm:gap-16 md:grid-cols-2 xl:grid-cols-2 lg:gap-20">
          {tutorials.map((tut) => (
            <li>
              <a href={`/es/tutorials/${tut.slug}`} class="tutorial-card group block">
                <div class="overflow-hidden rounded-none border border-[#1C2B32]/10 bg-white shadow-[0_4px_24px_-4px_rgba(28,43,50,0.08)] transition-all duration-300 hover:border-[#1C2B32]/20 hover:shadow-[0_12px_40px_-8px_rgba(28,43,50,0.15)]">
                  {tut.featuredImageUrl ? (
                    <div class="aspect-[16/10] overflow-hidden bg-[#1C2B32]/5">
                      <img
                        src={tut.featuredImageUrl.startsWith('http') ? tut.featuredImageUrl : `https:${tut.featuredImageUrl}`}
                        alt={tut.featuredImageAlt || tut.title}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                        width={640}
                        height={400}
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="aspect-[16/10] flex items-center justify-center bg-[#1C2B32]/[0.06]">
                      <span class="text-6xl font-black text-[#1C2B32]/10">VI</span>
                    </div>
                  )}
                  <div class="p-6 sm:p-8">
                    <div class="flex flex-wrap items-center gap-2">
                      {tut.category && (
                        <span class="inline-block text-xs font-bold uppercase tracking-[0.15em] text-accent">
                          {tut.category}
                        </span>
                      )}
                      {tut.difficulty && (
                        <span class={`inline-block rounded-none px-2 py-0.5 text-xs font-bold uppercase tracking-wider ${
                          tut.difficulty === 'Beginner' ? 'bg-emerald-100 text-emerald-700' :
                          tut.difficulty === 'Intermediate' ? 'bg-amber-100 text-amber-700' :
                          'bg-red-100 text-red-700'
                        }`}>
                          {tut.difficulty}
                        </span>
                      )}
                    </div>
                    <h2 class="mt-3 text-xl font-bold leading-tight text-[#1C2B32] transition-colors group-hover:text-accent sm:text-2xl">
                      {tut.title}
                    </h2>
                    {tut.excerpt && (
                      <p class="mt-3 line-clamp-3 text-[15px] leading-relaxed text-[#1C2B32]/70">
                        {tut.excerpt}
                      </p>
                    )}
                    <div class="mt-6 flex flex-wrap items-center gap-4 border-t border-[#1C2B32]/10 pt-5">
                      {tut.authorAvatarUrl && (
                        <img
                          src={tut.authorAvatarUrl.startsWith('http') ? tut.authorAvatarUrl : `https:${tut.authorAvatarUrl}`}
                          alt={tut.authorName ? `Avatar de ${tut.authorName}` : ''}
                          class="h-9 w-9 rounded-full object-cover ring-2 ring-white"
                          width="36"
                          height="36"
                        />
                      )}
                      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[#1C2B32]/60">
                        {tut.authorName && <span class="font-medium text-[#1C2B32]/80">{tut.authorName}</span>}
                        {tut.durationMinutes != null && (
                          <span>{tut.durationMinutes} min</span>
                        )}
                        {tut.date && (
                          <time datetime={tut.date}>
                            {new Date(tut.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
                          </time>
                        )}
                      </div>
                    </div>
                    {tut.tags && tut.tags.length > 0 && (
                      <div class="mt-4 flex flex-wrap gap-2">
                        {tut.tags.slice(0, 4).map((tag: string) => (
                          <span class="rounded-none border border-[#1C2B32]/15 bg-[#1C2B32]/[0.04] px-2.5 py-1 text-xs font-medium text-[#1C2B32]/70">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="rounded-none border border-[#1C2B32]/10 bg-white p-16 text-center">
          <p class="text-[#1C2B32]/60">Aún no hay tutoriales disponibles. ¡Vuelve pronto!</p>
          <a href="/es" class="mt-6 inline-block border border-[#1C2B32] px-6 py-3 text-sm font-bold uppercase tracking-widest text-[#1C2B32] transition-colors hover:bg-[#1C2B32] hover:text-cream">
            Volver al inicio
          </a>
        </div>
      )}
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .tutorial-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
