              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="text-[10px] font-bold uppercase tracking-wider text-black/70">
                  {item.category ?? item.type === 'changelog' ? 'Changelog' : 'Blog'}
                </span>
                <time class="text-xs font-mono text-gray-600" datetime={item.date}>
                  {item.date ? new Date(item.date).toLocaleDateString('es-ES', { month: 'short', day: 'numeric', year: 'numeric' }) : ''}
                </time>
              </div>
              <h3 class="text-lg sm:text-xl font-bold text-black group-hover:text-[rgb(200,90,70)] transition-colors mb-2">{item.title}</h3>
              {item.excerpt && (
                <p class="text-sm text-gray-600 leading-relaxed mb-4">{item.excerpt}</p>
              )}
              <span class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-black/60 group-hover:text-[rgb(200,90,70)] transition-colors">
                Leer más
                <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </a>
        ))}
      </div>
    ) : (
      <div class="w-full py-12 text-center text-gray-600 px-6">
        <p>Aún no hay actualizaciones. Añade entradas de changelog o publicaciones de blog en Contentful.</p>
      </div>
    )}
  </section>

  </main>
  <Footer />

  <script>
    const slider = document.getElementById('before-after-slider');
    if (slider) {
      const handle = document.getElementById('slider-handle');
      const left = document.getElementById('slider-left');
      const right = document.getElementById('slider-right');
      let isDragging = false;
      function updateSlider(x: number) {
        const rect = slider.getBoundingClientRect();
        let pct = ((x - rect.left) / rect.width) * 100;
        pct = Math.max(0, Math.min(100, pct));
        if (handle) handle.style.left = pct + '%';
        if (left) left.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
        if (right) right.style.clipPath = `inset(0 0 0 ${pct}%)`;
      }
      slider.addEventListener('mousedown', (e: MouseEvent) => { isDragging = true; updateSlider(e.clientX); });
      document.addEventListener('mousemove', (e: MouseEvent) => { if (isDragging) updateSlider(e.clientX); });
      document.addEventListener('mouseup', () => { isDragging = false; });
      slider.addEventListener('touchstart', (e: TouchEvent) => { isDragging = true; updateSlider(e.touches[0].clientX); });
      document.addEventListener('touchmove', (e: TouchEvent) => { if (isDragging) updateSlider(e.touches[0].clientX); });
      document.addEventListener('touchend', () => { isDragging = false; });
    }
  </script>
</BaseLayout>
