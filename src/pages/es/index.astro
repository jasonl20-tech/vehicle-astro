---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementBar from '../../components/AnnouncementBar.astro';
import { getEntries, getSiteStats, getCompanyInfo } from '../../lib/contentful';
import { buildAssetMap, richTextToPlainText } from '../../lib/contentful-rich-text';

type UpdateItem = { slug: string; title: string; date: string; excerpt?: string; category?: string; type: 'changelog' | 'blog' };
let latestUpdates: UpdateItem[] = [];
let announcementBar: {
  message: import('@contentful/rich-text-types').Document | null;
  link: string | null;
  linkColor: string | null;
  backgroundColor: string | null;
  assetMap?: import('../lib/contentful-rich-text').AssetMap;
} | null = null;

try {
  const [changelogRes, blogRes, announcementRes] = await Promise.all([
    getEntries({ content_type: 'api', order: '-sys.createdAt', limit: 4 }),
    getEntries({ content_type: 'blogPost', order: '-sys.createdAt', limit: 4 }).catch(() => ({ items: [] })),
    getEntries({ content_type: 'announcementBar', limit: 1, order: '-sys.updatedAt', include: 2 }).catch(() => ({ items: [], includes: {} })),
  ]);
  const firstAnnouncement = announcementRes?.items?.[0] as { fields?: { message?: unknown; link?: string; linkColor?: string; backgroundColor?: string } } | undefined;
  if (firstAnnouncement?.fields?.message) {
    announcementBar = {
      message: firstAnnouncement.fields.message as import('@contentful/rich-text-types').Document,
      link: firstAnnouncement.fields.link ?? null,
      linkColor: firstAnnouncement.fields.linkColor ?? null,
      backgroundColor: firstAnnouncement.fields.backgroundColor ?? null,
      assetMap: buildAssetMap(announcementRes?.includes),
    };
  }
  const changelogs: UpdateItem[] = (changelogRes.items || [])
    .filter((i: { fields?: { slug?: string } }) => i.fields?.slug)
    .map((i: { fields?: { slug?: string; title?: string; excerpt?: string; category?: string }; sys?: { createdAt?: string } }) => ({
      slug: i.fields!.slug!,
      title: i.fields?.title ?? 'Sin título',
      date: i.sys?.createdAt ?? '',
      excerpt: i.fields?.excerpt,
      category: i.fields?.category,
      type: 'changelog' as const,
    }));
  const blogs: UpdateItem[] = (blogRes.items || [])
    .filter((i: { fields?: { slug?: string } }) => i.fields?.slug)
    .map((i: { fields?: { slug?: string; title?: string; excerpt?: unknown; publishedAt?: string; category?: string }; sys?: { createdAt?: string } }) => ({
      slug: i.fields!.slug!,
      title: i.fields?.title ?? 'Sin título',
      date: i.fields?.publishedAt ?? i.sys?.createdAt ?? '',
      excerpt: i.fields?.excerpt ? richTextToPlainText(i.fields.excerpt as import('@contentful/rich-text-types').Document, 120) : undefined,
      category: i.fields?.category ?? 'Blog',
      type: 'blog' as const,
    }));
  latestUpdates = [...changelogs, ...blogs]
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
    .slice(0, 6);
} catch {
  latestUpdates = [];
  announcementBar = null;
}

const stats = await getSiteStats();
const company = await getCompanyInfo();
const siteUrl = Astro.url.origin;
const homepageStructuredData: unknown[] = [
  {
    '@type': 'SoftwareApplication',
    name: company.productName,
    applicationCategory: 'DeveloperApplication',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
    aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '150' },
    description: `API de imágenes de vehículos con calidad de estudio con más de ${stats.assets} fotos de coches. Optimizado para CDN, integración sencilla para empresas automotrices. Alternativa a IMAGIN.studio y EVOX Images con mejor precio y cobertura europea.`,
    url: siteUrl,
    provider: { '@type': 'Organization', name: company.companyName, url: siteUrl },
  },
  {
    '@type': 'Organization',
    name: company.companyName,
    url: siteUrl,
    logo: `${siteUrl}/logo.svg`,
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: company.phone,
      contactType: 'servicio al cliente',
      email: company.emailSupport,
    },
    sameAs: [company.twitterUrl, company.facebookUrl, company.linkedinUrl].filter(Boolean),
  },
  {
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: '¿Qué es Vehicle Imagery API?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: "Vehicle Imagery API proporciona fotos de coches con calidad de estudio e imágenes automotrices a través de una API REST sencilla. Está diseñado para concesionarios, empresas de leasing y aplicaciones automotrices que necesitan fotografía de vehículos consistente y de alta calidad.",
        },
      },
      {
        '@type': 'Question',
        name: '¿Cuántas imágenes de coches están disponibles?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Nuestra base de datos contiene más de 40.000 fotos de coches con calidad de estudio, cubriendo más de 10.000 modelos de coches únicos.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Vehicle Imagery API ofrece fondos transparentes?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Sí, todas las imágenes de vehículos están disponibles como PNG de alta resolución con fondos transparentes, listas para una integración perfecta en cualquier diseño o plataforma.',
        },
      },
      {
        '@type': 'Question',
        name: '¿Hay una prueba gratuita disponible?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Sí, puedes registrarte para obtener acceso gratuito y probar nuestra API con imágenes reales. No se requiere tarjeta de crédito para comenzar a explorar nuestra biblioteca.',
        },
      },
    ],
  },
];
---

<BaseLayout
  title="Vehicle Imagery API | Fotos de coches y API"
  description="La API definitiva de fotografía de coches. Imágenes de vehículos con calidad de estudio para concesionarios, leasing y plataformas automotrices. Consistente. Escalable. Hermoso."
  ogImage="/images/hero-car.webp"
  ogImageAlt="Vehicle Imagery – API de fotografía de coches con calidad de estudio para concesionarios y plataformas automotrices"
  canonicalUrl="/es"
  structuredDataGraph={homepageStructuredData}
  preloadHero
  preloadFirstImage="/images/cupra_front.webp"
>
  {announcementBar && (
    <AnnouncementBar
      message={announcementBar.message}
      link={announcementBar.link}
      linkColor={announcementBar.linkColor}
      backgroundColor={announcementBar.backgroundColor}
      assetMap={announcementBar.assetMap}
    />
  )}
  <Header />

  <style>
    .hero-section {
      --vi-dark: rgb(10, 43, 49);
      --vi-cream: rgb(255, 254, 252);
      --vi-red: rgb(200, 90, 70);
      font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
    }
    @media (min-width: 768px) {
      .hero-section { grid-template-columns: 65% 35%; }
    }
    .vi-font { font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif; }
    .interior-cell.img-failed picture { display: none; }
    .interior-cell.img-failed .img-placeholder { display: flex; }
  </style>

  <main id="main-content">
  <!-- Hero Section -->
  <section class="hero-section relative grid grid-cols-1 min-h-[calc(100svh-5rem)] md:min-h-[calc(100vh-80px)] md:h-[calc(100vh-80px)] overflow-hidden md:overflow-visible">
    <div class="pointer-events-none absolute left-0 right-0 -top-[2px] z-10" style="height:2px; background-color:var(--vi-dark); background-image:linear-gradient(to right, var(--vi-cream) 0%, var(--vi-cream) 65%, var(--vi-dark) 65%, var(--vi-dark) 100%);"></div>
    <div class="px-5 sm:px-8 md:px-16 flex flex-col justify-center items-start relative w-full order-1 self-stretch min-h-full py-12 sm:py-16 md:py-0" style="background-color:var(--vi-cream);">
      <div class="absolute top-0 left-0 w-full h-px bg-black/5 md:hidden"></div>
      <div class="max-w-[640px] w-full md:mt-[-15%]">
        <div class="flex items-center space-x-4 mb-6 sm:mb-8">
          <span class="text-xs font-mono text-gray-600 uppercase">Estándares de calidad de estudio</span>
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-black mb-6 sm:mb-8 text-black leading-[0.9] tracking-tighter uppercase">
          VEHICLE<br/>IMAGES<br/>API.
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 mb-8 sm:mb-10 leading-relaxed max-w-lg font-light">
          La API definitiva de fotografía de coches. Recursos con calidad de estudio para concesionarios, leasing y plataformas automotrices. Consistente. Escalable. Hermoso.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 items-start sm:items-center">
          <a class="group relative w-full sm:w-auto text-center sm:text-left px-6 sm:px-8 py-3.5 sm:py-4 text-white text-sm font-bold uppercase tracking-widest overflow-hidden rounded-none" style="background-color:var(--vi-dark);" href="/es/contact">
            <span class="relative z-10 group-hover:text-white transition-colors">Contáctenos</span>
            <div class="absolute inset-0 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300" style="background-color:var(--vi-red);"></div>
          </a>
          <a class="group flex items-center text-black text-sm font-bold uppercase tracking-widest transition-colors hover:text-[rgb(200,90,70)]" href="/es/documentation">
            Ver documentación
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
    <div class="hidden md:flex items-center justify-center p-0 relative z-0 overflow-hidden order-2 self-stretch" style="background-color:var(--vi-dark); border-bottom-left-radius: 48px;">
      <div class="absolute inset-0 opacity-20" style="background-image:radial-gradient(#4a4a4a 1px, transparent 1px); background-size:32px 32px; border-radius: inherit;"></div>
      <div class="p-10 md:p-16 w-full relative z-10">
        <div class="font-black text-white uppercase tracking-tighter leading-[0.8] pointer-events-none select-none mix-blend-overlay" style="font-size:clamp(3rem, 12vw, 230px); line-height:0.8; font-weight:900; opacity:0.05; transform:scale(1.5); transform-origin:center center;" aria-hidden="true">EVERY CAR STOCK IMAGERY, API.</div>
      </div>
    </div>
    <div class="hidden md:block absolute inset-0 z-20 pointer-events-none" style="left:65%; transform:translateX(-50%);">
      <picture>
      <source srcset="/images/hero-car.webp" type="image/webp" />
      <img src="/images/hero-car.png" alt="BMW X6 - Vista previa de Vehicle Imagery API" width="1200" height="805" draggable="false" fetchpriority="high" decoding="async" class="w-auto max-w-none object-contain pointer-events-auto" style="height:58.5%; margin-top:20%; filter:drop-shadow(0 20px 40px rgba(0,0,0,0.3)); user-select:none;"/>
    </picture>
    </div>
  </section>

  <!-- Vehicle Perspectives Gallery -->
  <section class="pt-10 sm:pt-16 md:pt-24 pb-0 w-full vi-font overflow-hidden" style="background-color:rgb(255, 254, 252);">
    <div class="w-full">
      <div class="mb-8 sm:mb-12 md:mb-16 px-4 sm:px-6 md:px-12">
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-black text-black tracking-tighter leading-none">PERSPECTIVAS DE VEHÍCULOS.</h2>
        <p class="mt-4 text-base sm:text-lg text-gray-600 font-light max-w-2xl">Fotografía de vehículos completa desde todos los ángulos con calidad de estudio profesional.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-0" style="grid-auto-rows: minmax(220px, 1fr);">
        {[
          { name: "Frontal", img: "cupra_front", num: "01", span: "", bg: "#f8f8f8", interior: false },
          { name: "Frontal-Izq", img: "cupra_front_left", num: "02", span: "", bg: "#efefef", interior: false },
          { name: "Lateral-Izq", img: "cupra_side_left", num: "03", span: "", bg: "#e8e8e8", interior: false },
          { name: "Trasero-Izq", img: "cupra_rear_left", num: "04", span: "", bg: "#f5f5f5", interior: false },
          { name: "Trasero", img: "cupra_rear", num: "05", span: "", bg: "#e0e0e0", interior: false },
          { name: "Trasero-Der", img: "cupra_rear_right", num: "06", span: "", bg: "#fafafa", interior: false },
          { name: "Lateral-Der", img: "cupra_side_right", num: "07", span: "", bg: "#ebebeb", interior: false },
          { name: "Frontal-Der", img: "cupra_front_right", num: "08", span: "", bg: "#f0f0f0", interior: false },
          { name: "Cabina", img: "cupra_cockpit", num: "09", span: "", bg: "#e5e5e5", interior: true, ext: "jpeg" },
          { name: "Volante", img: "cupra_front_row", num: "10", span: "", bg: "#eeeeee", interior: true, ext: "jpeg" },
          { name: "Consola central", img: "cupra_rear_row", num: "11", span: "", bg: "#e8e8e8", interior: true, ext: "jpeg" },
          { name: "—", img: null, num: "", span: "", bg: "rgb(10, 43, 49)", placeholder: true }
        ].map((a, i) => (
          <article class={`group relative flex items-center justify-center min-h-[180px] ${a.span || ""}`} style={`background-color:${a.bg}`}>
            {a.placeholder ? (
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-[10px] font-mono text-white/30 uppercase tracking-widest">—</span>
              </div>
            ) : a.interior ? (
              <div class="interior-cell absolute inset-0">
                <div class="img-placeholder absolute inset-0 hidden items-center justify-center bg-black/5">
                  <div class="w-12 h-12 border-2 border-dashed border-black/20 flex items-center justify-center">
                    <svg class="w-6 h-6 text-black/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14"></path></svg>
                  </div>
                  <span class="absolute top-2 right-2 text-[8px] font-bold uppercase tracking-wider text-black/40 px-1.5 py-0.5 bg-white/80">Próximamente</span>
                </div>
                <picture class="absolute inset-0" data-fallback="placeholder">
                  <img src={`/images/${a.img}.${a.ext || 'png'}`} alt={a.name} class="w-full h-full object-cover" loading="lazy" decoding="async" draggable="false" onerror="this.closest('.interior-cell').classList.add('img-failed')"/>
                </picture>
                <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex flex-col items-center justify-center">
                  <span class="text-xs font-bold uppercase tracking-widest text-black px-3 py-1.5 bg-white/95 rounded-lg shadow-sm">{a.name}</span>
                </div>
              </div>
            ) : (
              <>
                <picture class="absolute inset-0 flex items-center justify-center p-2">
                  <source srcset={`/images/${a.img}.webp`} type="image/webp" />
                  <img src={`/images/${a.img}.png`} alt={a.name} class="max-w-full max-h-full w-auto h-auto object-contain" loading={i < 4 ? "eager" : "lazy"} decoding="async" draggable="false" fetchpriority={i === 0 ? "high" : undefined}/>
                </picture>
                <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex flex-col items-center justify-center">
                  <span class="text-xs font-bold uppercase tracking-widest text-black px-3 py-1.5 bg-white/95 rounded-lg shadow-sm">{a.name}</span>
                </div>
              </>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Developer Experience -->
  <section class="py-16 sm:py-24 w-full text-white overflow-hidden vi-font" style="background-color:rgb(10, 43, 49);">
    <div class="w-full px-6 sm:px-8 md:px-12 lg:px-16 xl:px-24">
      <div class="w-full mx-auto max-w-[1400px]">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black mb-6 tracking-tighter">Experiencia de desarrollo ante todo</h2>
            <p class="text-lg text-gray-600 mb-8 leading-relaxed">Nuestra API está diseñada para ser intuitiva y potente. A diferencia de los proveedores tradicionales, no nos escondemos detrás de SDKs complejos o llamadas de ventas. Obtienes acceso instantáneo a documentación RESTful limpia.</p>
            <ul class="space-y-4 mb-10">
              {["Arquitectura API RESTful", "Respuestas JSON", "Manejo integral de errores", `SLA de ${stats.uptime} de disponibilidad`, "Entrega global por CDN"].map((item) => (
                <li class="flex items-center text-gray-300">
                  <svg class="w-5 h-5 mr-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  {item}
                </li>
              ))}
            </ul>
            <a class="inline-block bg-white text-black px-8 py-4 rounded-none font-bold uppercase tracking-widest hover:bg-[rgb(200,90,70)] hover:text-white transition-colors" href="/es/documentation">Ver documentación API</a>
          </div>
          <div class="bg-[#1e1e1e]  shadow-2xl overflow-hidden border border-white/10">
            <div class="flex items-center px-6 py-4 bg-[#252526] border-b border-white/5">
              <div class="flex space-x-2 mr-4">
                <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
                <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
                <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
              </div>
              <div class="text-sm text-gray-600 font-mono">example-request.js</div>
            </div>
            <div class="p-8 font-mono text-base leading-relaxed overflow-x-auto">
              <div class="text-gray-300">
                <span class="text-[#c586c0]">const</span> response <span class="text-[#c586c0]">=</span> <span class="text-[#c586c0]">await</span> <span class="text-[#dcdcaa]">fetch(</span><br/>
                &nbsp;&nbsp;<span class="text-[#ce9178]">'https://api.vehicleimagery.com/api/bmw/x5/2024/front-left'</span>,<br/>
                &nbsp;&nbsp;<span class="text-[#dcdcaa]">&#123;</span><br/>
                &nbsp;&nbsp;&nbsp;&nbsp;headers: <span class="text-[#dcdcaa]">&#123;</span><br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-[#ce9178]">'x-api-key'</span>: <span class="text-[#ce9178]">'YOUR_API_KEY'</span><br/>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="text-[#dcdcaa]">&#125;</span><br/>
                &nbsp;&nbsp;<span class="text-[#dcdcaa]">&#125;</span><br/>
                <span class="text-[#dcdcaa]">)</span>;<br/><br/>
                <span class="text-[#c586c0]">const</span> data <span class="text-[#c586c0]">=</span> <span class="text-[#c586c0]">await</span> response.<span class="text-[#dcdcaa]">json()</span>;<br/>
                console.<span class="text-[#dcdcaa]">log(</span>data[<span class="text-[#b5cea8]">0</span>].image_url<span class="text-[#dcdcaa]">)</span>;
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries We Serve -->
  <section class="border-t border-black/10 py-16 md:py-32 text-black w-full vi-font" style="background-color:rgb(255, 254, 252);">
    <div class="w-full px-6 sm:px-8 md:px-12 lg:px-16 xl:px-24">
      <div class="w-full mx-auto max-w-[1400px]">
        <div class="flex flex-col md:flex-row gap-16 items-start">
          <div class="md:w-1/3 md:sticky md:top-32">
            <h2 class="text-4xl sm:text-5xl font-black mb-6 text-black tracking-tighter leading-none">INDUSTRIAS<br/>QUE SERVIMOS</h2>
            <p class="text-lg text-gray-600 max-w-sm mb-8">Donde la API de imágenes de vehículos y la fotografía automotriz marcan una diferencia medible.</p>
            <div class="hidden md:block max-w-sm mt-12 p-6 bg-[#fafafa] border border-black/5 shadow-sm relative transform -rotate-1 hover:rotate-0 transition-transform duration-500">
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-16 h-6 bg-black/5 backdrop-blur-sm border border-black/5 rotate-2"></div>
              <div class="space-y-4">
                <div class="flex items-center space-x-2 mb-2">
                  <div class="w-1.5 h-1.5 bg-black/60 rounded-full" aria-hidden="true"></div>
                  <span class="text-[10px] font-mono uppercase tracking-widest text-gray-700">Nota técnica</span>
                </div>
                <p class="text-sm text-gray-600 leading-relaxed font-light">Nuestra <span class="text-black font-medium">API de imágenes automotrices</span> está diseñada para velocidad y precisión. Ya sea que estés construyendo un sitio web de concesionario o una plataforma de leasing global, proporcionamos <span class="text-black font-medium">fotos de coches en alta resolución</span> que se adaptan a tu marca.</p>
                <p class="text-sm text-gray-600 leading-relaxed font-light">Desde <span class="text-black font-medium">fondos PNG transparentes</span> para una integración perfecta en la interfaz hasta <span class="text-black font-medium">colores de pintura calibrados</span> en cada acabado, nuestra flota de {stats.assets} recursos está lista para escalar con las necesidades de tu negocio.</p>
              </div>
            </div>
          </div>
          <div class="md:w-2/3 rounded-xl overflow-hidden grid grid-cols-1 sm:grid-cols-2">
            {[
              { title: "Empresas de leasing", desc: "Reemplaza las fotos borrosas en tus presupuestos y contratos con tomas profesionales de estudio. Consistencia de flota que genera confianza.", icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z", bg: "#f2f2f2", href: "/contact" },
              { title: "Apps móviles y web", desc: "Fotos de coches perfectas para tu app sin problemas de tamaño de archivo. Imágenes optimizadas por CDN que cargan al instante en cualquier dispositivo.", icon: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z", bg: "#ffffff", href: "/contact" },
              { title: "Concesionarios de coches", desc: "Muestra cada coche de tu inventario con fotos profesionales. No más sesiones fotográficas programadas: concéntrate en vender.", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4", bg: "#ffffff", href: "/contact" },
