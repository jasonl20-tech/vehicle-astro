---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getSiteStats, getCompanyInfo } from '../../lib/contentful';

const benefits = [
  { num: '01', title: 'Reparto de ingresos', desc: 'Gana comisiones por cada cliente que traigas. Seguimiento transparente, pagos mensuales.' },
  { num: '02', title: 'Co-marketing', desc: 'Campañas conjuntas, casos de estudio y posicionamiento destacado en nuestro sitio web y materiales.' },
  { num: '03', title: 'Acceso prioritario', desc: 'Acceso anticipado a nuevas funciones, endpoints de API dedicados y programas beta.' },
  { num: '04', title: 'Soporte técnico', desc: 'Ingeniero de integración dedicado y canal de soporte prioritario para tu equipo.' },
];

const stats = await getSiteStats();
const company = await getCompanyInfo();
---

<BaseLayout
  title="Socios | Vehicle Imagery API"
  description="Programa de socios de Vehicle Imagery. Únete a las principales empresas automotrices que usan nuestra API. Consultas de asociación bienvenidas."
  canonicalUrl="/es/partners"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 pt-24 pb-8 sm:px-12 lg:px-16">
      <div class="max-w-3xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Programa de socios</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-[0.95] text-black tracking-tight mb-8">
          Socios
        </h1>
        <p class="text-[16px] text-black/50 leading-relaxed max-w-lg">
          Trabajamos con empresas automotrices líderes en Europa. Conviértete en socio y crece con nosotros.
        </p>
      </div>
    </section>


    <!-- Why Partner -->
    <section class="py-24 sm:py-32 bg-[#fafafa]">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="grid gap-16 lg:grid-cols-[1fr_1.5fr] lg:gap-24 items-start">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Beneficios</p>
            <h2 class="text-3xl sm:text-4xl font-light leading-[1.05] text-black tracking-tight mb-6">
              Por qué asociarte<br/>con nosotros
            </h2>
            <p class="text-[14px] text-black/50 leading-relaxed max-w-sm">
              Más que una simple integración de API. Una verdadera asociación con crecimiento compartido.
            </p>
          </div>

          <div class="space-y-0">
            {benefits.map((b) => (
              <div class="group flex gap-6 py-8 border-b border-black/[0.06] first:border-t">
                <span class="text-[11px] font-mono text-black/20 pt-1 shrink-0">{b.num}</span>
                <div>
                  <h3 class="text-[16px] font-medium text-black mb-2 group-hover:text-[rgb(200,90,70)] transition-colors">{b.title}</h3>
                  <p class="text-[13px] text-black/50 leading-relaxed max-w-md">{b.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16">
          {[
            { value: stats.brands, label: 'Marcas cubiertas' },
            { value: stats.latency, label: 'Latencia prom.' },
            { value: stats.uptime, label: 'SLA de disponibilidad' },
            { value: stats.responseTime, label: 'Tiempo de respuesta' },
          ].map((stat) => (
            <div class="text-center">
              <p class="text-5xl sm:text-6xl lg:text-7xl font-extralight text-black tracking-tight mb-3">{stat.value}</p>
              <p class="text-[11px] text-black/40 uppercase tracking-[0.15em]">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Partner Contact Form -->
    <section class="pb-24 sm:pb-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] px-8 py-20 sm:px-16 sm:py-24" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full opacity-[0.04] pointer-events-none" style="background: radial-gradient(circle, white 0%, transparent 60%);" aria-hidden="true"></div>
          <div class="absolute -bottom-32 -left-16 w-64 h-64 rounded-full opacity-[0.03] pointer-events-none" style="background: radial-gradient(circle, rgba(200,90,70,1) 0%, transparent 60%);" aria-hidden="true"></div>

          <div class="relative z-10 grid gap-12 lg:grid-cols-[1fr_1fr] lg:gap-20 items-start">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Conviértete en socio</p>
              <h2 class="text-4xl sm:text-5xl font-light tracking-tight text-white leading-[1.05] mb-6">
                Crezcamos<br/>juntos
              </h2>
              <p class="text-[14px] text-white/40 leading-relaxed mb-10 max-w-sm">
                Cuéntanos sobre tu empresa y cómo podemos trabajar juntos. Respondemos a cada consulta en 24 horas.
              </p>
              <div class="space-y-4">
                <div>
                  <p class="text-[11px] text-white/25 uppercase tracking-wider mb-1">Asociaciones</p>
                  <a href={`mailto:${company.emailPartners}`} class="text-[14px] text-white/70 hover:text-white transition-colors">{company.emailPartners}</a>
                </div>
                <div>
                  <p class="text-[11px] text-white/25 uppercase tracking-wider mb-1">General</p>
                  <a href={`mailto:${company.emailInfo}`} class="text-[14px] text-white/70 hover:text-white transition-colors">{company.emailInfo}</a>
                </div>
              </div>
            </div>

            <div id="partners-form-wrapper" class="transition-all duration-700 ease-out">
              <div id="partners-form-content">
                <form id="partners-form" class="space-y-5">
                  <input type="hidden" name="subject" value="Consulta de asociación – Vehicle Imagery" />

                  <div>
                    <input type="text" name="name" required placeholder="Tu nombre" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <input type="email" name="email" required placeholder="Correo de trabajo" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <input type="text" name="company" required placeholder="Nombre de la empresa" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <input type="text" name="website" placeholder="Sitio web (opcional)" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <textarea name="message" rows="2" placeholder="Cuéntanos sobre la asociación que tienes en mente" class="w-full resize-none border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors"></textarea>
                  </div>

                  <div class="pt-4">
                    <button type="submit" id="partners-submit-btn" class="group/btn inline-flex items-center justify-center rounded-full px-8 py-4 text-[13px] font-medium transition-all duration-300 bg-white text-black hover:bg-[rgb(200,90,70)] hover:text-white">
                      <span>Enviar consulta</span>
                      <svg class="w-4 h-4 ml-2 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                      </svg>
                    </button>
                  </div>
                </form>
              </div>

              <div id="partners-success" class="hidden flex-col items-center justify-center text-center py-12">
                <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-white/20">
                  <svg class="h-10 w-10" viewBox="0 0 52 52" fill="none">
                    <circle cx="26" cy="26" r="24" stroke="white" stroke-width="2.5" fill="none" stroke-dasharray="150.8" stroke-dashoffset="150.8" class="partners-circle" />
                    <path d="M15 27L23 35L37 19" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" stroke-dasharray="40" stroke-dashoffset="40" class="partners-check" />
                  </svg>
                </div>
                <h3 class="text-2xl font-normal text-white mb-3">¡Consulta enviada!</h3>
                <p class="text-[14px] text-white/70 max-w-xs leading-relaxed">Responderemos en 24 horas.</p>
              </div>
            </div>

            <style>
              @keyframes partners-draw-circle { to { stroke-dashoffset: 0; } }
              @keyframes partners-draw-check { to { stroke-dashoffset: 0; } }
              #partners-form-wrapper.success .partners-circle { animation: partners-draw-circle 0.6s ease-out 0.2s forwards; }
              #partners-form-wrapper.success .partners-check { animation: partners-draw-check 0.4s ease-out 0.7s forwards; }
            </style>

            <script>
              (function() {
                const form = document.getElementById('partners-form');
                const wrapper = document.getElementById('partners-form-wrapper');
                const formContent = document.getElementById('partners-form-content');
                const successEl = document.getElementById('partners-success');
                form.addEventListener('submit', (e) => {
                  e.preventDefault();
                  const data = Object.fromEntries(new FormData(form).entries());
                  fetch('/api/submit', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify(data) }).catch(() => {});
                  formContent.style.opacity = '0'; formContent.style.transform = 'scale(0.95)'; formContent.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                  setTimeout(() => { formContent.classList.add('hidden'); wrapper.classList.add('success'); successEl.classList.remove('hidden'); successEl.classList.add('flex'); successEl.style.opacity = '0'; successEl.style.transform = 'scale(0.95)'; requestAnimationFrame(() => { successEl.style.transition = 'opacity 0.5s ease 0.1s, transform 0.5s ease 0.1s'; successEl.style.opacity = '1'; successEl.style.transform = 'scale(1)'; }); }, 300);
                });
              })();
            </script>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
