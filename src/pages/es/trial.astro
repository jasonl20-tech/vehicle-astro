---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const benefits = [
  { title: 'Sin límite de solicitudes', desc: 'Llamadas API ilimitadas durante tu prueba. Prueba todo lo que necesites dentro del alcance de la prueba.' },
  { title: 'Catálogo limitado', desc: 'Un conjunto reducido de vehículos y modelos, con opciones restringidas (ej. colores). Suficiente para integrar y validar la API.' },
  { title: 'Clave de 1 semana', desc: 'Tu clave API de prueba es válida durante 7 días. Sin tarjeta de crédito — sin compromiso, sin cargos automáticos.' },
];
---

<BaseLayout
  title="Prueba gratuita | Vehicle Imagery API"
  description="Solicita tu prueba gratuita de la API de Vehicle Imagery. Vehículos y opciones limitados, clave de 1 semana, sin límite de solicitudes, sin tarjeta de crédito. Comienza en minutos."
  canonicalUrl="/es/trial"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 pt-24 pb-8 sm:px-12 lg:px-16">
      <div class="max-w-3xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Pruébalo ahora</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-[0.95] text-black tracking-tight mb-8">
          Prueba gratuita
        </h1>
        <p class="text-[16px] text-black/50 leading-relaxed max-w-lg">
          Obtén tu clave API de prueba en minutos. Vehículos y opciones limitados para probar la API — sin límite de solicitudes, clave válida por 1 semana, sin tarjeta de crédito.
        </p>
        <p class="mt-6 text-[13px] text-black/40">
          <a href="/es/pricing" class="hover:text-[rgb(200,90,70)] transition-colors">Ver todos los planes →</a>
        </p>
      </div>
    </section>

    <!-- Main: Benefits + form -->
    <section class="mx-auto max-w-[1400px] px-6 pt-16 pb-24 sm:px-12 lg:px-16">
      <div class="grid gap-16 lg:grid-cols-[1fr_1fr] items-start">

        <!-- Left: What you get -->
        <div>
          <div class="rounded-[2rem] overflow-hidden border border-black/[0.06] bg-[#fafafa] p-10 sm:p-12 mb-12">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-full inline-block mb-6">Gratis</span>
            <h2 class="text-4xl sm:text-5xl font-light text-black tracking-tight leading-[1.05] mb-6">
              Qué incluye
            </h2>
            <p class="text-[14px] text-black/50 leading-relaxed mb-10 max-w-md">
              Una prueba enfocada: vehículos y modelos limitados, opciones restringidas (ej. colores). La misma API, la misma calidad — ideal para integrar y probar.
            </p>
            <ul class="space-y-4">
              {benefits.map((b) => (
                <li class="flex gap-4">
                  <span class="shrink-0 w-6 h-6 rounded-full bg-[rgb(200,90,70)]/10 flex items-center justify-center">
                    <svg class="w-3 h-3 text-[rgb(200,90,70)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </span>
                  <div>
                    <p class="text-[14px] font-medium text-black">{b.title}</p>
                    <p class="text-[13px] text-black/50 leading-relaxed">{b.desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <div class="grid grid-cols-3 gap-6">
            <div>
              <p class="text-2xl font-light text-black tracking-tight">7 días</p>
              <p class="text-[10px] text-black/40 uppercase tracking-wider mt-1">Validez de clave</p>
            </div>
            <div>
              <p class="text-2xl font-light text-black tracking-tight">Sin límite</p>
              <p class="text-[10px] text-black/40 uppercase tracking-wider mt-1">Solicitudes</p>
            </div>
            <div>
              <p class="text-2xl font-light text-black tracking-tight">Sin tarjeta</p>
              <p class="text-[10px] text-black/40 uppercase tracking-wider mt-1">Requerida</p>
            </div>
          </div>
        </div>

        <!-- Right: Trial request form -->
        <div class="group relative rounded-[2rem] overflow-hidden transition-all duration-500 hover:shadow-[0_40px_80px_-20px_rgba(10,43,49,0.35)]" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[rgb(200,90,70)] via-[rgb(200,90,70)]/40 to-transparent"></div>
          <div class="relative p-10 sm:p-14">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/20 mb-4 block">Solicitar acceso</span>
            <h3 class="text-3xl sm:text-4xl font-light text-white tracking-tight leading-[1.05] mb-4">
              Obtén tu clave API
            </h3>
            <p class="text-[14px] text-white/40 leading-relaxed mb-10 max-w-sm">
              Ingresa tu correo electrónico y te enviaremos los detalles de la prueba y tu clave API.
            </p>

            <div id="trial-form-wrapper" class="transition-all duration-700 ease-out">
              <div id="trial-form-content">
                <form id="trial-form" class="space-y-5">
                  <input type="hidden" name="subject" value="Free Trial Request" />

                  <div>
                    <input type="email" name="email" required placeholder="Correo de trabajo" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>

                  <div class="pt-4">
                    <button type="submit" id="trial-submit-btn" class="group/btn inline-flex items-center justify-center rounded-full px-8 py-4 text-[13px] font-medium transition-all duration-300 bg-white text-black hover:bg-[rgb(200,90,70)] hover:text-white w-full sm:w-auto">
                      <span>Solicitar prueba gratuita</span>
                      <svg class="w-4 h-4 ml-2 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                      </svg>
                    </button>
                  </div>
                </form>
              </div>

              <div id="trial-success" class="hidden flex-col items-center justify-center text-center py-12">
                <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-white/20">
                  <svg class="h-10 w-10" viewBox="0 0 52 52" fill="none">
                    <circle cx="26" cy="26" r="24" stroke="white" stroke-width="2.5" fill="none" stroke-dasharray="150.8" stroke-dashoffset="150.8" class="trial-circle" />
                    <path d="M15 27L23 35L37 19" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" stroke-dasharray="40" stroke-dashoffset="40" class="trial-check" />
                  </svg>
                </div>
                <h3 class="text-2xl font-normal text-white mb-3">¡Solicitud enviada!</h3>
                <p class="text-[14px] text-white/70 max-w-xs leading-relaxed">Te enviaremos los detalles de tu prueba en breve.</p>
              </div>
            </div>

            <style>
              @keyframes trial-draw-circle { to { stroke-dashoffset: 0; } }
              @keyframes trial-draw-check { to { stroke-dashoffset: 0; } }
              #trial-form-wrapper.success .trial-circle { animation: trial-draw-circle 0.6s ease-out 0.2s forwards; }
              #trial-form-wrapper.success .trial-check { animation: trial-draw-check 0.4s ease-out 0.7s forwards; }
            </style>

            <script>
              (function() {
                const form = document.getElementById('trial-form');
                const wrapper = document.getElementById('trial-form-wrapper');
                const formContent = document.getElementById('trial-form-content');
                const successEl = document.getElementById('trial-success');
                form.addEventListener('submit', (e) => {
                  e.preventDefault();
                  const data = Object.fromEntries(new FormData(form).entries());
                  fetch('https://submit-form.com/v6dFS1FAS', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify(data) }).catch(() => {});
                  formContent.style.opacity = '0'; formContent.style.transform = 'scale(0.95)'; formContent.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                  setTimeout(() => { formContent.classList.add('hidden'); wrapper.classList.add('success'); successEl.classList.remove('hidden'); successEl.classList.add('flex'); successEl.style.opacity = '0'; successEl.style.transform = 'scale(0.95)'; requestAnimationFrame(() => { successEl.style.transition = 'opacity 0.5s ease 0.1s, transform 0.5s ease 0.1s'; successEl.style.opacity = '1'; successEl.style.transform = 'scale(1)'; }); }, 300);
                });
              })();
            </script>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="pb-24 sm:pb-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] px-8 py-16 sm:px-16 sm:py-20" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-10">
            <div class="max-w-xl">
              <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Próximos pasos</p>
              <h2 class="text-3xl sm:text-4xl font-light tracking-tight text-white leading-[1.05] mb-4">
                ¿Necesitas el catálogo completo?
              </h2>
              <p class="text-[14px] text-white/40 leading-relaxed">
                Accede a todos los vehículos, modelos y opciones. Consulta nuestros precios o reserva una llamada para discutir tus necesidades.
              </p>
            </div>
            <div class="flex flex-col sm:flex-row gap-4 shrink-0">
              <a href="/es/pricing" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[13px] font-medium text-black transition-all duration-300 hover:bg-[rgb(200,90,70)] hover:text-white">
                Ver precios
              </a>
              <a href="/es/documentation" class="inline-flex items-center justify-center rounded-full border border-white/15 px-8 py-4 text-[13px] font-medium text-white/70 transition-all duration-300 hover:bg-white/10 hover:text-white">
                Documentación
              </a>
              <a href="/es/book-a-call" class="inline-flex items-center justify-center rounded-full border border-white/15 px-8 py-4 text-[13px] font-medium text-white/70 transition-all duration-300 hover:bg-white/10 hover:text-white">
                Reservar llamada
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
