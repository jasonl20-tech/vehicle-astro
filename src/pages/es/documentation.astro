---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getSiteStats } from '../../lib/contentful';

const BASE_URL = 'https://api.vehicleimagery.com';
const stats = await getSiteStats();

const endpoints = [
  { id: 'brands', method: 'GET', path: '/api/brands', title: 'Listar marcas', desc: 'Devuelve todas las marcas de vehículos disponibles en la base de datos.', params: [], query: [{ name: 'format', default: 'png', desc: 'Filtro de formato de imagen (png, webp, etc.)' }, { name: 'resolution', default: 'default', desc: 'Filtro de resolución (default, high, etc.)' }], response: '{\n  "brands": [\n    "Audi",\n    "BMW",\n    "Mercedes-Benz",\n    "Volkswagen",\n    ...\n  ]\n}' },
  { id: 'models', method: 'GET', path: '/api/{brand}', title: 'Listar modelos', desc: 'Devuelve todos los modelos disponibles para una marca determinada.', params: [{ name: 'brand', type: 'string', desc: 'Nombre de la marca (ej. BMW, Audi)' }], query: [{ name: 'format', default: 'png', desc: 'Filtro de formato de imagen' }, { name: 'resolution', default: 'default', desc: 'Filtro de resolución' }], response: '{\n  "brand": "BMW",\n  "resolution": "default",\n  "format": "png",\n  "models": [\n    "1 Series",\n    "3 Series",\n    "X5",\n    ...\n  ]\n}' },
  { id: 'years', method: 'GET', path: '/api/{brand}/{model}', title: 'Listar años', desc: 'Devuelve todos los años de modelo disponibles para una combinación específica de marca y modelo.', params: [{ name: 'brand', type: 'string', desc: 'Nombre de la marca' }, { name: 'model', type: 'string', desc: 'Nombre del modelo (ej. X5, A4)' }], query: [{ name: 'format', default: 'png', desc: 'Filtro de formato de imagen' }, { name: 'resolution', default: 'default', desc: 'Filtro de resolución' }], response: '[{\n  "brand": "BMW",\n  "model": "X5",\n  "resolution": "default",\n  "format": "png",\n  "years": [2020, 2021, 2022, 2023, 2024]\n}]' },
  { id: 'variants', method: 'GET', path: '/api/{brand}/{model}/{year}', title: 'Listar variantes', desc: 'Devuelve todas las variantes de carrocería (ej. Sedán, SUV, Wagon) disponibles para un año de modelo específico.', params: [{ name: 'brand', type: 'string', desc: 'Nombre de la marca' }, { name: 'model', type: 'string', desc: 'Nombre del modelo' }, { name: 'year', type: 'number', desc: 'Año del modelo (ej. 2024)' }], query: [{ name: 'format', default: 'png', desc: 'Filtro de formato de imagen' }, { name: 'resolution', default: 'default', desc: 'Filtro de resolución' }], response: '[{\n  "brand": "BMW",\n  "model": "X5",\n  "year": 2024,\n  "resolution": "default",\n  "format": "png",\n  "variants": ["SUV"]\n}]' },
  { id: 'trims', method: 'GET', path: '/api/{brand}/{model}/{year}/{variant}', title: 'Listar acabados', desc: 'Devuelve todos los acabados disponibles para una variante específica.', params: [{ name: 'brand', type: 'string', desc: 'Nombre de la marca' }, { name: 'model', type: 'string', desc: 'Nombre del modelo' }, { name: 'year', type: 'number', desc: 'Año del modelo' }, { name: 'variant', type: 'string', desc: 'Variante de carrocería (ej. SUV, Sedán)' }], query: [{ name: 'format', default: 'png', desc: 'Filtro de formato de imagen' }, { name: 'resolution', default: 'default', desc: 'Filtro de resolución' }], response: '[{\n  "brand": "BMW",\n  "model": "X5",\n  "year": 2024,\n  "variant": "SUV",\n  "resolution": "default",\n  "format": "png",\n  "trims": ["xDrive40i", "M60i"]\n}]' },
  { id: 'views', method: 'GET', path: '/api/{brand}/{model}/{year}/{variant}/{trim}', title: 'Listar vistas', desc: 'Devuelve todos los ángulos de cámara/vistas disponibles para una configuración de vehículo específica. Las vistas marcadas como "not_allowed" no están incluidas en su plan actual.', params: [{ name: 'brand', type: 'string', desc: 'Nombre de la marca' }, { name: 'model', type: 'string', desc: 'Nombre del modelo' }, { name: 'year', type: 'number', desc: 'Año del modelo' }, { name: 'variant', type: 'string', desc: 'Variante de carrocería' }, { name: 'trim', type: 'string', desc: 'Nivel de acabado' }], query: [{ name: 'format', default: 'png', desc: 'Filtro de formato de imagen' }, { name: 'resolution', default: 'default', desc: 'Filtro de resolución' }], response: '[{\n  "id": "a1b2c3d4e5f6",\n  "brand": "BMW",\n  "model": "X5",\n  "year": 2024,\n  "variant": "SUV",\n  "trim": "xDrive40i",\n  "resolution": "default",\n  "format": "png",\n  "views": {\n    "front": true,\n    "front-left": true,\n    "side-left": true,\n    "rear": true,\n    "cockpit": "not_allowed"\n  }\n}]' },
  { id: 'colors', method: 'GET', path: '/api/{brand}/{model}/{year}/{variant}/{trim}/colors', title: 'Listar colores', desc: 'Devuelve todos los colores disponibles para una configuración de vehículo específica. Solo se incluyen los colores permitidos por su plan.', params: [{ name: 'brand', type: 'string', desc: 'Nombre de la marca' }, { name: 'model', type: 'string', desc: 'Nombre del modelo' }, { name: 'year', type: 'number', desc: 'Año del modelo' }, { name: 'variant', type: 'string', desc: 'Variante de carrocería' }, { name: 'trim', type: 'string', desc: 'Nivel de acabado' }], query: [{ name: 'format', default: 'png', desc: 'Filtro de formato de imagen' }, { name: 'resolution', default: 'default', desc: 'Filtro de resolución' }], response: '[{\n  "id": "a1b2c3d4e5f6",\n  "brand": "BMW",\n  "model": "X5",\n  "year": 2024,\n  "variant": "SUV",\n  "trim": "xDrive40i",\n  "resolution": "default",\n  "format": "png",\n  "colors": ["default", "Blue", "Black", "White", "Silver"]\n}]' },
  { id: 'features', method: 'GET', path: '/api/{brand}/{model}/{year}/{variant}/{trim}/features', title: 'Listar características', desc: 'Devuelve las características de imagen disponibles (sombra, transparencia) para una configuración. Las características marcadas como "not_allowed" no están incluidas en su plan.', params: [{ name: 'brand', type: 'string', desc: 'Nombre de la marca' }, { name: 'model', type: 'string', desc: 'Nombre del modelo' }, { name: 'year', type: 'number', desc: 'Año del modelo' }, { name: 'variant', type: 'string', desc: 'Variante de carrocería' }, { name: 'trim', type: 'string', desc: 'Nivel de acabado' }], query: [{ name: 'format', default: 'png', desc: 'Filtro de formato de imagen' }, { name: 'resolution', default: 'default', desc: 'Filtro de resolución' }], response: '[{\n  "id": "a1b2c3d4e5f6",\n  "brand": "BMW",\n  "model": "X5",\n  "year": 2024,\n  "variant": "SUV",\n  "trim": "xDrive40i",\n  "resolution": "default",\n  "format": "png",\n  "features": {\n    "shadow": true,\n    "transparent": true,\n    "shadow_and_transparent": true\n  }\n}]' },
  { id: 'image', method: 'GET', path: '/api/{brand}/{model}/{year}/{variant}/{trim}/{view}', title: 'Obtener imagen', desc: 'Devuelve una URL de CDN firmada para una imagen de vehículo específica. Este es el endpoint principal para obtener imágenes de vehículos. La URL devuelta es válida por 7 días de forma predeterminada.', params: [{ name: 'brand', type: 'string', desc: 'Nombre de la marca' }, { name: 'model', type: 'string', desc: 'Nombre del modelo' }, { name: 'year', type: 'number', desc: 'Año del modelo' }, { name: 'variant', type: 'string', desc: 'Variante de carrocería' }, { name: 'trim', type: 'string', desc: 'Nivel de acabado' }, { name: 'view', type: 'string', desc: 'Ángulo de cámara (ej. front, front-left, side-left, rear, cockpit)' }], query: [{ name: 'format', default: 'png', desc: 'Formato de imagen (png, webp)' }, { name: 'resolution', default: 'default', desc: 'Resolución de imagen' }, { name: 'color', default: 'default', desc: 'Color del vehículo (ej. Blue, Black, White)' }, { name: 'shadow', default: 'false', desc: 'Incluir sombra de suelo (depende del plan)' }, { name: 'transparency', default: 'false', desc: 'Fondo transparente (depende del plan)' }], response: '[{\n  "id": "a1b2c3d4e5f6",\n  "brand": "BMW",\n  "model": "X5",\n  "year": 2024,\n  "variant": "SUV",\n  "trim": "xDrive40i",\n  "view": "front-left",\n  "resolution": "default",\n  "format": "png",\n  "settings": {\n    "color": "Blue",\n    "shadow": true,\n    "transparency": false,\n    "watermark": false\n  },\n  "image_url": "https://cdn.vehicle.pics/v1/png/default/BMW/X5/...",\n  "errornotes": []\n}]' },
  { id: 'resolutions', method: 'GET', path: '/api/resolutions', title: 'Listar resoluciones', desc: 'Devuelve todas las resoluciones de imagen disponibles. Filtrado según los permisos de su plan.', params: [], query: [], response: '{\n  "resolutions": ["default", "high", "ultra"]\n}' },
  { id: 'formats', method: 'GET', path: '/api/formats', title: 'Listar formatos', desc: 'Devuelve todos los formatos de imagen disponibles. Filtrado según los permisos de su plan.', params: [], query: [], response: '{\n  "formats": ["png", "webp"]\n}' },
  { id: 'getall', method: 'GET', path: '/api/getall', title: 'Obtener todas las configuraciones', desc: 'Devuelve cada configuración de vehículo en la base de datos, expandida por año. Requiere el permiso especial "getall" en su API key. Útil para construir cachés locales o catálogos.', params: [], query: [], response: '[\n  {\n    "brand": "BMW",\n    "model": "X5",\n    "variant": "SUV",\n    "trim": "xDrive40i",\n    "year": 2024,\n    "resolution": "default",\n    "format": "png",\n    "color": "default"\n  },\n  ...\n]' },
];

const errorCodes = [
  { code: '401', description: 'Falta el header x-api-key. Incluya su API key en la solicitud.' },
  { code: '403', description: 'API key inválida, clave expirada, o el recurso solicitado no está permitido por su plan.' },
  { code: '404', description: 'La marca, modelo, año, variante, acabado, vista o color solicitado no fue encontrado.' },
  { code: '400', description: 'Parámetro de solicitud inválido (ej. año no numérico).' },
  { code: '500', description: 'Error interno del servidor. Contacte a soporte si esto persiste.' },
];

const errornotes = [
  { code: 'P11', description: 'Formato o resolución solicitados no permitidos por el plan — se utilizó automáticamente el valor predeterminado de su plan.' },
  { code: 'F04', description: 'Color solicitado no encontrado — se utilizó el color predeterminado.' },
  { code: 'C09', description: 'Color solicitado bloqueado por el plan — se utilizó el color predeterminado.' },
  { code: 'R08', description: 'Resolución solicitada no disponible para este vehículo — se utilizó la resolución permitida más cercana.' },
  { code: 'S05', description: 'Sombra solicitada pero no disponible o no permitida — devuelto sin sombra.' },
  { code: 'S12', description: 'Versión sin sombra no disponible — se devolvió la versión con sombra.' },
  { code: 'T06', description: 'Transparencia solicitada pero no disponible o no permitida — devuelto sin transparencia.' },
  { code: 'T13', description: 'Versión no transparente no disponible — se devolvió la versión transparente.' },
];
---

<BaseLayout
  title="Documentación de la API | Vehicle Imagery"
  description="Referencia completa de la API de Vehicle Imagery. Endpoints, autenticación, parámetros y formatos de respuesta."
  canonicalUrl="/es/documentation"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="px-4 pt-6 pb-10 sm:px-8 lg:px-12">
      <div class="mx-auto max-w-[1400px]">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem]" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="relative flex min-h-[320px] flex-col justify-end px-8 py-10 sm:min-h-[400px] sm:px-16 sm:py-16 lg:min-h-[440px]">
            <p class="text-[11px] font-medium text-white/40 mb-4 uppercase tracking-widest">Referencia de la API v1</p>
            <h1 class="text-5xl font-light tracking-tight text-white sm:text-7xl md:text-8xl">Documentación</h1>
            <p class="mt-4 text-white/60 text-base sm:text-lg max-w-xl leading-relaxed">
              Todo lo que necesita para integrar imágenes de vehículos de calidad de estudio en su aplicación.
            </p>

            <div class="absolute bottom-0 right-6 sm:right-12 lg:right-16">
              <div class="rounded-t-2xl bg-white px-7 py-3.5 shadow-[0_-8px_30px_-12px_rgba(0,0,0,0.1)]">
                <p class="text-[13px] tracking-wide text-black/80">
                  <a href="/es" class="transition-colors hover:text-black">Inicio</a>
                  <span class="mx-2.5 text-black/20">/</span>
                  <span class="font-medium text-black">Documentación</span>
                </p>
              </div>
            </div>

            <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-[25%] -rotate-90 origin-center pointer-events-none select-none" aria-hidden="true">
              <span class="text-[140px] sm:text-[180px] font-extralight tracking-tighter text-transparent" style="-webkit-text-stroke: 1px rgba(255,255,255,0.08);">API</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Navigation + Content -->
    <section class="mx-auto max-w-[1400px] px-6 pb-24 pt-4 sm:px-12 lg:px-16">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-stretch">

        <!-- Sidebar Navigation -->
        <aside class="w-full lg:w-64 shrink-0 order-2 lg:order-1">
          <nav class="lg:sticky lg:top-24 rounded-2xl bg-[#f4f4f5] p-6 border border-black/[0.06] h-fit">
            <h3 class="text-[11px] font-medium text-black/40 uppercase tracking-widest mb-4">Navegación rápida</h3>
            <ul class="space-y-0.5" id="doc-nav">
              <li><a href="#authentication" data-doc-link="authentication" class="doc-nav-link active block py-2.5 px-3 text-[13px] text-black/70 hover:text-black hover:bg-white rounded-lg transition-colors border border-transparent hover:border-black/5">Autenticación</a></li>
              <li><a href="#base-url" data-doc-link="base-url" class="doc-nav-link block py-2.5 px-3 text-[13px] text-black/70 hover:text-black hover:bg-white rounded-lg transition-colors border border-transparent hover:border-black/5">Base URL</a></li>
              <li><a href="#query-params" data-doc-link="query-params" class="doc-nav-link block py-2.5 px-3 text-[13px] text-black/70 hover:text-black hover:bg-white rounded-lg transition-colors border border-transparent hover:border-black/5">Parámetros globales</a></li>
              <li><a href="#hierarchy" data-doc-link="hierarchy" class="doc-nav-link block py-2.5 px-3 text-[13px] text-black/70 hover:text-black hover:bg-white rounded-lg transition-colors border border-transparent hover:border-black/5">Jerarquía de la API</a></li>
              <li class="pt-4 mt-2 border-t border-black/5">
                <span class="block py-2 px-3 text-[10px] font-medium text-black/40 uppercase tracking-widest">Endpoints</span>
              </li>
              {endpoints.map((ep) => (
                <li>
                  <a href={`#${ep.id}`} data-doc-link={ep.id} class="doc-nav-link group flex items-center gap-2.5 py-2.5 px-3 text-[13px] text-black/70 hover:text-black hover:bg-white rounded-lg transition-colors border border-transparent hover:border-black/5">
                    <span class="text-[9px] font-bold text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded font-mono shrink-0">{ep.method}</span>
                    <span class="truncate">{ep.title}</span>
                  </a>
                </li>
              ))}
              <li class="pt-4 mt-2 border-t border-black/5">
                <span class="block py-2 px-3 text-[10px] font-medium text-black/40 uppercase tracking-widest">Referencia</span>
              </li>
              <li><a href="#errors" data-doc-link="errors" class="doc-nav-link block py-2.5 px-3 text-[13px] text-black/70 hover:text-black hover:bg-white rounded-lg transition-colors border border-transparent hover:border-black/5">Códigos de error</a></li>
              <li><a href="#errornotes" data-doc-link="errornotes" class="doc-nav-link block py-2.5 px-3 text-[13px] text-black/70 hover:text-black hover:bg-white rounded-lg transition-colors border border-transparent hover:border-black/5">Notas de error</a></li>
              <li><a href="#rate-limits" data-doc-link="rate-limits" class="doc-nav-link block py-2.5 px-3 text-[13px] text-black/70 hover:text-black hover:bg-white rounded-lg transition-colors border border-transparent hover:border-black/5">Límites de solicitudes</a></li>
            </ul>
          </nav>
        </aside>

        <!-- Main Content -->
        <div id="doc-content" class="flex-1 min-w-0 max-w-3xl order-1 lg:order-2">
          <style is:global>
            #doc-content .doc-section { display: none; }
            #doc-content .doc-section.active { display: block; }
            .doc-nav-link.active { background: white !important; border-color: rgba(0,0,0,0.1) !important; color: black !important; font-weight: 500; }
          </style>

          <!-- Authentication -->
          <section id="authentication" data-doc-section="authentication" class="doc-section active mb-20 scroll-mt-24">
            <p class="text-[11px] font-medium text-black/50 mb-4">/ autenticación /</p>
            <h2 class="text-3xl sm:text-4xl font-normal leading-[1.1] text-black tracking-tight mb-6">
              Autenticación con API Key
            </h2>
            <p class="text-[14px] text-black/60 leading-relaxed mb-8">
              Todas las solicitudes a la API requieren una API key enviada a través del header <code class="text-[13px] bg-[#f4f4f5] px-2 py-1 rounded text-black font-mono">x-api-key</code>. Puede obtener su clave a través de nuestro panel de control o contactando al equipo de ventas.
            </p>
            <div class="rounded-xl bg-[#1e1e1e] overflow-hidden">
              <div class="flex items-center px-5 py-3 bg-[#252526] border-b border-white/5">
                <div class="flex space-x-1.5 mr-3">
                  <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
                </div>
                <span class="text-[11px] text-white/40 font-mono">curl</span>
              </div>
              <pre class="p-5 text-[13px] text-gray-300 font-mono leading-relaxed overflow-x-auto whitespace-pre"><code>curl -H "x-api-key: YOUR_API_KEY" \
  {BASE_URL}/api/brands</code></pre>
            </div>
            <div class="mt-6 p-4 border border-amber-200 bg-amber-50 rounded-xl">
              <p class="text-[13px] text-amber-900 leading-relaxed">
                <strong>Mantenga su API key en secreto.</strong> Nunca la exponga en código del lado del cliente. Use solicitudes del lado del servidor o un proxy para mantener su clave segura.
              </p>
            </div>
          </section>

          <!-- Base URL -->
          <section id="base-url" data-doc-section="base-url" class="doc-section mb-20 scroll-mt-24">
            <p class="text-[11px] font-medium text-black/50 mb-4">/ base url /</p>
            <h2 class="text-3xl sm:text-4xl font-normal leading-[1.1] text-black tracking-tight mb-6">
              Base URL
            </h2>
            <p class="text-[14px] text-black/60 leading-relaxed mb-6">
              Todos los endpoints de la API se acceden en relación con la siguiente base URL:
            </p>
            <div class="rounded-xl bg-[#f4f4f5] p-5 flex items-center gap-3">
              <code class="text-[15px] font-mono text-black font-medium">{BASE_URL}</code>
            </div>
            <p class="mt-4 text-[13px] text-black/50 leading-relaxed">
              Todas las respuestas se devuelven como JSON con <code class="text-[12px] bg-[#f4f4f5] px-1.5 py-0.5 rounded text-black font-mono">Content-Type: application/json</code>. CORS está habilitado para todos los orígenes.
            </p>
          </section>

          <!-- Global Query Parameters -->
          <section id="query-params" data-doc-section="query-params" class="doc-section mb-20 scroll-mt-24">
            <p class="text-[11px] font-medium text-black/50 mb-4">/ parámetros /</p>
            <h2 class="text-3xl sm:text-4xl font-normal leading-[1.1] text-black tracking-tight mb-6">
              Parámetros de consulta globales
            </h2>
            <p class="text-[14px] text-black/60 leading-relaxed mb-8">
              Estos parámetros se pueden agregar a la mayoría de los endpoints para filtrar resultados.
            </p>
            <div class="border border-black/10 rounded-xl overflow-hidden">
              <table class="w-full text-left">
                <thead>
                  <tr class="bg-[#f4f4f5]">
                    <th class="px-5 py-3 text-[11px] font-medium text-black/50 uppercase tracking-wider">Parámetro</th>
                    <th class="px-5 py-3 text-[11px] font-medium text-black/50 uppercase tracking-wider">Predeterminado</th>
                    <th class="px-5 py-3 text-[11px] font-medium text-black/50 uppercase tracking-wider">Descripción</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-black/5">
                  <tr>
                    <td class="px-5 py-3.5"><code class="text-[12px] font-mono text-black bg-[#f4f4f5] px-1.5 py-0.5 rounded">format</code></td>
                    <td class="px-5 py-3.5 text-[13px] text-black/50">png</td>
                    <td class="px-5 py-3.5 text-[13px] text-black/60">Formato de imagen. Las opciones disponibles dependen de su plan.</td>
                  </tr>
                  <tr>
                    <td class="px-5 py-3.5"><code class="text-[12px] font-mono text-black bg-[#f4f4f5] px-1.5 py-0.5 rounded">resolution</code></td>
                    <td class="px-5 py-3.5 text-[13px] text-black/50">default</td>
                    <td class="px-5 py-3.5 text-[13px] text-black/60">Resolución de imagen. Las resoluciones más altas pueden requerir un plan de nivel superior.</td>
                  </tr>
                  <tr>
                    <td class="px-5 py-3.5"><code class="text-[12px] font-mono text-black bg-[#f4f4f5] px-1.5 py-0.5 rounded">color</code></td>
                    <td class="px-5 py-3.5 text-[13px] text-black/50">default</td>
                    <td class="px-5 py-3.5 text-[13px] text-black/60">Color del vehículo. Solo se utiliza en el endpoint de imagen.</td>
                  </tr>
                  <tr>
                    <td class="px-5 py-3.5"><code class="text-[12px] font-mono text-black bg-[#f4f4f5] px-1.5 py-0.5 rounded">shadow</code></td>
                    <td class="px-5 py-3.5 text-[13px] text-black/50">false</td>
                    <td class="px-5 py-3.5 text-[13px] text-black/60">Agregar sombra de suelo a la imagen. Requiere permiso del plan.</td>
                  </tr>
                  <tr>
                    <td class="px-5 py-3.5"><code class="text-[12px] font-mono text-black bg-[#f4f4f5] px-1.5 py-0.5 rounded">transparency</code></td>
                    <td class="px-5 py-3.5 text-[13px] text-black/50">false</td>
                    <td class="px-5 py-3.5 text-[13px] text-black/60">Devolver imagen con fondo transparente. Requiere permiso del plan.</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <!-- API Hierarchy -->
          <section id="hierarchy" data-doc-section="hierarchy" class="doc-section mb-20 scroll-mt-24">
            <p class="text-[11px] font-medium text-black/50 mb-4">/ modelo de datos /</p>
            <h2 class="text-3xl sm:text-4xl font-normal leading-[1.1] text-black tracking-tight mb-6">
              Jerarquía de la API
            </h2>
            <p class="text-[14px] text-black/60 leading-relaxed mb-8">
              La API de Vehicle Imagery sigue una estructura jerárquica. Navegue paso a paso desde la marca hasta la imagen:
            </p>
            <div class="flex flex-wrap gap-2 items-center text-[13px] font-mono">
              {['Marcas', 'Modelos', 'Años', 'Variantes', 'Acabados', 'Vistas / Colores / Características', 'Imagen'].map((step, i) => (
                <>
                  <span class="bg-[#f4f4f5] text-black px-3 py-1.5 rounded-lg">{step}</span>
                  {i < 6 && <span class="text-black/30">→</span>}
                </>
              ))}
            </div>
          </section>

          <!-- Endpoints -->
          {endpoints.map((ep) => (
            <section id={ep.id} data-doc-section={ep.id} class="doc-section mb-16 scroll-mt-24 pb-16 border-b border-black/5 last:border-b-0">
              <div class="flex flex-wrap items-center gap-3 mb-4">
                <span class="text-[11px] font-bold text-emerald-700 bg-emerald-50 px-2.5 py-1 rounded-md font-mono tracking-wider">{ep.method}</span>
                <code class="text-[14px] font-mono text-black break-all">{ep.path}</code>
              </div>
              <h3 class="text-2xl font-normal text-black tracking-tight mb-3">{ep.title}</h3>
              <p class="text-[14px] text-black/60 leading-relaxed mb-8">{ep.desc}</p>

              {ep.params.length > 0 && (
                <div class="mb-8">
                  <h4 class="text-[11px] font-medium text-black/40 uppercase tracking-widest mb-3">Parámetros de ruta</h4>
                  <div class="space-y-2">
                    {ep.params.map((p) => (
                      <div class="flex items-start gap-3 py-2.5 px-4 bg-[#f4f4f5] rounded-lg">
                        <code class="text-[12px] font-mono text-black shrink-0 mt-0.5">{p.name}</code>
                        <span class="text-[11px] text-black/40 font-mono shrink-0 mt-0.5">{p.type}</span>
                        <span class="text-[13px] text-black/60">{p.desc}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {ep.query.length > 0 && (
                <div class="mb-8">
                  <h4 class="text-[11px] font-medium text-black/40 uppercase tracking-widest mb-3">Parámetros de consulta</h4>
                  <div class="space-y-2">
                    {ep.query.map((q) => (
                      <div class="flex items-start gap-3 py-2.5 px-4 bg-[#f4f4f5] rounded-lg">
                        <code class="text-[12px] font-mono text-black shrink-0 mt-0.5">{q.name}</code>
                        <span class="text-[11px] text-black/30 font-mono shrink-0 mt-0.5">= {q.default}</span>
                        <span class="text-[13px] text-black/60">{q.desc}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              <div>
                <h4 class="text-[11px] font-medium text-black/40 uppercase tracking-widest mb-3">Respuesta de ejemplo</h4>
                <div class="rounded-xl bg-[#1e1e1e] overflow-hidden">
                  <div class="flex items-center px-5 py-3 bg-[#252526] border-b border-white/5">
                    <div class="flex space-x-1.5 mr-3">
                      <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
                      <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
                      <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
                    </div>
                    <span class="text-[11px] text-white/40 font-mono">response.json</span>
                  </div>
                  <pre class="p-5 text-[13px] text-gray-300 font-mono leading-relaxed overflow-x-auto whitespace-pre"><code>{ep.response}</code></pre>
                </div>
              </div>
            </section>
          ))}

          <!-- Error Codes -->
          <section id="errors" data-doc-section="errors" class="doc-section mb-20 scroll-mt-24">
            <p class="text-[11px] font-medium text-black/50 mb-4">/ referencia /</p>
            <h2 class="text-3xl sm:text-4xl font-normal leading-[1.1] text-black tracking-tight mb-6">
              Códigos de estado HTTP
            </h2>
            <p class="text-[14px] text-black/60 leading-relaxed mb-8">
              La API utiliza códigos de estado HTTP estándar. Cada respuesta de error incluye un cuerpo JSON con un campo <code class="text-[12px] bg-[#f4f4f5] px-1.5 py-0.5 rounded text-black font-mono">error</code> que describe el problema.
            </p>
            <div class="border border-black/10 rounded-xl overflow-hidden">
              <table class="w-full text-left">
                <thead>
                  <tr class="bg-[#f4f4f5]">
                    <th class="px-5 py-3 text-[11px] font-medium text-black/50 uppercase tracking-wider w-24">Código</th>
                    <th class="px-5 py-3 text-[11px] font-medium text-black/50 uppercase tracking-wider">Descripción</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-black/5">
                  {errorCodes.map((ec) => (
                    <tr>
                      <td class="px-5 py-3.5"><code class="text-[13px] font-mono font-bold text-black">{ec.code}</code></td>
                      <td class="px-5 py-3.5 text-[13px] text-black/60">{ec.description}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <!-- Error Notes -->
          <section id="errornotes" data-doc-section="errornotes" class="doc-section mb-20 scroll-mt-24">
            <h2 class="text-3xl sm:text-4xl font-normal leading-[1.1] text-black tracking-tight mb-6">
              Notas de error (Códigos de respaldo)
            </h2>
            <p class="text-[14px] text-black/60 leading-relaxed mb-8">
              Cuando la API no puede cumplir su solicitud exacta pero encuentra un respaldo adecuado, devuelve la imagen junto con un array <code class="text-[12px] bg-[#f4f4f5] px-1.5 py-0.5 rounded text-black font-mono">errornotes</code> que explica lo que se cambió. Esto solo aplica cuando los respaldos están habilitados en su plan.
            </p>
            <div class="border border-black/10 rounded-xl overflow-hidden">
              <table class="w-full text-left">
                <thead>
                  <tr class="bg-[#f4f4f5]">
                    <th class="px-5 py-3 text-[11px] font-medium text-black/50 uppercase tracking-wider w-24">Código</th>
                    <th class="px-5 py-3 text-[11px] font-medium text-black/50 uppercase tracking-wider">Descripción</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-black/5">
                  {errornotes.map((en) => (
                    <tr>
                      <td class="px-5 py-3.5"><code class="text-[13px] font-mono font-bold text-amber-700 bg-amber-50 px-2 py-0.5 rounded">{en.code}</code></td>
                      <td class="px-5 py-3.5 text-[13px] text-black/60">{en.description}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <!-- Rate Limits -->
          <section id="rate-limits" data-doc-section="rate-limits" class="doc-section mb-20 scroll-mt-24">
            <h2 class="text-3xl sm:text-4xl font-normal leading-[1.1] text-black tracking-tight mb-6">
              Límites de solicitudes y caché
            </h2>
            <p class="text-[14px] text-black/60 leading-relaxed mb-8">
              Los límites de solicitudes dependen de su plan. Todas las URLs de imágenes se sirven a través de un CDN global y están firmadas con un token de tiempo limitado (7 días por defecto). Almacene estas URLs en caché para un rendimiento óptimo.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="p-6 bg-[#f4f4f5] rounded-xl">
                <p class="text-2xl font-normal text-black mb-1">{stats.latency}</p>
                <p class="text-[12px] text-black/50 uppercase tracking-wider">Latencia prom.</p>
              </div>
              <div class="p-6 bg-[#f4f4f5] rounded-xl">
                <p class="text-2xl font-normal text-black mb-1">{stats.uptime}</p>
                <p class="text-[12px] text-black/50 uppercase tracking-wider">SLA de disponibilidad</p>
              </div>
              <div class="p-6 bg-[#f4f4f5] rounded-xl">
                <p class="text-2xl font-normal text-black mb-1">{stats.signedUrlExpiry}</p>
                <p class="text-[12px] text-black/50 uppercase tracking-wider">Expiración de URL</p>
              </div>
            </div>
          </section>

          <!-- CTA -->
          <section class="rounded-2xl p-8 sm:p-12 text-center" style="background-color: rgb(10, 43, 49);">
            <h2 class="text-2xl sm:text-3xl font-normal text-white tracking-tight mb-3">¿Listo para comenzar?</h2>
            <p class="text-[14px] text-white/60 mb-8 max-w-md mx-auto leading-relaxed">
              Obtenga su API key y comience a integrar imágenes de vehículos de calidad de estudio hoy.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/es/contact" class="inline-flex items-center justify-center rounded-full bg-white px-7 py-3.5 text-[13px] font-medium text-black transition-colors hover:bg-[rgb(200,90,70)] hover:text-white">
                Obtener API Key
              </a>
              <a href="/es/contact" class="inline-flex items-center justify-center rounded-full border border-white/20 px-7 py-3.5 text-[13px] font-medium text-white transition-colors hover:bg-white/10">
                Contactar ventas
              </a>
            </div>
          </section>

        </div>
      </div>
    </section>

    <script>
      function showDocSection(id, updateHash) {
        const sections = document.querySelectorAll('.doc-section');
        const links = document.querySelectorAll('.doc-nav-link');
        sections.forEach((el) => {
          el.classList.toggle('active', el.dataset.docSection === id);
        });
        links.forEach((a) => {
          a.classList.toggle('active', a.dataset.docLink === id);
        });
        if (updateHash) history.replaceState(null, '', '#' + id);
      }

      function initDocNav() {
        const validIds = ['authentication', 'base-url', 'query-params', 'hierarchy', 'errors', 'errornotes', 'rate-limits', ...['brands','models','years','variants','trims','views','colors','features','image','resolutions','formats','getall']];
        const rawHash = location.hash ? location.hash.slice(1) : '';
        const hasExplicitHash = rawHash && validIds.includes(rawHash);
        const id = hasExplicitHash ? rawHash : 'authentication';
        showDocSection(id, hasExplicitHash);

        if (!hasExplicitHash) {
          window.scrollTo(0, 0);
        }

        document.querySelectorAll('.doc-nav-link').forEach((a) => {
          a.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = a.dataset.docLink;
            if (targetId) showDocSection(targetId, true);
          });
        });

        window.addEventListener('hashchange', () => {
          const h = location.hash ? location.hash.slice(1) : '';
          if (validIds.includes(h)) showDocSection(h, true);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initDocNav);
      } else {
        initDocNav();
      }
    </script>
  </main>
  <Footer />
</BaseLayout>
