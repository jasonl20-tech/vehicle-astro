---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getEntries, getSiteStats, getCompanyInfo } from '../../lib/contentful';
import { richTextToPlainText } from '../../lib/contentful-rich-text';

const mediaAssets = [
  { title: 'Logo (claro)', desc: 'Logo principal en formato vectorial. Usar sobre fondos claros.', file: '/logo.svg', type: 'SVG', bg: 'light' },
  { title: 'Logo (oscuro)', desc: 'Logo invertido para fondos oscuros. Versión en blanco.', file: '/logo.svg', type: 'SVG', bg: 'dark' },
  { title: 'Flota de vehículos', desc: 'Vista general de la flota con múltiples vehículos. Usar para imágenes editoriales y destacadas.', file: '/images/footer_vehicles.webp', type: 'WebP', bg: 'light' },
];

type PressRelease = { title: string; shortText: string; date: string; excerpt: string; link: string };
let pressReleases: PressRelease[] = [];
try {
  const res = await getEntries({ content_type: 'titleComponent', order: '-fields.date', limit: 20 });
  pressReleases = (res.items || []).map((item: { fields?: { title?: string; shortText?: string; date?: string; excerpt?: unknown; link?: string } }) => ({
    title: item.fields?.title ?? '',
    shortText: item.fields?.shortText ?? '',
    date: item.fields?.date ?? '',
    excerpt: item.fields?.excerpt
      ? richTextToPlainText(item.fields.excerpt as import('@contentful/rich-text-types').Document, 300)
      : '',
    link: item.fields?.link ?? '',
  }));
} catch {
  pressReleases = [];
}

const stats = await getSiteStats();
const company = await getCompanyInfo();

const facts = [
  { label: 'Fundación', value: company.founded },
  { label: 'Sede', value: company.headquarters },
  { label: 'Industria', value: company.industry },
  { label: 'Producto', value: company.productName },
];
---

<BaseLayout
  title="Prensa y kit de medios | Vehicle Imagery API"
  description="Recursos de prensa, kit de medios y activos de marca de Vehicle Imagery. Logos, capturas de pantalla y comunicados de prensa."
  canonicalUrl="/es/press"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 pt-24 pb-8 sm:px-12 lg:px-16">
      <div class="max-w-3xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Prensa y medios</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-[0.95] text-black tracking-tight mb-8">
          Kit de prensa
        </h1>
        <p class="text-[16px] text-black/50 leading-relaxed max-w-lg">
          Todo lo que necesitas para escribir sobre Vehicle Imagery. Logos, imágenes de producto, datos de la empresa y comunicados de prensa.
        </p>
      </div>
    </section>

    <!-- Company Facts -->
    <section class="mx-auto max-w-[1400px] px-6 pt-16 pb-24 sm:px-12 lg:px-16">
      <div class="grid gap-16 lg:grid-cols-[1fr_1.5fr] lg:gap-24 items-start">
        <div>
          <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-black/30 mb-6">Acerca de</p>
          <h2 class="text-3xl sm:text-4xl font-light leading-[1.05] text-black tracking-tight mb-6">
            Descripción de la empresa
          </h2>
        </div>
        <div>
          <p class="text-[15px] text-black/60 leading-[1.8] mb-10">
            Vehicle Imagery es una API orientada al desarrollador que ofrece imágenes de vehículos con calidad de estudio para la industria automotriz. Diseñada para concesionarios, plataformas de leasing y marketplaces automotrices, la API proporciona acceso instantáneo a imágenes de alta resolución de más de {stats.brands} marcas — servidas a través de un CDN global con tiempos de respuesta promedio inferiores a {stats.latency}.
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
            {facts.map((fact) => (
              <div class="border-t border-black/[0.06] pt-4">
                <p class="text-[10px] text-black/35 uppercase tracking-[0.15em] mb-2">{fact.label}</p>
                <p class="text-[15px] font-medium text-black">{fact.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Brand Assets / Media Kit -->
    <section class="py-24 sm:py-32 bg-[#fafafa]">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-16">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Recursos de marca</p>
            <h2 class="text-3xl sm:text-4xl font-light leading-[1.05] text-black tracking-tight">
              Logos e imágenes
            </h2>
          </div>
          <p class="text-[13px] text-black/40 max-w-sm leading-relaxed">
            Por favor, no modifiques, distorsiones ni recolorees nuestros logos. Úsalos tal como se proporcionan.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {mediaAssets.map((asset) => (
            <div class="group rounded-lg overflow-hidden border border-black/[0.06] bg-white transition-all duration-500 hover:shadow-xl hover:shadow-black/5 hover:border-black/10">
              <div class={`relative h-52 flex items-center justify-center overflow-hidden ${asset.bg === 'dark' ? 'bg-[rgb(10,43,49)]' : 'bg-[#ebebeb]'}`}>
                <img
                  src={asset.file}
                  alt={asset.title}
                  class={`max-h-20 max-w-[70%] object-contain transition-transform duration-500 group-hover:scale-110 ${asset.bg === 'dark' ? 'brightness-0 invert' : ''}`}
                  loading="lazy"
                />
                <div class="absolute top-4 right-4">
                  <span class="text-[9px] font-bold uppercase tracking-widest text-black/30 bg-white/90 backdrop-blur-sm px-2.5 py-1 rounded">{asset.type}</span>
                </div>
              </div>
              <div class="p-6 flex items-center justify-between gap-4">
                <div>
                  <h3 class="text-[14px] font-medium text-black">{asset.title}</h3>
                  <p class="text-[11px] text-black/40 mt-0.5">{asset.desc}</p>
                </div>
                <a href={asset.file} download class="shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-black/[0.04] hover:bg-[rgb(200,90,70)] hover:text-white text-black/40 transition-all duration-300">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v12m0 0l-4-4m4 4l4-4M4 18h16"></path>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Brand Guidelines -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="grid gap-16 lg:grid-cols-[1fr_1.5fr] lg:gap-24 items-start">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-black/30 mb-6">Marca</p>
            <h2 class="text-3xl sm:text-4xl font-light leading-[1.05] text-black tracking-tight">
              Directrices
            </h2>
          </div>
          <div>
            <div class="space-y-8">
              <!-- Colors -->
              <div>
                <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-black/30 mb-4">Colores de marca</p>
                <div class="flex flex-wrap gap-4">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl" style="background-color: rgb(10, 43, 49);"></div>
                    <div>
                      <p class="text-[13px] font-medium text-black">Verde azulado oscuro</p>
                      <p class="text-[11px] text-black/40 font-mono">rgb(10, 43, 49)</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl" style="background-color: rgb(200, 90, 70);"></div>
                    <div>
                      <p class="text-[13px] font-medium text-black">Rojo de acento</p>
                      <p class="text-[11px] text-black/40 font-mono">rgb(200, 90, 70)</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl border border-black/10" style="background-color: #ffffff;"></div>
                    <div>
                      <p class="text-[13px] font-medium text-black">Blanco</p>
                      <p class="text-[11px] text-black/40 font-mono">#FFFFFF</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-xl" style="background-color: #f4f4f5;"></div>
                    <div>
                      <p class="text-[13px] font-medium text-black">Gris claro</p>
                      <p class="text-[11px] text-black/40 font-mono">#F4F4F5</p>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Typography -->
              <div class="border-t border-black/[0.06] pt-8">
                <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-black/30 mb-4">Tipografía</p>
                <p class="text-[14px] text-black/60 leading-relaxed">
                  Usamos <strong class="text-black">Arial</strong> (Helvetica Neue, Helvetica) como nuestra tipografía principal en todas las plataformas. Los títulos se establecen en peso ligero y el texto del cuerpo en regular.
                </p>
              </div>
              <!-- Name -->
              <div class="border-t border-black/[0.06] pt-8">
                <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-black/30 mb-4">Nombre de la empresa</p>
                <p class="text-[14px] text-black/60 leading-relaxed">
                  Siempre escríbelo como <strong class="text-black">Vehicle Imagery</strong> (dos palabras, ambas en mayúscula). El producto se denomina <strong class="text-black">Vehicle Imagery API</strong>.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Press Releases -->
    <section class="py-24 sm:py-32 bg-[#fafafa]">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Noticias</p>
        <h2 class="text-3xl sm:text-4xl font-light leading-[1.05] text-black tracking-tight mb-16">
          Comunicados de prensa
        </h2>

        {pressReleases.length > 0 ? (
          <div class="space-y-0">
            {pressReleases.map((pr) => {
              const d = pr.date && pr.date.length > 4 ? new Date(pr.date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' }) : pr.date;
              return (
                <div class="group flex flex-col sm:flex-row gap-6 sm:gap-12 py-10 border-b border-black/[0.06] first:border-t">
                  <span class="text-[12px] font-mono text-black/25 shrink-0 pt-1 min-w-[100px]">{d}</span>
                  <div>
                    <h3 class="text-[17px] font-medium text-black mb-2 group-hover:text-[rgb(200,90,70)] transition-colors leading-snug">
                      {pr.link ? <a href={pr.link} target="_blank" rel="noopener noreferrer">{pr.title}</a> : pr.title}
                    </h3>
                    {pr.shortText && <p class="text-[14px] text-black/70 mb-2">{pr.shortText}</p>}
                    {pr.excerpt && <p class="text-[13px] text-black/45 leading-relaxed max-w-2xl">{pr.excerpt}</p>}
                    {pr.link && (
                      <a href={pr.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-[12px] font-medium text-[rgb(200,90,70)] mt-3 hover:underline">
                        Leer más
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                      </a>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <p class="text-[14px] text-black/40">Aún no hay comunicados de prensa. Vuelve pronto.</p>
        )}
      </div>
    </section>

    <!-- Contact for Press -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] px-8 py-20 sm:px-16 sm:py-24" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full opacity-[0.04] pointer-events-none" style="background: radial-gradient(circle, white 0%, transparent 60%);" aria-hidden="true"></div>

          <div class="relative z-10 grid gap-12 lg:grid-cols-[1fr_1fr] lg:gap-20 items-start">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Contacto de prensa</p>
              <h2 class="text-4xl sm:text-5xl font-light tracking-tight text-white leading-[1.05] mb-6">
                Ponte en contacto
              </h2>
              <p class="text-[14px] text-white/40 leading-relaxed mb-10 max-w-sm">
                Para consultas de prensa, entrevistas o materiales adicionales, contacta con nuestro equipo de medios.
              </p>
              <div class="space-y-4">
                <div>
                  <p class="text-[11px] text-white/25 uppercase tracking-wider mb-1">Correo electrónico</p>
                  <a href={`mailto:${company.emailPress}`} class="text-[14px] text-white/70 hover:text-white transition-colors">{company.emailPress}</a>
                </div>
                <div>
                  <p class="text-[11px] text-white/25 uppercase tracking-wider mb-1">General</p>
                  <a href={`mailto:${company.emailInfo}`} class="text-[14px] text-white/70 hover:text-white transition-colors">{company.emailInfo}</a>
                </div>
              </div>
            </div>

            <div id="press-form-wrapper" class="transition-all duration-700 ease-out">
              <div id="press-form-content">
                <form id="press-form" class="space-y-5">
                  <input type="hidden" name="subject" value="Consulta de prensa – Vehicle Imagery" />

                  <div>
                    <input type="text" name="name" required placeholder="Tu nombre" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <input type="email" name="email" required placeholder="Correo electrónico" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <input type="text" name="publication" placeholder="Publicación / medio" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <textarea name="message" rows="2" placeholder="¿Cómo podemos ayudarte?" class="w-full resize-none border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors"></textarea>
                  </div>

                  <div class="pt-4">
                    <button type="submit" id="press-submit-btn" class="group/btn inline-flex items-center justify-center rounded-full px-8 py-4 text-[13px] font-medium transition-all duration-300 bg-white text-black hover:bg-[rgb(200,90,70)] hover:text-white">
                      <span>Enviar consulta</span>
                      <svg class="w-4 h-4 ml-2 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                      </svg>
                    </button>
                  </div>
                </form>
              </div>

              <div id="press-success" class="hidden flex-col items-center justify-center text-center py-12">
                <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-white/20">
                  <svg class="h-10 w-10" viewBox="0 0 52 52" fill="none">
                    <circle cx="26" cy="26" r="24" stroke="white" stroke-width="2.5" fill="none" stroke-dasharray="150.8" stroke-dashoffset="150.8" class="press-circle" />
                    <path d="M15 27L23 35L37 19" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" stroke-dasharray="40" stroke-dashoffset="40" class="press-check" />
                  </svg>
                </div>
                <h3 class="text-2xl font-normal text-white mb-3">¡Consulta enviada!</h3>
                <p class="text-[14px] text-white/70 max-w-xs leading-relaxed">Te responderemos pronto.</p>
              </div>
            </div>

            <style>
              @keyframes press-draw-circle { to { stroke-dashoffset: 0; } }
              @keyframes press-draw-check { to { stroke-dashoffset: 0; } }
              #press-form-wrapper.success .press-circle { animation: press-draw-circle 0.6s ease-out 0.2s forwards; }
              #press-form-wrapper.success .press-check { animation: press-draw-check 0.4s ease-out 0.7s forwards; }
            </style>

            <script>
              (function() {
                const form = document.getElementById('press-form');
                const wrapper = document.getElementById('press-form-wrapper');
                const formContent = document.getElementById('press-form-content');
                const successEl = document.getElementById('press-success');
                form.addEventListener('submit', (e) => {
                  e.preventDefault();
                  const data = Object.fromEntries(new FormData(form).entries());
                  fetch('/api/submit', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify(data) }).catch(() => {});
                  formContent.style.opacity = '0'; formContent.style.transform = 'scale(0.95)'; formContent.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                  setTimeout(() => { formContent.classList.add('hidden'); wrapper.classList.add('success'); successEl.classList.remove('hidden'); successEl.classList.add('flex'); successEl.style.opacity = '0'; successEl.style.transform = 'scale(0.95)'; requestAnimationFrame(() => { successEl.style.transition = 'opacity 0.5s ease 0.1s, transform 0.5s ease 0.1s'; successEl.style.opacity = '1'; successEl.style.transform = 'scale(1)'; }); }, 300);
                });
              })();
            </script>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
