---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getSiteStats } from '../../../lib/contentful';

const stats = await getSiteStats();
const vehicleTypes = [
  {
    title: 'Sedanes y berlinas',
    desc: 'Desde sedanes compactos urbanos hasta berlinas de lujo de tamaño completo. Cada acabado, cada color, cada ángulo.',
    count: stats.sedans,
    examples: 'BMW 3 Series, Mercedes C-Class, Audi A4, Toyota Camry, Honda Civic',
  },
  {
    title: 'SUVs y crossovers',
    desc: 'Desde crossovers compactos hasta SUVs de lujo de gran tamaño. El segmento de mayor crecimiento con la cobertura más completa.',
    count: stats.suvs,
    examples: 'BMW X5, Range Rover, Porsche Cayenne, Toyota RAV4, Volkswagen Tiguan',
  },
  {
    title: 'Deportivos y superdeportivos',
    desc: 'Vehículos de alto rendimiento desde cada ángulo — detalles aerodinámicos, alerones y difusores renderizados con precisión.',
    count: stats.sportsCars,
    examples: 'Ferrari 296 GTB, Porsche 911, Lamborghini Huracán, McLaren 750S, Aston Martin Vantage',
  },
  {
    title: 'Hatchbacks y familiares',
    desc: 'Favoritos europeos y vehículos prácticos del día a día. Variantes Estate, Avant, Touring y Sportback incluidas.',
    count: stats.hatchbacks,
    examples: 'Volkswagen Golf, BMW 3 Series Touring, Audi A4 Avant, Ford Focus, Peugeot 308',
  },
  {
    title: 'Coupés y descapotables',
    desc: 'Coupés de dos puertas, cabriolets y roadsters. Configuraciones con capota abierta y cerrada cuando están disponibles.',
    count: stats.coupes,
    examples: 'BMW 4 Series, Mercedes E-Class Coupé, Porsche 718 Boxster, Audi TT, Ford Mustang',
  },
  {
    title: 'Camionetas pickup',
    desc: 'Camionetas de tamaño completo y mediano. Configuraciones de cabina simple, cabina doble y chasis cabina.',
    count: stats.trucks,
    examples: 'Ford F-150, RAM 1500, Chevrolet Silverado, Toyota Hilux, GMC Sierra',
  },
  {
    title: 'Furgonetas y monovolúmenes',
    desc: 'Furgonetas comerciales, de pasajeros y vehículos multiusos. Variantes de furgón de carga y furgón de tripulación.',
    count: stats.vans,
    examples: 'Mercedes Sprinter, Ford Transit, Volkswagen Transporter, Peugeot Expert, Renault Master',
  },
  {
    title: 'Vehículos eléctricos',
    desc: 'Plataformas EV dedicadas y variantes eléctricas. Detalles de configuración de batería y posición del puerto de carga incluidos.',
    count: stats.electric,
    examples: 'Tesla Model 3, Porsche Taycan, BMW iX, Mercedes EQS, Hyundai Ioniq 5',
  },
];
---

<BaseLayout
  title="Tipos de vehículos | Vehicle Imagery API"
  description="Cobertura completa de imágenes para cada segmento de vehículo — sedanes, SUVs, deportivos, camionetas, furgonetas y vehículos eléctricos."
  canonicalUrl="/es/coverage/vehicle-types"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 pt-24 pb-8 sm:px-12 lg:px-16">
      <div class="max-w-3xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Tipos de vehículos</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-[0.95] text-black tracking-tight mb-8">
          Cada segmento.<br />Cada carrocería.
        </h1>
        <p class="text-[16px] text-black/50 leading-relaxed max-w-lg">
          Desde hatchbacks compactos hasta SUVs de gran tamaño, superdeportivos hasta furgonetas comerciales — imágenes con calidad de estudio para cada categoría de vehículo.
        </p>
      </div>
    </section>

    <!-- Stats -->
    <section class="mx-auto max-w-[1400px] px-6 pb-16 sm:px-12 lg:px-16">
      <div class="flex gap-12 sm:gap-16 border-t border-black/5 pt-8">
        {[
          { value: stats.segments, label: 'Segmentos' },
          { value: stats.configurations, label: 'Configuraciones' },
          { value: stats.viewsPerConfig, label: 'Vistas por config.' },
          { value: stats.newAdditions, label: 'Nuevas adiciones' },
        ].map((stat) => (
          <div>
            <p class="text-2xl sm:text-3xl font-light text-black tracking-tight">{stat.value}</p>
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/25 mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Vehicle Types -->
    <section class="mx-auto max-w-[1400px] px-6 pt-16 pb-32 sm:px-12 lg:px-16">
      <div class="space-y-6">
        {vehicleTypes.map((type, idx) => (
          <div class="relative rounded-[2rem] overflow-hidden border border-black/[0.06] bg-white">
            <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-black/10 via-black/5 to-transparent"></div>
            <div class="p-8 sm:p-12">
              <div class="grid lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 items-start">
                <div>
                  <div class="flex items-center gap-4 mb-6">
                    <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/20">{String(idx + 1).padStart(2, '0')}</span>
                    <h2 class="text-3xl sm:text-4xl font-light text-black tracking-tight">{type.title}</h2>
                  </div>
                  <p class="text-[14px] text-black/45 leading-relaxed mb-6">{type.desc}</p>
                  <div class="border-t border-black/5 pt-6">
                    <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/25 mb-2">Modelos populares</p>
                    <p class="text-[13px] text-black/40 leading-relaxed">{type.examples}</p>
                  </div>
                </div>
                <div class="flex items-center justify-end">
                  <div class="flex items-baseline gap-2">
                    <span class="text-5xl sm:text-6xl font-extralight text-black tracking-tight">{type.count}</span>
                    <span class="text-[11px] text-black/30 uppercase tracking-wider">configs</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Data per Vehicle -->
    <section class="py-24 sm:py-32 bg-[#fafafa]">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="grid gap-16 lg:grid-cols-[1fr_1.5fr] lg:gap-24 items-start mb-20">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Por vehículo</p>
            <h2 class="text-4xl sm:text-5xl font-light leading-[1.05] text-black tracking-tight">
              Lo que obtienes<br />por cada configuración
            </h2>
          </div>
          <p class="text-[16px] text-black/50 leading-relaxed max-w-lg self-end">
            Cada configuración de vehículo en nuestra base de datos incluye un conjunto completo de recursos y metadatos, independientemente del segmento.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            { title: 'Vistas exteriores', desc: `Frontal, frontal-izquierdo, lateral, trasero, trasero-izquierdo y cenital. Hasta ${stats.viewsPerConfig} posiciones para cobertura premium.` },
            { title: 'Vistas interiores', desc: 'Cabina, salpicadero, asientos traseros y maletero. Panorámicas de 360° para modelos compatibles.' },
            { title: 'Todos los niveles de acabado', desc: 'Acabados básico, medio y superior. M-Package, AMG-Line, S-Line y variantes deportivas.' },
            { title: 'Múltiples formatos', desc: `PNG y WebP con fondos transparentes opcionales y sombras de suelo. Desde resolución web hasta ${stats.maxResolution}.` },
            { title: 'Metadatos del vehículo', desc: 'Datos de marca, modelo, año, variante, acabado y color incluidos en cada respuesta de la API.' },
          ].map((item) => (
            <div class="relative rounded-[2rem] overflow-hidden border border-black/[0.06] bg-white p-10 sm:p-12">
              <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-black/10 via-black/5 to-transparent"></div>
              <h3 class="text-[15px] font-bold text-black mb-3">{item.title}</h3>
              <p class="text-[13px] text-black/45 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="pb-24 sm:pb-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] px-8 py-20 sm:px-16 sm:py-24" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full opacity-[0.04] pointer-events-none" style="background: radial-gradient(circle, white 0%, transparent 60%);" aria-hidden="true"></div>
          <div class="relative z-10 text-center max-w-2xl mx-auto">
            <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Explorar</p>
            <h2 class="text-4xl sm:text-5xl font-light tracking-tight text-white leading-[1.05] mb-6">
              Encuentra tu tipo de vehículo
            </h2>
            <p class="text-[14px] text-white/45 leading-relaxed mb-12 max-w-md mx-auto">
              Explora nuestra base de datos completa de marcas o inicia una prueba gratuita para explorar la API con imágenes reales.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/es/trial" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[13px] font-medium text-black transition-all duration-300 hover:bg-[rgb(200,90,70)] hover:text-white">
                Solicitar prueba
              </a>
              <a href="/es/coverage" class="inline-flex items-center justify-center rounded-full border border-white/15 px-8 py-4 text-[13px] font-medium text-white/70 transition-all duration-300 hover:bg-white/10 hover:text-white">
                Explorar marcas
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
