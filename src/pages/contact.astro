---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact | Vehicle Imagery API"
  description="Get in touch with Vehicle Imagery. API keys, sales, and technical support for studio-quality vehicle imagery."
  canonicalUrl="/contact"
>
  <Header />
  <main class="min-h-screen bg-cream">
    <!-- Hero: floating card style -->
    <section class="px-6 pt-8 pb-12 sm:px-12 lg:px-16">
      <div class="mx-auto max-w-7xl">
        <div class="relative overflow-hidden rounded-2xl bg-[#1C2B32] shadow-[0_24px_80px_-24px_rgba(28,43,50,0.5)]">
          <div class="absolute inset-0 bg-gradient-to-br from-[#1C2B32] via-[#25363F] to-[#1C2B32]" aria-hidden="true" />
          <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 50%, rgba(255,136,68,0.15) 0%, transparent 50%);" aria-hidden="true" />
          <div class="relative flex min-h-[220px] flex-col justify-between px-8 py-10 sm:min-h-[260px] sm:px-12 sm:py-14">
            <h1 class="text-4xl font-black tracking-tight text-white sm:text-5xl md:text-6xl">
              Contact
            </h1>
            <p class="absolute bottom-8 right-8 text-sm text-white/50">
              <a href="/" class="hover:text-white/80 transition-colors">Home</a>
              <span class="mx-2">–</span>
              <span>Contact</span>
            </p>
            <p class="absolute right-8 top-1/2 -translate-y-1/2 -rotate-90 origin-center text-2xl font-bold tracking-widest text-white/10 sm:text-3xl" aria-hidden="true">
              Contact
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Two columns: info + form -->
    <section class="mx-auto max-w-7xl px-6 pb-24 pt-6 sm:px-12 lg:px-16">
      <div class="grid gap-12 lg:grid-cols-[1fr_1fr] lg:gap-16">
        <!-- Left: Contact info -->
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#1C2B32]/50">/ get in touch /</p>
          <h2 class="mt-4 text-3xl font-black leading-tight tracking-tight text-[#1C2B32] sm:text-4xl">
            We are always ready to help you
          </h2>
          <p class="mt-6 max-w-lg text-lg leading-relaxed text-[#1C2B32]/75">
            Questions about the API, pricing, or integration? Our team is here for you. Get your API key, request a demo, or reach out for enterprise solutions.
          </p>
          <div class="mt-10 space-y-8">
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-[#1C2B32]/70">Call &amp; Support</h3>
              <p class="mt-2 text-[#1C2B32]"><a href="tel:+18005291337" class="hover:text-accent transition-colors">+1 800 529 1337</a></p>
              <p class="mt-1 text-[#1C2B32]/80">Mon–Fri, 9:00 – 18:00 CET</p>
            </div>
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-[#1C2B32]/70">Email</h3>
              <p class="mt-2"><a href="mailto:hello@vehicleimagery.com" class="text-[#1C2B32] hover:text-accent transition-colors">hello@vehicleimagery.com</a></p>
            </div>
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-[#1C2B32]/70">Social</h3>
              <div class="mt-3 flex gap-4">
                <a href="https://twitter.com/vehicleimagery" target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-lg border border-[#1C2B32]/15 bg-white text-[#1C2B32] transition-colors hover:border-accent hover:bg-accent/10 hover:text-accent" aria-label="Twitter">𝕏</a>
                <a href="https://linkedin.com/company/vehicleimagery" target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-lg border border-[#1C2B32]/15 bg-white text-[#1C2B32] transition-colors hover:border-accent hover:bg-accent/10 hover:text-accent" aria-label="LinkedIn">in</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Get in Touch form card -->
        <div class="rounded-2xl border border-[#1C2B32]/10 bg-[#1C2B32]/[0.03] p-8 shadow-sm sm:p-10">
          <h2 class="text-2xl font-bold text-[#1C2B32]">Get in Touch</h2>
          <p class="mt-3 text-[#1C2B32]/70">
            Tell us about your use case. We’ll get back to you within one business day.
          </p>
          <form
            class="mt-8 space-y-5"
            action="https://submit-form.com/v6dFS1FAS"
            method="POST"
          >
            <input type="hidden" name="subject" value="Contact Form – Vehicle Imagery" />
            <input type="hidden" name="_redirect" value="/contact?sent=1" />
            <div>
              <label for="name" class="sr-only">Full name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Full name"
                class="w-full rounded-lg border border-[#1C2B32]/15 bg-white px-4 py-3.5 text-[#1C2B32] placeholder-[#1C2B32]/50 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              />
            </div>
            <div>
              <label for="email" class="sr-only">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="Email"
                class="w-full rounded-lg border border-[#1C2B32]/15 bg-white px-4 py-3.5 text-[#1C2B32] placeholder-[#1C2B32]/50 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              />
            </div>
            <div>
              <label for="subject" class="sr-only">Subject</label>
              <input
                id="subject"
                name="subject_line"
                type="text"
                placeholder="Subject"
                class="w-full rounded-lg border border-[#1C2B32]/15 bg-white px-4 py-3.5 text-[#1C2B32] placeholder-[#1C2B32]/50 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              />
            </div>
            <div>
              <label for="message" class="sr-only">Message</label>
              <textarea
                id="message"
                name="message"
                rows={5}
                required
                placeholder="Message"
                class="w-full resize-y rounded-lg border border-[#1C2B32]/15 bg-white px-4 py-3.5 text-[#1C2B32] placeholder-[#1C2B32]/50 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              />
            </div>
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-[#1C2B32] px-6 py-4 text-sm font-bold uppercase tracking-widest text-white transition-colors hover:bg-[#25363F] sm:w-auto"
            >
              Send message
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
