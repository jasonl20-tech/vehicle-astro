---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getEntries } from '../../lib/contentful';

let categories: { slug: string; label: string; count: number; desc: string }[] = [];

try {
  const res = await getEntries({ content_type: 'faq', limit: 1000 });
  const items = res.items || [];
  const catMap = new Map<string, number>();

  for (const item of items) {
    const cat = (item as { fields?: { category?: string } }).fields?.category;
    if (cat) {
      const slug = cat.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
      catMap.set(slug, (catMap.get(slug) || 0) + 1);
    }
  }

  const categoryMeta: Record<string, { label: string; desc: string }> = {
    general: { label: 'General', desc: 'Common questions about Vehicle Imagery and our services.' },
    api: { label: 'API', desc: 'Technical questions about endpoints, authentication, and integration.' },
    billing: { label: 'Billing', desc: 'Pricing, invoices, plans, and payment-related questions.' },
    support: { label: 'Support', desc: 'Get help with your account, technical issues, and more.' },
    account: { label: 'Account', desc: 'Account management, settings, and access.' },
    coverage: { label: 'Coverage', desc: 'Available brands, models, and regional support.' },
    integration: { label: 'Integration', desc: 'SDKs, webhooks, and third-party integrations.' },
  };

  categories = Array.from(catMap.entries()).map(([slug, count]) => ({
    slug,
    label: categoryMeta[slug]?.label ?? slug.charAt(0).toUpperCase() + slug.slice(1),
    count,
    desc: categoryMeta[slug]?.desc ?? `Frequently asked questions about ${slug}.`,
  }));

  categories.sort((a, b) => a.label.localeCompare(b.label));
} catch {
  categories = [];
}

const fallbackCategories = [
  { slug: 'general', label: 'General', count: 0, desc: 'Common questions about Vehicle Imagery and our services.' },
  { slug: 'api', label: 'API', count: 0, desc: 'Technical questions about endpoints, authentication, and integration.' },
  { slug: 'billing', label: 'Billing', count: 0, desc: 'Pricing, invoices, plans, and payment-related questions.' },
  { slug: 'support', label: 'Support', count: 0, desc: 'Get help with your account, technical issues, and more.' },
];

const displayCategories = categories.length > 0 ? categories : fallbackCategories;

const categoryIcons: Record<string, string> = {
  general: 'M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z',
  api: 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5',
  billing: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z',
  support: 'M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z',
  account: 'M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z',
  coverage: 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418',
  integration: 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.068-9.068l-1.757 1.757a4.5 4.5 0 00-6.364 6.364l4.5 4.5a4.5 4.5 0 007.244 1.242',
};
---

<BaseLayout
  title="FAQ | Vehicle Imagery API"
  description="Frequently asked questions about Vehicle Imagery API – general, technical, billing, and more."
  canonicalUrl="/faq"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">
    <!-- Hero -->
    <section class="px-4 pt-6 pb-10 sm:px-8 lg:px-12">
      <div class="mx-auto max-w-[1400px]">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] bg-[#1C2B32]">
          <div class="absolute inset-0 bg-gradient-to-br from-[#1C2B32] via-[#25363F] to-[#1C2B32]" aria-hidden="true" />
          <div class="relative flex min-h-[240px] flex-col justify-end px-8 py-10 sm:min-h-[300px] sm:px-16 sm:py-16">
            <h1 class="text-5xl font-light tracking-tight text-white sm:text-7xl">FAQ</h1>
            <div class="absolute bottom-0 right-6 sm:right-12 lg:right-16">
              <div class="rounded-t-2xl bg-white px-7 py-3.5 shadow-[0_-8px_30px_-12px_rgba(0,0,0,0.1)]">
                <p class="text-[13px] tracking-wide text-black/80">
                  <a href="/" class="transition-colors hover:text-black">Home</a>
                  <span class="mx-2.5 text-black/20">/</span>
                  <span class="font-medium text-black">FAQ</span>
                </p>
              </div>
            </div>
            <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-[25%] -rotate-90 origin-center pointer-events-none select-none" aria-hidden="true">
              <span class="text-[140px] sm:text-[180px] font-extralight tracking-tighter text-transparent" style="-webkit-text-stroke: 1px rgba(255,255,255,0.08);">FAQ</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories Grid: unified card, no gaps, only outer corners rounded -->
    <section class="mx-auto max-w-5xl px-6 pb-24 pt-8 sm:px-12 lg:px-16">
      <p class="text-[11px] font-medium uppercase tracking-widest text-black/40 mb-8">Choose a topic</p>
      <div class="rounded-xl overflow-hidden grid grid-cols-1 sm:grid-cols-2">
        {displayCategories.map((cat, i) => {
          const isCheckerboard = (i % 2 === 0 && Math.floor(i / 2) % 2 === 0) || (i % 2 === 1 && Math.floor(i / 2) % 2 === 1);
          const bg = isCheckerboard ? '#f2f2f2' : '#ffffff';
          return (
            <a
              href={`/faq/${cat.slug}`}
              class="group relative p-8 block transition-colors duration-300"
              style={`background-color:${bg};`}
            >
              <div class="relative z-10">
                <div class="w-10 h-10 rounded-md flex items-center justify-center mb-5 bg-white/70 group-hover:bg-[rgb(200,90,70)] transition-colors">
                  <svg class="w-5 h-5 text-black group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d={categoryIcons[cat.slug] || categoryIcons.general} />
                  </svg>
                </div>
                <h2 class="text-lg font-black text-black tracking-tight mb-2">{cat.label}</h2>
                <p class="text-sm text-gray-500 leading-relaxed font-light mb-4">{cat.desc}</p>
                <span class="flex items-center text-[11px] font-bold uppercase tracking-widest text-black group-hover:text-[rgb(200,90,70)] transition-colors">
                  {cat.count > 0 ? `${cat.count} ${cat.count === 1 ? 'article' : 'articles'}` : 'Browse'}
                  <svg class="w-3 h-3 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
