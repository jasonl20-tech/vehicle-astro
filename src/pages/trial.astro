---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const benefits = [
  { title: 'No request limit', desc: 'Unlimited API calls during your trial. Test as much as you need within the trial scope.' },
  { title: 'Limited catalog', desc: 'A small set of vehicles and models, with restricted options (e.g. colors). Enough to integrate and validate the API.' },
  { title: '1 week key', desc: 'Your trial API key is valid for 7 days. No credit card required — no commitment, no auto-charge.' },
];
---

<BaseLayout
  title="Free Trial | Vehicle Imagery API"
  description="Request your free Vehicle Imagery API trial. Limited vehicles and options, 1 week key, no request limit, no credit card. Get started in minutes."
  canonicalUrl="/trial"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 pt-24 pb-8 sm:px-12 lg:px-16">
      <div class="max-w-3xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Try Now</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-[0.95] text-black tracking-tight mb-8">
          Free Trial
        </h1>
        <p class="text-[16px] text-black/50 leading-relaxed max-w-lg">
          Get your trial API key in minutes. Limited vehicles and options to test the API — no request limit, key valid for 1 week, no credit card required.
        </p>
        <p class="mt-6 text-[13px] text-black/40">
          <a href="/pricing" class="hover:text-[rgb(200,90,70)] transition-colors">View all plans →</a>
        </p>
      </div>
    </section>

    <!-- Main: Benefits + form -->
    <section class="mx-auto max-w-[1400px] px-6 pt-16 pb-24 sm:px-12 lg:px-16">
      <div class="grid gap-16 lg:grid-cols-[1fr_1fr] items-start">

        <!-- Left: What you get -->
        <div>
          <div class="rounded-[2rem] overflow-hidden border border-black/[0.06] bg-[#fafafa] p-10 sm:p-12 mb-12">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-full inline-block mb-6">Free</span>
            <h2 class="text-4xl sm:text-5xl font-light text-black tracking-tight leading-[1.05] mb-6">
              What's included
            </h2>
            <p class="text-[14px] text-black/50 leading-relaxed mb-10 max-w-md">
              A focused trial: limited vehicles and models, restricted options (e.g. colors). Same API, same quality — ideal to integrate and test.
            </p>
            <ul class="space-y-4">
              {benefits.map((b) => (
                <li class="flex gap-4">
                  <span class="shrink-0 w-6 h-6 rounded-full bg-[rgb(200,90,70)]/10 flex items-center justify-center">
                    <svg class="w-3 h-3 text-[rgb(200,90,70)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </span>
                  <div>
                    <p class="text-[14px] font-medium text-black">{b.title}</p>
                    <p class="text-[13px] text-black/50 leading-relaxed">{b.desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <div class="grid grid-cols-3 gap-6">
            <div>
              <p class="text-2xl font-light text-black tracking-tight">7 days</p>
              <p class="text-[10px] text-black/40 uppercase tracking-wider mt-1">Key validity</p>
            </div>
            <div>
              <p class="text-2xl font-light text-black tracking-tight">No limit</p>
              <p class="text-[10px] text-black/40 uppercase tracking-wider mt-1">Requests</p>
            </div>
            <div>
              <p class="text-2xl font-light text-black tracking-tight">No CC</p>
              <p class="text-[10px] text-black/40 uppercase tracking-wider mt-1">Required</p>
            </div>
          </div>
        </div>

        <!-- Right: Trial request form -->
        <div class="group relative rounded-[2rem] overflow-hidden transition-all duration-500 hover:shadow-[0_40px_80px_-20px_rgba(10,43,49,0.35)]" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[rgb(200,90,70)] via-[rgb(200,90,70)]/40 to-transparent"></div>
          <div class="relative p-10 sm:p-14">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/20 mb-4 block">Request access</span>
            <h3 class="text-3xl sm:text-4xl font-light text-white tracking-tight leading-[1.05] mb-4">
              Get your API key
            </h3>
            <p class="text-[14px] text-white/40 leading-relaxed mb-10 max-w-sm">
              Enter your email and we'll send you the trial details and your API key.
            </p>

            <form class="space-y-5" action="https://submit-form.com/v6dFS1FAS" method="POST">
              <input type="hidden" name="subject" value="Free Trial Request" />
              <input type="hidden" name="_redirect" value="/trial?sent=1" />

              <div>
                <input type="email" name="email" required placeholder="Work email" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
              </div>

              <div class="pt-4">
                <button type="submit" class="group/btn inline-flex items-center justify-center rounded-full px-8 py-4 text-[13px] font-medium transition-all duration-300 bg-white text-black hover:bg-[rgb(200,90,70)] hover:text-white w-full sm:w-auto">
                  <span>Request Free Trial</span>
                  <svg class="w-4 h-4 ml-2 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="pb-24 sm:pb-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] px-8 py-16 sm:px-16 sm:py-20" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-10">
            <div class="max-w-xl">
              <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Next steps</p>
              <h2 class="text-3xl sm:text-4xl font-light tracking-tight text-white leading-[1.05] mb-4">
                Need the full catalog?
              </h2>
              <p class="text-[14px] text-white/40 leading-relaxed">
                Get access to all vehicles, models, and options. Check our pricing or book a call to discuss your needs.
              </p>
            </div>
            <div class="flex flex-col sm:flex-row gap-4 shrink-0">
              <a href="/pricing" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[13px] font-medium text-black transition-all duration-300 hover:bg-[rgb(200,90,70)] hover:text-white">
                View Pricing
              </a>
              <a href="/documentation" class="inline-flex items-center justify-center rounded-full border border-white/15 px-8 py-4 text-[13px] font-medium text-white/70 transition-all duration-300 hover:bg-white/10 hover:text-white">
                Documentation
              </a>
              <a href="/book-a-call" class="inline-flex items-center justify-center rounded-full border border-white/15 px-8 py-4 text-[13px] font-medium text-white/70 transition-all duration-300 hover:bg-white/10 hover:text-white">
                Book a Call
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
