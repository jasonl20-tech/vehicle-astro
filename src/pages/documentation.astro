---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const BASE = 'https://api.vehicleimagery.com';

const sections = [
  {
    id: 'auth',
    label: 'Authentication',
    title: 'Authenticate with your API key',
    desc: `Every request requires an <code>x-api-key</code> header. Get your key from the dashboard or contact sales. Keep it server-side — never expose it in client code.`,
    code: `curl -H "x-api-key: YOUR_API_KEY" \\
  ${BASE}/api/brands`,
    codeLang: 'bash',
    response: null,
  },
  {
    id: 'brands',
    label: 'List Brands',
    title: 'Get all available brands',
    desc: 'Returns every vehicle brand in the database. Use the optional <code>format</code> and <code>resolution</code> query parameters to filter.',
    code: `GET /api/brands`,
    codeLang: 'http',
    response: `{
  "brands": [
    "Audi",
    "BMW",
    "Mercedes-Benz",
    "Volkswagen",
    "Toyota",
    ...
  ]
}`,
  },
  {
    id: 'models',
    label: 'List Models',
    title: 'Get models for a brand',
    desc: 'Pass a brand name as a path parameter to retrieve all models available for that brand.',
    code: `GET /api/{brand}
GET /api/BMW`,
    codeLang: 'http',
    response: `{
  "brand": "BMW",
  "resolution": "default",
  "format": "png",
  "models": [
    "1 Series",
    "3 Series",
    "X5",
    "iX",
    ...
  ]
}`,
  },
  {
    id: 'years',
    label: 'List Years',
    title: 'Get available years',
    desc: 'Returns every model year available for a specific brand and model combination.',
    code: `GET /api/{brand}/{model}
GET /api/BMW/X5`,
    codeLang: 'http',
    response: `[{
  "brand": "BMW",
  "model": "X5",
  "years": [2020, 2021, 2022, 2023, 2024]
}]`,
  },
  {
    id: 'variants',
    label: 'List Variants',
    title: 'Get body variants',
    desc: 'Returns all body variants (e.g. Sedan, SUV, Wagon) available for a specific model year.',
    code: `GET /api/{brand}/{model}/{year}
GET /api/BMW/X5/2024`,
    codeLang: 'http',
    response: `[{
  "brand": "BMW",
  "model": "X5",
  "year": 2024,
  "variants": ["SUV"]
}]`,
  },
  {
    id: 'trims',
    label: 'List Trims',
    title: 'Get trim levels',
    desc: 'Returns all available trims for a given variant. Trims represent specific equipment lines.',
    code: `GET /api/{brand}/{model}/{year}/{variant}
GET /api/BMW/X5/2024/SUV`,
    codeLang: 'http',
    response: `[{
  "brand": "BMW",
  "model": "X5",
  "year": 2024,
  "variant": "SUV",
  "trims": ["xDrive40i", "M60i"]
}]`,
  },
  {
    id: 'views',
    label: 'List Views',
    title: 'Get camera angles',
    desc: 'Returns all available views (camera angles) for a configuration. Views marked <code>"not_allowed"</code> are restricted by your plan.',
    code: `GET /api/{brand}/{model}/{year}/{variant}/{trim}
GET /api/BMW/X5/2024/SUV/xDrive40i`,
    codeLang: 'http',
    response: `[{
  "id": "a1b2c3d4e5f6",
  "brand": "BMW",
  "model": "X5",
  "views": {
    "front": true,
    "front-left": true,
    "side-left": true,
    "rear": true,
    "cockpit": "not_allowed"
  }
}]`,
  },
  {
    id: 'colors',
    label: 'List Colors',
    title: 'Get available colors',
    desc: 'Returns all colors for a specific vehicle. Only colors allowed by your plan are returned.',
    code: `GET /api/{brand}/{model}/{year}/{variant}/{trim}/colors
GET /api/BMW/X5/2024/SUV/xDrive40i/colors`,
    codeLang: 'http',
    response: `[{
  "id": "a1b2c3d4e5f6",
  "brand": "BMW",
  "model": "X5",
  "colors": [
    "default", "Blue", "Black",
    "White", "Silver"
  ]
}]`,
  },
  {
    id: 'features',
    label: 'List Features',
    title: 'Check image features',
    desc: 'Returns which image features (shadow, transparency) are available. Features marked <code>"not_allowed"</code> require a plan upgrade.',
    code: `GET /api/{brand}/{model}/{year}/{variant}/{trim}/features
GET /api/BMW/X5/2024/SUV/xDrive40i/features`,
    codeLang: 'http',
    response: `[{
  "id": "a1b2c3d4e5f6",
  "features": {
    "shadow": true,
    "transparent": true,
    "shadow_and_transparent": true
  }
}]`,
  },
  {
    id: 'image',
    label: 'Get Image',
    title: 'Retrieve a vehicle image',
    desc: `The main endpoint. Returns a signed CDN URL valid for 7 days. Use query parameters to control <code>color</code>, <code>shadow</code>, and <code>transparency</code>.`,
    code: `GET /api/{brand}/{model}/{year}/{variant}/{trim}/{view}
GET /api/BMW/X5/2024/SUV/xDrive40i/front-left
    ?color=Blue&shadow=true&transparency=false`,
    codeLang: 'http',
    response: `[{
  "id": "a1b2c3d4e5f6",
  "brand": "BMW",
  "model": "X5",
  "year": 2024,
  "view": "front-left",
  "settings": {
    "color": "Blue",
    "shadow": true,
    "transparency": false,
    "watermark": false
  },
  "image_url": "https://cdn.vehicle.pics/v1/png/...",
  "errornotes": []
}]`,
  },
  {
    id: 'resolutions',
    label: 'List Resolutions',
    title: 'Available resolutions',
    desc: 'Returns all image resolutions available. Higher resolutions may require a higher-tier plan.',
    code: `GET /api/resolutions`,
    codeLang: 'http',
    response: `{
  "resolutions": ["default", "high", "ultra"]
}`,
  },
  {
    id: 'formats',
    label: 'List Formats',
    title: 'Available formats',
    desc: 'Returns all image formats available. Filtered by your plan permissions.',
    code: `GET /api/formats`,
    codeLang: 'http',
    response: `{
  "formats": ["png", "webp"]
}`,
  },
  {
    id: 'getall',
    label: 'Get All',
    title: 'Export entire catalog',
    desc: 'Returns every vehicle configuration expanded by year. Requires special <code>getall</code> permission. Useful for building local caches.',
    code: `GET /api/getall`,
    codeLang: 'http',
    response: `[
  {
    "brand": "BMW",
    "model": "X5",
    "variant": "SUV",
    "trim": "xDrive40i",
    "year": 2024,
    "resolution": "default",
    "format": "png",
    "color": "default"
  },
  ...
]`,
  },
];
---

<BaseLayout
  title="API Documentation | Vehicle Imagery"
  description="Complete API reference for the Vehicle Imagery API. Endpoints, authentication, parameters, and response formats."
  canonicalUrl="/documentation"
>
  <Header />
  <main class="min-h-screen" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero: split layout -->
    <section class="grid grid-cols-1 lg:grid-cols-2 min-h-[70vh]">
      <div class="bg-white flex items-center px-8 sm:px-16 lg:px-20 xl:px-28 py-20">
        <div class="max-w-lg">
          <p class="text-[11px] font-medium text-black/40 uppercase tracking-[0.2em] mb-6">API Reference v1</p>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-light tracking-tight text-black leading-[1.05] mb-6">
            Vehicle Imagery<br/>API Docs.
          </h1>
          <p class="text-[15px] text-black/50 leading-relaxed mb-10 max-w-md">
            Integrate studio-quality vehicle photography into your product. RESTful, predictable, fast.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="#auth" class="inline-flex items-center gap-2 rounded-full bg-black px-6 py-3 text-[13px] font-medium text-white hover:bg-[rgb(200,90,70)] transition-colors">
              Get Started
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </a>
            <a href="/contact" class="inline-flex items-center rounded-full border border-black/15 px-6 py-3 text-[13px] font-medium text-black hover:border-black/40 transition-colors">
              Get API Key
            </a>
          </div>
        </div>
      </div>
      <div class="hidden lg:flex items-center justify-center relative overflow-hidden" style="background-color: rgb(10, 43, 49);">
        <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 24px 24px;" aria-hidden="true"></div>
        <div class="relative z-10 w-full max-w-md px-8">
          <div class="rounded-xl bg-black/30 backdrop-blur-sm border border-white/10 overflow-hidden shadow-2xl">
            <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-white/5">
              <div class="w-2 h-2 rounded-full bg-[#ff5f56]"></div>
              <div class="w-2 h-2 rounded-full bg-[#ffbd2e]"></div>
              <div class="w-2 h-2 rounded-full bg-[#27c93f]"></div>
              <span class="ml-2 text-[10px] text-white/30 font-mono">quickstart.js</span>
            </div>
            <pre class="p-5 text-[12px] sm:text-[13px] text-gray-300 font-mono leading-[1.8] overflow-x-auto"><code><span class="text-[#c586c0]">const</span> res <span class="text-white/40">=</span> <span class="text-[#c586c0]">await</span> <span class="text-[#dcdcaa]">fetch</span>(
  <span class="text-[#ce9178]">'{BASE}/api/BMW/X5/2024/SUV/xDrive40i/front-left'</span>,
  <span class="text-white/60">&#123;</span>
    headers: <span class="text-white/60">&#123;</span>
      <span class="text-[#ce9178]">'x-api-key'</span>: <span class="text-[#ce9178]">'YOUR_KEY'</span>
    <span class="text-white/60">&#125;</span>
  <span class="text-white/60">&#125;</span>
);

<span class="text-[#c586c0]">const</span> data <span class="text-white/40">=</span> <span class="text-[#c586c0]">await</span> res.<span class="text-[#dcdcaa]">json</span>();
console.<span class="text-[#dcdcaa]">log</span>(data[<span class="text-[#b5cea8]">0</span>].image_url);
<span class="text-[#6a9955]">// → https://cdn.vehicle.pics/v1/...</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Sticky nav bar -->
    <nav class="sticky top-0 z-40 bg-white/90 backdrop-blur-lg border-b border-black/5">
      <div class="overflow-x-auto scrollbar-hide">
        <div class="flex items-center gap-0 px-4 min-w-max">
          {sections.map((s) => (
            <a href={`#${s.id}`} class="px-4 py-3.5 text-[11px] font-medium uppercase tracking-wider text-black/40 hover:text-black transition-colors whitespace-nowrap border-b-2 border-transparent hover:border-black">
              {s.label}
            </a>
          ))}
          <a href="#errors" class="px-4 py-3.5 text-[11px] font-medium uppercase tracking-wider text-black/40 hover:text-black transition-colors whitespace-nowrap border-b-2 border-transparent hover:border-black">
            Errors
          </a>
          <a href="#params" class="px-4 py-3.5 text-[11px] font-medium uppercase tracking-wider text-black/40 hover:text-black transition-colors whitespace-nowrap border-b-2 border-transparent hover:border-black">
            Parameters
          </a>
        </div>
      </div>
    </nav>

    <!-- Base URL bar -->
    <section class="bg-[#f8f8f8] border-b border-black/5">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 px-8 sm:px-16 lg:px-20 xl:px-28 py-5">
        <div class="flex items-center gap-3">
          <span class="text-[10px] font-medium text-black/40 uppercase tracking-widest">Base URL</span>
          <code class="text-[14px] font-mono text-black font-medium">{BASE}</code>
        </div>
        <div class="flex items-center gap-3 text-[11px] text-black/40">
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>All endpoints return JSON</span>
          <span>·</span>
          <span>CORS enabled</span>
          <span>·</span>
          <span>HTTPS only</span>
        </div>
      </div>
    </section>

    <!-- Endpoint sections (alternating split layout) -->
    {sections.map((s, i) => (
      <section id={s.id} class="scroll-mt-12 grid grid-cols-1 lg:grid-cols-2 border-b border-black/5">
        <!-- Left: explanation -->
        <div class={`px-8 sm:px-16 lg:px-20 xl:px-28 py-16 lg:py-20 ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafafa]'}`}>
          <div class="max-w-lg">
            <div class="flex items-center gap-3 mb-5">
              <span class="text-[10px] font-bold text-emerald-700 bg-emerald-50 px-2 py-1 rounded font-mono tracking-wider">GET</span>
              <code class="text-[13px] font-mono text-black/60 break-all">{s.code.split('\n')[0].replace('GET ', '')}</code>
            </div>
            <h2 class="text-2xl sm:text-3xl font-normal text-black tracking-tight mb-4 leading-[1.2]">{s.title}</h2>
            <p class="text-[14px] text-black/55 leading-relaxed" set:html={s.desc}></p>

            {s.id === 'image' && (
              <div class="mt-8 space-y-3">
                <h4 class="text-[10px] font-medium text-black/40 uppercase tracking-widest">Image-specific parameters</h4>
                {[
                  { p: 'color', d: 'Vehicle color (e.g. Blue, Black)', def: 'default' },
                  { p: 'shadow', d: 'Ground shadow under the car', def: 'false' },
                  { p: 'transparency', d: 'Transparent PNG background', def: 'false' },
                ].map((param) => (
                  <div class="flex items-start gap-3 py-2 px-3 bg-black/[0.03] rounded-lg">
                    <code class="text-[11px] font-mono text-black shrink-0 mt-0.5">{param.p}</code>
                    <span class="text-[12px] text-black/40 shrink-0 mt-0.5">= {param.def}</span>
                    <span class="text-[12px] text-black/55">{param.d}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
        <!-- Right: code -->
        <div class="px-8 sm:px-12 lg:px-16 py-16 lg:py-20 flex flex-col justify-center" style="background-color: rgb(24, 24, 27);">
          <div class="max-w-lg mx-auto w-full">
            {s.code.split('\n').length > 1 && s.id !== 'auth' && (
              <div class="mb-6">
                <p class="text-[10px] font-medium text-white/30 uppercase tracking-widest mb-2">Request</p>
                <pre class="text-[13px] font-mono text-white/80 leading-relaxed"><code>{s.code}</code></pre>
              </div>
            )}
            {s.id === 'auth' && (
              <div class="mb-6">
                <p class="text-[10px] font-medium text-white/30 uppercase tracking-widest mb-2">Request</p>
                <pre class="text-[13px] font-mono text-white/80 leading-relaxed"><code>{s.code}</code></pre>
              </div>
            )}
            {s.response && (
              <div>
                <p class="text-[10px] font-medium text-white/30 uppercase tracking-widest mb-2">Response</p>
                <div class="rounded-lg bg-white/[0.04] border border-white/[0.06] p-5 overflow-x-auto">
                  <pre class="text-[12px] sm:text-[13px] font-mono text-emerald-300/90 leading-relaxed"><code>{s.response}</code></pre>
                </div>
              </div>
            )}
            {s.id === 'auth' && (
              <div class="mt-6 p-4 rounded-lg border border-amber-400/20 bg-amber-400/5">
                <p class="text-[12px] text-amber-200/80 leading-relaxed">
                  <strong class="text-amber-200">Keep your key secret.</strong> Never expose it in client-side JavaScript. Use a server-side proxy.
                </p>
              </div>
            )}
          </div>
        </div>
      </section>
    ))}

    <!-- Global Parameters -->
    <section id="params" class="scroll-mt-12 grid grid-cols-1 lg:grid-cols-2 border-b border-black/5">
      <div class="px-8 sm:px-16 lg:px-20 xl:px-28 py-16 lg:py-20 bg-white">
        <div class="max-w-lg">
          <h2 class="text-2xl sm:text-3xl font-normal text-black tracking-tight mb-4 leading-[1.2]">Global Query Parameters</h2>
          <p class="text-[14px] text-black/55 leading-relaxed mb-8">
            These parameters can be appended to most endpoints. They filter results based on your plan permissions.
          </p>
          <div class="space-y-4">
            {[
              { name: 'format', default: 'png', desc: 'Image format. Depends on plan.' },
              { name: 'resolution', default: 'default', desc: 'Image resolution. Higher tiers unlock more.' },
              { name: 'color', default: 'default', desc: 'Vehicle color. Image endpoint only.' },
              { name: 'shadow', default: 'false', desc: 'Ground shadow. Plan-dependent.' },
              { name: 'transparency', default: 'false', desc: 'Transparent background. Plan-dependent.' },
              { name: 'debug', default: 'false', desc: 'Debug mode. Requires plan permission.' },
            ].map((p) => (
              <div class="flex items-start gap-4 py-3 border-b border-black/5 last:border-b-0">
                <code class="text-[12px] font-mono text-black bg-[#f4f4f5] px-2 py-0.5 rounded shrink-0">{p.name}</code>
                <div class="flex-1">
                  <span class="text-[13px] text-black/60">{p.desc}</span>
                  <span class="ml-2 text-[11px] text-black/30 font-mono">default: {p.default}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="px-8 sm:px-12 lg:px-16 py-16 lg:py-20 flex flex-col justify-center" style="background-color: rgb(24, 24, 27);">
        <div class="max-w-lg mx-auto w-full">
          <p class="text-[10px] font-medium text-white/30 uppercase tracking-widest mb-4">API Hierarchy</p>
          <p class="text-[13px] text-white/50 leading-relaxed mb-6">Navigate step by step from brand to image:</p>
          <div class="space-y-2">
            {[
              { step: '1', path: '/api/brands', label: 'Brands' },
              { step: '2', path: '/api/{brand}', label: 'Models' },
              { step: '3', path: '/api/{brand}/{model}', label: 'Years' },
              { step: '4', path: '/api/{brand}/{model}/{year}', label: 'Variants' },
              { step: '5', path: '/api/{brand}/{model}/{year}/{variant}', label: 'Trims' },
              { step: '6', path: '/api/.../{trim}', label: 'Views' },
              { step: '7', path: '/api/.../{trim}/{view}', label: 'Image URL' },
            ].map((h) => (
              <div class="flex items-center gap-3 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/[0.04]">
                <span class="text-[10px] font-mono text-white/25 w-4">{h.step}</span>
                <code class="text-[11px] font-mono text-emerald-300/70 flex-1 truncate">{h.path}</code>
                <span class="text-[11px] text-white/40">{h.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Errors & Fallbacks -->
    <section id="errors" class="scroll-mt-12 grid grid-cols-1 lg:grid-cols-2 border-b border-black/5">
      <div class="px-8 sm:px-16 lg:px-20 xl:px-28 py-16 lg:py-20 bg-[#fafafa]">
        <div class="max-w-lg">
          <h2 class="text-2xl sm:text-3xl font-normal text-black tracking-tight mb-4 leading-[1.2]">Error Handling</h2>
          <p class="text-[14px] text-black/55 leading-relaxed mb-8">
            Standard HTTP status codes. Every error includes a JSON body with a descriptive <code class="text-[12px] bg-white px-1.5 py-0.5 rounded text-black font-mono">error</code> field.
          </p>
          <div class="space-y-0">
            {[
              { code: '200', color: 'text-emerald-700 bg-emerald-50', desc: 'Success. Data returned.' },
              { code: '400', color: 'text-amber-700 bg-amber-50', desc: 'Bad request (e.g. invalid year).' },
              { code: '401', color: 'text-red-700 bg-red-50', desc: 'Missing API key header.' },
              { code: '403', color: 'text-red-700 bg-red-50', desc: 'Invalid key or restricted resource.' },
              { code: '404', color: 'text-orange-700 bg-orange-50', desc: 'Resource not found.' },
              { code: '500', color: 'text-red-700 bg-red-50', desc: 'Server error. Contact support.' },
            ].map((e) => (
              <div class="flex items-center gap-4 py-3.5 border-b border-black/5 last:border-b-0">
                <code class={`text-[12px] font-mono font-bold px-2.5 py-1 rounded ${e.color}`}>{e.code}</code>
                <span class="text-[13px] text-black/60">{e.desc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="px-8 sm:px-12 lg:px-16 py-16 lg:py-20 flex flex-col justify-center" style="background-color: rgb(24, 24, 27);">
        <div class="max-w-lg mx-auto w-full">
          <p class="text-[10px] font-medium text-white/30 uppercase tracking-widest mb-4">Fallback Codes (errornotes)</p>
          <p class="text-[13px] text-white/40 leading-relaxed mb-6">When the API falls back to an alternative, it tells you why:</p>
          <div class="space-y-2">
            {[
              { code: 'P11', desc: 'Format/resolution fell back to plan default' },
              { code: 'F04', desc: 'Requested color not found — using default' },
              { code: 'C09', desc: 'Color blocked by plan — using default' },
              { code: 'R08', desc: 'Resolution unavailable — nearest used' },
              { code: 'S05', desc: 'Shadow unavailable — returned without' },
              { code: 'S12', desc: 'Only shadow version exists — shadow applied' },
              { code: 'T06', desc: 'Transparency unavailable — returned opaque' },
              { code: 'T13', desc: 'Only transparent version — transparency applied' },
            ].map((n) => (
              <div class="flex items-start gap-3 py-2.5 px-3 rounded-lg bg-white/[0.03] border border-white/[0.04]">
                <code class="text-[11px] font-mono text-amber-300/80 shrink-0 mt-0.5">{n.code}</code>
                <span class="text-[12px] text-white/50">{n.desc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Performance stats -->
    <section class="bg-white">
      <div class="grid grid-cols-2 sm:grid-cols-4 border-b border-black/5">
        {[
          { value: '50ms', label: 'Avg. Response' },
          { value: '99.9%', label: 'Uptime SLA' },
          { value: '7 days', label: 'URL Validity' },
          { value: '40k+', label: 'Vehicle Assets' },
        ].map((stat) => (
          <div class="px-8 sm:px-12 py-10 text-center border-r border-black/5 last:border-r-0">
            <p class="text-2xl sm:text-3xl font-light text-black tracking-tight mb-1">{stat.value}</p>
            <p class="text-[10px] font-medium text-black/40 uppercase tracking-widest">{stat.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="grid grid-cols-1 lg:grid-cols-2">
