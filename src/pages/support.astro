---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getSiteStats } from '../lib/contentful';

const stats = await getSiteStats();

const channels = [
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>',
    title: 'Email Support',
    desc: 'For general questions, billing, and account issues.',
    contact: 'support@vehicleimagery.com',
    href: 'mailto:support@vehicleimagery.com',
    response: 'Within 24 hours',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/>',
    title: 'Technical Support',
    desc: 'API integration help, error debugging, and technical guidance.',
    contact: 'dev@vehicleimagery.com',
    href: 'mailto:dev@vehicleimagery.com',
    response: 'Within 12 hours',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>',
    title: 'Documentation',
    desc: 'Full API reference, endpoints, parameters, and code examples.',
    contact: 'Browse Docs',
    href: '/documentation',
    response: 'Self-service',
  },
];

const faqs = [
  { q: 'How do I get my API key?', a: 'Contact us via the form below or email support@vehicleimagery.com. We\'ll set up your account and send your key within 24 hours.' },
  { q: 'My API key is not working', a: 'Check that you\'re sending the key via the x-api-key header. If you\'re getting a 403, your key may have expired or the requested resource may not be part of your plan.' },
  { q: 'I\'m getting 404 errors', a: 'Make sure the brand, model, year, variant, and trim all exist in our database. Use the /api/brands endpoint to start and navigate the hierarchy step by step.' },
  { q: 'Images are loading slowly', a: `Our average latency is ~${stats.latency}. If you're experiencing slowness, check your CDN caching. Signed URLs are valid for ${stats.signedUrlExpiry} — cache them on your end for best performance.` },
  { q: 'How do I upgrade my plan?', a: 'Contact sales at info@vehicleimagery.com. Plan changes take effect immediately. No downtime.' },
  { q: 'Do you offer on-premise deployment?', a: 'Yes, on-premise and white-label options are available on our custom plans. Contact us for details.' },
];


---

<BaseLayout
  title="Support | Vehicle Imagery API"
  description="Get help with the Vehicle Imagery API. Technical support, documentation, and frequently asked questions."
  canonicalUrl="/support"
>
  <Header />
  <main class="min-h-screen bg-white" style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;">

    <!-- Hero -->
    <section class="mx-auto max-w-[1400px] px-6 pt-24 pb-8 sm:px-12 lg:px-16">
      <div class="max-w-3xl">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">Help Center</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-[0.95] text-black tracking-tight mb-8">
          Support
        </h1>
        <p class="text-[16px] text-black/50 leading-relaxed max-w-lg">
          Need help? Find answers, reach our team, or check the system status. We're here for you.
        </p>
      </div>
    </section>

    <!-- Support Channels -->
    <section class="mx-auto max-w-[1400px] px-6 pt-16 pb-24 sm:px-12 lg:px-16">
      <div class="grid gap-6 lg:grid-cols-3">
        {channels.map((ch) => (
          <a href={ch.href} class="group relative rounded-lg border border-black/[0.06] bg-white p-8 sm:p-10 transition-all duration-500 hover:border-black/10 hover:shadow-xl hover:shadow-black/5 flex flex-col">
            <div class="w-10 h-10 rounded-lg bg-black/[0.03] flex items-center justify-center mb-8 group-hover:bg-[rgb(200,90,70)]/10 transition-colors">
              <svg class="w-5 h-5 text-black/40 group-hover:text-[rgb(200,90,70)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={ch.icon} />
            </div>
            <h3 class="text-xl font-medium text-black mb-2 group-hover:text-[rgb(200,90,70)] transition-colors">{ch.title}</h3>
            <p class="text-[13px] text-black/45 leading-relaxed mb-6">{ch.desc}</p>
            <div class="mt-auto pt-6 border-t border-black/[0.04] flex items-center justify-between">
              <span class="text-[13px] font-medium text-black">{ch.contact}</span>
              <span class="text-[11px] text-black/30">{ch.response}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="grid gap-16 lg:grid-cols-[1fr_1.5fr] lg:gap-24 items-start">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[rgb(200,90,70)] mb-6">FAQ</p>
            <h2 class="text-3xl sm:text-4xl font-light leading-[1.05] text-black tracking-tight mb-6">
              Common<br/>questions
            </h2>
            <p class="text-[14px] text-black/50 leading-relaxed">
              Quick answers to the most common issues. Can't find yours? <a href="#contact" class="text-black underline underline-offset-4 hover:text-[rgb(200,90,70)] transition-colors">Contact us below</a>.
            </p>
          </div>

          <div class="space-y-0">
            {faqs.map((faq) => (
              <details class="group border-b border-black/[0.06] first:border-t">
                <summary class="flex items-center justify-between gap-6 py-7 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <span class="text-[15px] font-medium text-black group-hover:text-[rgb(200,90,70)] transition-colors">{faq.q}</span>
                  <svg class="w-5 h-5 shrink-0 text-black/20 group-open:rotate-45 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"></path>
                  </svg>
                </summary>
                <div class="pb-7 pr-16">
                  <p class="text-[13px] text-black/50 leading-relaxed">{faq.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form -->
    <section id="contact" class="pb-24 sm:pb-32">
      <div class="mx-auto max-w-[1400px] px-6 sm:px-12 lg:px-16">
        <div class="relative overflow-hidden rounded-[2rem] sm:rounded-[2.5rem] px-8 py-20 sm:px-16 sm:py-24" style="background-color: rgb(10, 43, 49);">
          <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
          <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full opacity-[0.04] pointer-events-none" style="background: radial-gradient(circle, white 0%, transparent 60%);" aria-hidden="true"></div>

          <div class="relative z-10 grid gap-12 lg:grid-cols-[1fr_1fr] lg:gap-20 items-start">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Contact Support</p>
              <h2 class="text-4xl sm:text-5xl font-light tracking-tight text-white leading-[1.05] mb-6">
                Still need help?
              </h2>
              <p class="text-[14px] text-white/40 leading-relaxed mb-10 max-w-sm">
                Describe your issue and our team will get back to you as quickly as possible.
              </p>
              <div class="space-y-4">
                <div>
                  <p class="text-[11px] text-white/25 uppercase tracking-wider mb-1">Support</p>
                  <a href="mailto:support@vehicleimagery.com" class="text-[14px] text-white/70 hover:text-white transition-colors">support@vehicleimagery.com</a>
                </div>
                <div>
                  <p class="text-[11px] text-white/25 uppercase tracking-wider mb-1">Technical</p>
                  <a href="mailto:dev@vehicleimagery.com" class="text-[14px] text-white/70 hover:text-white transition-colors">dev@vehicleimagery.com</a>
                </div>
              </div>
            </div>

            <div id="support-form-wrapper" class="transition-all duration-700 ease-out">
              <div id="support-form-content">
                <form id="support-form" class="space-y-5">
                  <input type="hidden" name="subject" value="Support Request – Vehicle Imagery" />

                  <div>
                    <input type="text" name="name" required placeholder="Your name" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <input type="email" name="email" required placeholder="Email" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <input type="text" name="subject_line" placeholder="Subject" class="w-full border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors" />
                  </div>
                  <div>
                    <textarea name="message" rows="3" required placeholder="Describe your issue in detail" class="w-full resize-none border-b border-white/10 bg-transparent px-0 py-3 text-[13px] text-white placeholder-white/25 focus:border-[rgb(200,90,70)] focus:outline-none transition-colors"></textarea>
                  </div>

                  <div class="pt-4">
                    <button type="submit" id="support-submit-btn" class="group/btn inline-flex items-center justify-center rounded-full px-8 py-4 text-[13px] font-medium transition-all duration-300 bg-white text-black hover:bg-[rgb(200,90,70)] hover:text-white">
                      <span>Submit Request</span>
                      <svg class="w-4 h-4 ml-2 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                      </svg>
                    </button>
                  </div>
                </form>
              </div>

              <div id="support-success" class="hidden flex-col items-center justify-center text-center py-12">
                <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-white/20">
                  <svg class="h-10 w-10 support-checkmark" viewBox="0 0 52 52" fill="none">
                    <circle cx="26" cy="26" r="24" stroke="white" stroke-width="2.5" fill="none" stroke-dasharray="150.8" stroke-dashoffset="150.8" class="support-circle" />
                    <path d="M15 27L23 35L37 19" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" stroke-dasharray="40" stroke-dashoffset="40" class="support-check" />
                  </svg>
                </div>
                <h3 class="text-2xl font-normal text-white mb-3">Request Sent!</h3>
                <p class="text-[14px] text-white/70 max-w-xs leading-relaxed">We'll get back to you as quickly as possible.</p>
              </div>
            </div>

            <style>
              @keyframes support-draw-circle { to { stroke-dashoffset: 0; } }
              @keyframes support-draw-check { to { stroke-dashoffset: 0; } }
              #support-form-wrapper.success .support-circle { animation: support-draw-circle 0.6s ease-out 0.2s forwards; }
              #support-form-wrapper.success .support-check { animation: support-draw-check 0.4s ease-out 0.7s forwards; }
            </style>

            <script>
              (function() {
                const form = document.getElementById('support-form');
                const wrapper = document.getElementById('support-form-wrapper');
                const formContent = document.getElementById('support-form-content');
                const successEl = document.getElementById('support-success');
                form.addEventListener('submit', (e) => {
                  e.preventDefault();
                  const data = Object.fromEntries(new FormData(form).entries());
                  fetch('https://submit-form.com/v6dFS1FAS', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify(data) }).catch(() => {});
                  formContent.style.opacity = '0'; formContent.style.transform = 'scale(0.95)'; formContent.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                  setTimeout(() => { formContent.classList.add('hidden'); wrapper.classList.add('success'); successEl.classList.remove('hidden'); successEl.classList.add('flex'); successEl.style.opacity = '0'; successEl.style.transform = 'scale(0.95)'; requestAnimationFrame(() => { successEl.style.transition = 'opacity 0.5s ease 0.1s, transform 0.5s ease 0.1s'; successEl.style.opacity = '1'; successEl.style.transform = 'scale(1)'; }); }, 300);
                });
              })();
            </script>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
