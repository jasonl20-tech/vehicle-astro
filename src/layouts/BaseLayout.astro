---
import '../styles/global.css';

const defaultKeywords = 'vehicle imagery API, car stock photos API, automotive imagery API, vehicle photography API, car images API, vehicle stock imagery, automotive stock photos, vehicle imagery for dealerships, car stock photos for websites, vehicle photography API documentation, automotive imagery API Europe';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  keywords?: string;
}

const { title, description = '', ogImage, ogImageAlt = '', canonicalUrl, noIndex = false, keywords = defaultKeywords } = Astro.props;
const siteUrl = Astro.url.origin;
const defaultOgImage = `${siteUrl}/images/hero-car.webp`;
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage.startsWith('/') ? '' : '/'}${ogImage}`)
  : defaultOgImage;
const ogUrl = canonicalUrl ? `${siteUrl}${canonicalUrl.startsWith('/') ? '' : '/'}${canonicalUrl}` : Astro.url.href;
const ogImageWidth = 1200;
const ogImageHeight = 630;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" type="image/x-icon" />
    <link rel="icon" href="/favicon-192.png" sizes="192x192" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" type="image/png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    {noIndex ? <meta name="robots" content="noindex" /> : <meta name="robots" content="index, follow" />}
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={`${siteUrl}${canonicalUrl.startsWith('/') ? '' : '/'}${canonicalUrl}`} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={ogImageHeight} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Vehicle Imagery API" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:width" content={ogImageWidth} />
    <meta name="twitter:image:height" content={ogImageHeight} />
    <link rel="preload" as="image" href="/images/hero-car.webp" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'Organization',
          '@id': `${siteUrl}/#organization`,
          name: 'Vehicle Imagery',
          url: siteUrl,
          logo: { '@type': 'ImageObject', url: `${siteUrl}/logo.svg` },
        },
        {
          '@type': 'WebSite',
          '@id': `${siteUrl}/#website`,
          url: siteUrl,
          name: 'Vehicle Imagery API',
          description: 'Studio-quality vehicle imagery API. Car stock photos for dealerships, leasing, and automotive platforms.',
          publisher: { '@id': `${siteUrl}/#organization` },
        },
      ]},
    )} />
    <!-- Silktide CSS non-blocking: lädt nach erstem Paint -->
    <link rel="stylesheet" href="/silktide/silktide-consent-manager.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="/silktide/silktide-consent-manager.css" /></noscript>
  </head>
  <body class="antialiased min-h-screen bg-cream text-gray-900">
    <slot />
    <script>
      document.addEventListener('contextmenu', (e) => {
        if (e.target && e.target.tagName === 'IMG') e.preventDefault();
      });
    </script>
    <!-- Silktide JS mit defer: blockiert nicht das Parsing, Init läuft wenn Script geladen -->
    <script is:inline defer src="/silktide/silktide-consent-manager.js"></script>
    <script is:inline>
      (function initSilktide() {
        var c = window.silktideConsentManager;
        if (c) {
          c.init({
            consentTypes: [
              { id: 'essential', label: 'Essential', description: 'Necessary for the website to function. Cannot be switched off.', required: true },
              { id: 'analytics', label: 'Analytics', description: 'Help us understand how visitors use the site.', defaultValue: true, gtag: 'analytics_storage' },
              { id: 'marketing', label: 'Marketing', description: 'Used to deliver relevant advertisements.', defaultValue: false, gtag: ['ad_storage', 'ad_user_data', 'ad_personalization'] },
            ],
            text: {
              prompt: { description: '<p>We use cookies to improve your experience and analyse traffic. Choose your preferences.</p>', acceptAllButtonText: 'Accept all', rejectNonEssentialButtonText: 'Reject non-essential', preferencesButtonText: 'Preferences' },
              preferences: { title: 'Cookie preferences', description: '<p>Choose which cookies you want to accept.</p>', saveButtonText: 'Save and close', creditLinkText: 'Free cookie banner by Silktide' },
            },
            prompt: { position: 'bottomRight' },
            icon: { position: 'bottomLeft' },
          });
          return;
        }
        function run() { setTimeout(initSilktide, 0); }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
        else run();
      })();
    </script>
    <style is:global>
      #stcm-wrapper {
        --primaryColor: #1C2B32;
        --backgroundColor: #FBFBF7;
        --textColor: #1C2B32;
        --iconColor: #1C2B32;
        --iconBackgroundColor: #FBFBF7;
      }
      /* Banner und Icon fest rechts */
      #stcm-banner.stcm-pos-bottom-right,
      #stcm-banner {
        left: auto !important;
        right: 16px !important;
      }
      #stcm-icon.stcm-pos-bottom-left,
      #stcm-icon {
        left: 10px !important;
        right: auto !important;
      }
    </style>
  </body>
</html>
