---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const { title, description = '', ogImage, ogImageAlt = '', canonicalUrl, noIndex = false } = Astro.props;
const siteUrl = Astro.url.origin;
const ogImageUrl = ogImage ? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage.startsWith('/') ? '' : '/'}${ogImage}`) : null;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex" />}
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={`${siteUrl}${canonicalUrl.startsWith('/') ? '' : '/'}${canonicalUrl}`} />}
    {ogImageUrl && (
      <>
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageUrl} />
        {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl ? `${siteUrl}${canonicalUrl.startsWith('/') ? '' : '/'}${canonicalUrl}` : Astro.url.href} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageUrl} />
      </>
    )}
    <link rel="preload" as="image" href="/images/hero-car.webp" />
    <link rel="stylesheet" href="/silktide/silktide-consent-manager.css" />
  </head>
  <body class="antialiased min-h-screen bg-cream text-gray-900">
    <slot />
    <script>
      document.addEventListener('contextmenu', (e) => {
        if (e.target && e.target.tagName === 'IMG') e.preventDefault();
      });
    </script>
    <script is:inline src="/silktide/silktide-consent-manager.js"></script>
    <script is:inline>
      window.silktideConsentManager.init({
        consentTypes: [
          {
            id: 'essential',
            label: 'Essential',
            description: 'Necessary for the website to function. Cannot be switched off.',
            required: true,
          },
          {
            id: 'analytics',
            label: 'Analytics',
            description: 'Help us understand how visitors use the site.',
            defaultValue: true,
            gtag: 'analytics_storage',
          },
          {
            id: 'marketing',
            label: 'Marketing',
            description: 'Used to deliver relevant advertisements.',
            defaultValue: false,
            gtag: ['ad_storage', 'ad_user_data', 'ad_personalization'],
          },
        ],
        text: {
          prompt: {
            description: '<p>We use cookies to improve your experience and analyse traffic. Choose your preferences.</p>',
            acceptAllButtonText: 'Accept all',
            rejectNonEssentialButtonText: 'Reject non-essential',
            preferencesButtonText: 'Preferences',
          },
          preferences: {
            title: 'Cookie preferences',
            description: '<p>Choose which cookies you want to accept.</p>',
            saveButtonText: 'Save and close',
            creditLinkText: 'Free cookie banner by Silktide',
          },
        },
        prompt: { position: 'bottomRight' },
        icon: { position: 'bottomRight' },
      });
    </script>
    <style is:global>
      #stcm-wrapper {
        --primaryColor: #1C2B32;
        --backgroundColor: #FBFBF7;
        --textColor: #1C2B32;
        --iconColor: #1C2B32;
        --iconBackgroundColor: #FBFBF7;
      }
    </style>
  </body>
</html>
