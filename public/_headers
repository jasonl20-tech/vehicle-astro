# Sitemap-Dateien: application/xml sorgt für korrekte XML-Anzeige im Browser
# (ohne dies wird die Datei als HTML interpretiert und die Tags sind unsichtbar)
/sitemap.xml
  Content-Type: application/xml; charset=utf-8

/sitemap-0.xml
  Content-Type: application/xml; charset=utf-8

/sitemap-index.xml
  Content-Type: application/xml; charset=utf-8

# Fallback für alle .xml-Dateien
/*.xml
  Content-Type: application/xml; charset=utf-8
